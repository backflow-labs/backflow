{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y8KyvbEnKvtPYsiahCkgwc","type":"tool_result","content":"     1→package models\n     2→\n     3→import (\n     4→\t\"encoding/json\"\n     5→\t\"fmt\"\n     6→\t\"time\"\n     7→)\n     8→\n     9→type TaskStatus string\n    10→\n    11→const (\n    12→\tTaskStatusPending      TaskStatus = \"pending\"\n    13→\tTaskStatusProvisioning TaskStatus = \"provisioning\"\n    14→\tTaskStatusRunning      TaskStatus = \"running\"\n    15→\tTaskStatusCompleted    TaskStatus = \"completed\"\n    16→\tTaskStatusFailed       TaskStatus = \"failed\"\n    17→\tTaskStatusInterrupted  TaskStatus = \"interrupted\"\n    18→\tTaskStatusCancelled    TaskStatus = \"cancelled\"\n    19→)\n    20→\n    21→func (s TaskStatus) IsTerminal() bool {\n    22→\treturn s == TaskStatusCompleted || s == TaskStatusFailed || s == TaskStatusCancelled\n    23→}\n    24→\n    25→type Task struct {\n    26→\tID            string     `json:\"id\"`\n    27→\tStatus        TaskStatus `json:\"status\"`\n    28→\tRepoURL       string     `json:\"repo_url\"`\n    29→\tBranch        string     `json:\"branch\"`\n    30→\tTargetBranch  string     `json:\"target_branch\"`\n    31→\tPrompt        string     `json:\"prompt\"`\n    32→\tContext       string     `json:\"context,omitempty\"`\n    33→\tModel         string     `json:\"model,omitempty\"`\n    34→\tEffort        string     `json:\"effort,omitempty\"`\n    35→\tMaxBudgetUSD  float64    `json:\"max_budget_usd,omitempty\"`\n    36→\tMaxRuntimeMin int        `json:\"max_runtime_min,omitempty\"`\n    37→\tMaxTurns      int        `json:\"max_turns,omitempty\"`\n    38→\tCreatePR      bool       `json:\"create_pr\"`\n    39→\tPRTitle       string     `json:\"pr_title,omitempty\"`\n    40→\tPRBody        string     `json:\"pr_body,omitempty\"`\n    41→\tPRURL         string     `json:\"pr_url,omitempty\"`\n    42→\tAllowedTools  []string   `json:\"allowed_tools,omitempty\"`\n    43→\tClaudeMD      string     `json:\"claude_md,omitempty\"`\n    44→\tEnvVars       map[string]string `json:\"env_vars,omitempty\"`\n    45→\tInstanceID    string     `json:\"instance_id,omitempty\"`\n    46→\tContainerID   string     `json:\"container_id,omitempty\"`\n    47→\tRetryCount    int        `json:\"retry_count\"`\n    48→\tCostUSD       float64    `json:\"cost_usd,omitempty\"`\n    49→\tError         string     `json:\"error,omitempty\"`\n    50→\tCreatedAt     time.Time  `json:\"created_at\"`\n    51→\tUpdatedAt     time.Time  `json:\"updated_at\"`\n    52→\tStartedAt     *time.Time `json:\"started_at,omitempty\"`\n    53→\tCompletedAt   *time.Time `json:\"completed_at,omitempty\"`\n    54→}\n    55→\n    56→// AllowedToolsJSON returns the JSON representation for DB storage.\n    57→func (t *Task) AllowedToolsJSON() string {\n    58→\tif len(t.AllowedTools) == 0 {\n    59→\t\treturn \"[]\"\n    60→\t}\n    61→\tb, _ := json.Marshal(t.AllowedTools)\n    62→\treturn string(b)\n    63→}\n    64→\n    65→// EnvVarsJSON returns the JSON representation for DB storage.\n    66→func (t *Task) EnvVarsJSON() string {\n    67→\tif len(t.EnvVars) == 0 {\n    68→\t\treturn \"{}\"\n    69→\t}\n    70→\tb, _ := json.Marshal(t.EnvVars)\n    71→\treturn string(b)\n    72→}\n    73→\n    74→// CreateTaskRequest is the API input for creating a task.\n    75→type CreateTaskRequest struct {\n    76→\tRepoURL       string            `json:\"repo_url\"`\n    77→\tBranch        string            `json:\"branch,omitempty\"`\n    78→\tTargetBranch  string            `json:\"target_branch,omitempty\"`\n    79→\tPrompt        string            `json:\"prompt\"`\n    80→\tContext       string            `json:\"context,omitempty\"`\n    81→\tModel         string            `json:\"model,omitempty\"`\n    82→\tEffort        string            `json:\"effort,omitempty\"`\n    83→\tMaxBudgetUSD  float64           `json:\"max_budget_usd,omitempty\"`\n    84→\tMaxRuntimeMin int               `json:\"max_runtime_min,omitempty\"`\n    85→\tMaxTurns      int               `json:\"max_turns,omitempty\"`\n    86→\tCreatePR      bool              `json:\"create_pr\"`\n    87→\tPRTitle       string            `json:\"pr_title,omitempty\"`\n    88→\tPRBody        string            `json:\"pr_body,omitempty\"`\n    89→\tAllowedTools  []string          `json:\"allowed_tools,omitempty\"`\n    90→\tClaudeMD      string            `json:\"claude_md,omitempty\"`\n    91→\tEnvVars       map[string]string `json:\"env_vars,omitempty\"`\n    92→}\n    93→\n    94→func (r *CreateTaskRequest) Validate() error {\n    95→\tif r.RepoURL == \"\" {\n    96→\t\treturn fmt.Errorf(\"repo_url is required\")\n    97→\t}\n    98→\tif r.Prompt == \"\" {\n    99→\t\treturn fmt.Errorf(\"prompt is required\")\n   100→\t}\n   101→\tif r.MaxBudgetUSD < 0 {\n   102→\t\treturn fmt.Errorf(\"max_budget_usd must be non-negative\")\n   103→\t}\n   104→\tif r.MaxRuntimeMin < 0 {\n   105→\t\treturn fmt.Errorf(\"max_runtime_min must be non-negative\")\n   106→\t}\n   107→\tif r.Effort != \"\" {\n   108→\t\tswitch r.Effort {\n   109→\t\tcase \"low\", \"medium\", \"high\", \"xhigh\":\n   110→\t\tdefault:\n   111→\t\t\treturn fmt.Errorf(\"effort must be low, medium, high, or xhigh\")\n   112→\t\t}\n   113→\t}\n   114→\treturn nil\n   115→}\n   116→"}]},"parent_tool_use_id":"toolu_01WjBDJU9gqMDSiqbdYofAYA","session_id":"2af19d51-84dc-4ce3-80b2-7d4b83aa4cbe","uuid":"e80a62c0-93c7-4d0c-a783-011731aa385e"}
