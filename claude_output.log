{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NnbSigFB29ZQc9H33tXokT","type":"tool_result","content":"     1→package notify\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"net/http\"\n     8→\t\"time\"\n     9→\n    10→\t\"github.com/rs/zerolog/log\"\n    11→)\n    12→\n    13→type EventType string\n    14→\n    15→const (\n    16→\tEventTaskCreated     EventType = \"task.created\"\n    17→\tEventTaskRunning     EventType = \"task.running\"\n    18→\tEventTaskCompleted   EventType = \"task.completed\"\n    19→\tEventTaskFailed      EventType = \"task.failed\"\n    20→\tEventTaskNeedsInput  EventType = \"task.needs_input\"\n    21→\tEventTaskInterrupted EventType = \"task.interrupted\"\n    22→)\n    23→\n    24→type Event struct {\n    25→\tType         EventType `json:\"event\"`\n    26→\tTaskID       string    `json:\"task_id\"`\n    27→\tRepoURL      string    `json:\"repo_url,omitempty\"`\n    28→\tPrompt       string    `json:\"prompt,omitempty\"`\n    29→\tMessage      string    `json:\"message,omitempty\"`\n    30→\tAgentLogTail string    `json:\"agent_log_tail,omitempty\"`\n    31→\tTimestamp    time.Time `json:\"timestamp\"`\n    32→}\n    33→\n    34→// Notifier sends notifications for task lifecycle events.\n    35→type Notifier interface {\n    36→\tNotify(event Event) error\n    37→}\n    38→\n    39→// NoopNotifier discards all events.\n    40→type NoopNotifier struct{}\n    41→\n    42→func (NoopNotifier) Notify(Event) error { return nil }\n    43→\n    44→// WebhookNotifier sends HTTP POST notifications.\n    45→type WebhookNotifier struct {\n    46→\turl        string\n    47→\tevents     map[EventType]bool // nil = all events\n    48→\thttpClient *http.Client\n    49→}\n    50→\n    51→func NewWebhookNotifier(url string, filterEvents []string) *WebhookNotifier {\n    52→\tw := &WebhookNotifier{\n    53→\t\turl: url,\n    54→\t\thttpClient: &http.Client{\n    55→\t\t\tTimeout: 10 * time.Second,\n    56→\t\t},\n    57→\t}\n    58→\tif len(filterEvents) > 0 {\n    59→\t\tw.events = make(map[EventType]bool, len(filterEvents))\n    60→\t\tfor _, e := range filterEvents {\n    61→\t\t\tw.events[EventType(e)] = true\n    62→\t\t}\n    63→\t}\n    64→\treturn w\n    65→}\n    66→\n    67→func (w *WebhookNotifier) Notify(event Event) error {\n    68→\tif w.events != nil && !w.events[event.Type] {\n    69→\t\treturn nil\n    70→\t}\n    71→\n    72→\tbody, err := json.Marshal(event)\n    73→\tif err != nil {\n    74→\t\treturn fmt.Errorf(\"marshal event: %w\", err)\n    75→\t}\n    76→\n    77→\tvar lastErr error\n    78→\tfor attempt := 0; attempt < 3; attempt++ {\n    79→\t\tif attempt > 0 {\n    80→\t\t\ttime.Sleep(time.Duration(attempt) * 2 * time.Second)\n    81→\t\t}\n    82→\n    83→\t\treq, err := http.NewRequest(http.MethodPost, w.url, bytes.NewReader(body))\n    84→\t\tif err != nil {\n    85→\t\t\treturn fmt.Errorf(\"create request: %w\", err)\n    86→\t\t}\n    87→\t\treq.Header.Set(\"Content-Type\", \"application/json\")\n    88→\t\treq.Header.Set(\"User-Agent\", \"backflow-webhook/1.0\")\n    89→\n    90→\t\tresp, err := w.httpClient.Do(req)\n    91→\t\tif err != nil {\n    92→\t\t\tlastErr = err\n    93→\t\t\tlog.Warn().Err(err).Int(\"attempt\", attempt+1).Str(\"event\", string(event.Type)).Msg(\"webhook request failed\")\n    94→\t\t\tcontinue\n    95→\t\t}\n    96→\t\tresp.Body.Close()\n    97→\n    98→\t\tif resp.StatusCode >= 200 && resp.StatusCode < 300 {\n    99→\t\t\tlog.Debug().Str(\"event\", string(event.Type)).Str(\"task_id\", event.TaskID).Msg(\"webhook sent\")\n   100→\t\t\treturn nil\n   101→\t\t}\n   102→\t\tlastErr = fmt.Errorf(\"webhook returned status %d\", resp.StatusCode)\n   103→\t\tlog.Warn().Int(\"status\", resp.StatusCode).Int(\"attempt\", attempt+1).Msg(\"webhook non-2xx response\")\n   104→\t}\n   105→\n   106→\treturn fmt.Errorf(\"webhook failed after 3 attempts: %w\", lastErr)\n   107→}\n   108→"}]},"parent_tool_use_id":"toolu_01WjBDJU9gqMDSiqbdYofAYA","session_id":"2af19d51-84dc-4ce3-80b2-7d4b83aa4cbe","uuid":"6c2fa525-2e70-42c3-8eaf-42321cb015e4"}
