er(t)\n    63→\n    64→\tbody := `{\"repo_url\":\"https://github.com/test/repo\",\"prompt\":\"Fix the bug\",\"create_pr\":true}`\n    65→\treq := httptest.NewRequest(http.MethodPost, \"/api/v1/tasks\", bytes.NewBufferString(body))\n    66→\treq.Header.Set(\"Content-Type\", \"application/json\")\n    67→\tw := httptest.NewRecorder()\n    68→\n    69→\tsrv.ServeHTTP(w, req)\n    70→\n    71→\tif w.Code != http.StatusCreated {\n    72→\t\tt.Fatalf(\"create status = %d, want %d, body: %s\", w.Code, http.StatusCreated, w.Body.String())\n    73→\t}\n    74→\n    75→\tvar resp struct {\n    76→\t\tData struct {\n    77→\t\t\tID     string `json:\"id\"`\n    78→\t\t\tStatus string `json:\"status\"`\n    79→\t\t} `json:\"data\"`\n    80→\t}\n    81→\tjson.NewDecoder(w.Body).Decode(&resp)\n    82→\n    83→\tif resp.Data.ID == \"\" {\n    84→\t\tt.Fatal(\"expected non-empty task ID\")\n    85→\t}\n    86→\tif resp.Data.Status != \"pending\" {\n    87→\t\tt.Errorf(\"status = %q, want pending\", resp.Data.Status)\n    88→\t}\n    89→\n    90→\t// Get the task\n    91→\treq2 := httptest.NewRequest(http.MethodGet, \"/api/v1/tasks/\"+resp.Data.ID, nil)\n    92→\tw2 := httptest.NewRecorder()\n    93→\tsrv.ServeHTTP(w2, req2)\n    94→\n    95→\tif w2.Code != http.StatusOK {\n    96→\t\tt.Errorf(\"get status = %d, want %d\", w2.Code, http.StatusOK)\n    97→\t}\n    98→}\n    99→\n   100→func TestListTasks(t *testing.T) {\n   101→\tsrv := testServer(t)\n   102→\n   103→\treq := httptest.NewRequest(http.MethodGet, \"/api/v1/tasks\", nil)\n   104→\tw := httptest.NewRecorder()\n   105→\tsrv.ServeHTTP(w, req)\n   106→\n   107→\tif w.Code != http.StatusOK {\n   108→\t\tt.Errorf(\"status = %d, want %d\", w.Code, http.StatusOK)\n   109→\t}\n   110→\n   111→\tvar resp struct {\n   112→\t\tData []any `json:\"data\"`\n   113→\t}\n   114→\tjson.NewDecoder(w.Body).Decode(&resp)\n   115→\n   116→\tif resp.Data == nil {\n   117→\t\tt.Error(\"expected non-nil data array\")\n   118→\t}\n   119→}\n   1