{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012PNbHbjxNgXwcRtXH3Db4i","type":"tool_result","content":"     1→package models\n     2→\n     3→import \"testing\"\n     4→\n     5→func TestCreateTaskRequestValidation(t *testing.T) {\n     6→\ttests := []struct {\n     7→\t\tname    string\n     8→\t\treq     CreateTaskRequest\n     9→\t\twantErr bool\n    10→\t}{\n    11→\t\t{\n    12→\t\t\tname:    \"valid\",\n    13→\t\t\treq:     CreateTaskRequest{RepoURL: \"https://github.com/test/repo\", Prompt: \"Fix bug\"},\n    14→\t\t\twantErr: false,\n    15→\t\t},\n    16→\t\t{\n    17→\t\t\tname:    \"missing repo_url\",\n    18→\t\t\treq:     CreateTaskRequest{Prompt: \"Fix bug\"},\n    19→\t\t\twantErr: true,\n    20→\t\t},\n    21→\t\t{\n    22→\t\t\tname:    \"missing prompt\",\n    23→\t\t\treq:     CreateTaskRequest{RepoURL: \"https://github.com/test/repo\"},\n    24→\t\t\twantErr: true,\n    25→\t\t},\n    26→\t\t{\n    27→\t\t\tname:    \"negative budget\",\n    28→\t\t\treq:     CreateTaskRequest{RepoURL: \"https://github.com/test/repo\", Prompt: \"Fix\", MaxBudgetUSD: -1},\n    29→\t\t\twantErr: true,\n    30→\t\t},\n    31→\t}\n    32→\n    33→\tfor _, tt := range tests {\n    34→\t\tt.Run(tt.name, func(t *testing.T) {\n    35→\t\t\terr := tt.req.Validate()\n    36→\t\t\tif (err != nil) != tt.wantErr {\n    37→\t\t\t\tt.Errorf(\"Validate() error = %v, wantErr %v\", err, tt.wantErr)\n    38→\t\t\t}\n    39→\t\t})\n    40→\t}\n    41→}\n    42→\n    43→func TestTaskStatusIsTerminal(t *testing.T) {\n    44→\tterminal := []TaskStatus{TaskStatusCompleted, TaskStatusFailed, TaskStatusCancelled}\n    45→\tfor _, s := range terminal {\n    46→\t\tif !s.IsTerminal() {\n    47→\t\t\tt.Errorf(\"%q should be terminal\", s)\n    48→\t\t}\n    49→\t}\n    50→\n    51→\tnonTerminal := []TaskStatus{TaskStatusPending, TaskStatusProvisioning, TaskStatusRunning, TaskStatusInterrupted}\n    52→\tfor _, s := range nonTerminal {\n    53→\t\tif s.IsTerminal() {\n    54→\t\t\tt.Errorf(\"%q should not be terminal\", s)\n    55→\t\t}\n    56→\t}\n    57→}\n    58→"}]},"parent_tool_use_id":"toolu_01WjBDJU9gqMDSiqbdYofAYA","session_id":"2af19d51-84dc-4ce3-80b2-7d4b83aa4cbe","uuid":"21338d94-c613-42a7-8cd9-dbfc645bc176"}
