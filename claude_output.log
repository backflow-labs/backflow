{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011spCY62F3qxLtpZK5kU1aY","type":"tool_result","content":"     1→package config\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"os\"\n     6→\t\"strconv\"\n     7→\t\"strings\"\n     8→\t\"time\"\n     9→)\n    10→\n    11→type AuthMode string\n    12→\n    13→const (\n    14→\tAuthModeAPIKey          AuthMode = \"api_key\"\n    15→\tAuthModeMaxSubscription AuthMode = \"max_subscription\"\n    16→)\n    17→\n    18→type Config struct {\n    19→\t// Server\n    20→\tListenAddr string\n    21→\n    22→\t// Auth\n    23→\tAuthMode             AuthMode\n    24→\tAnthropicAPIKey      string\n    25→\tClaudeCredentialsPath string\n    26→\n    27→\t// AWS\n    28→\tAWSRegion        string\n    29→\tInstanceType     string\n    30→\tAMI              string\n    31→\tMaxInstances     int\n    32→\tContainersPerInst int\n    33→\tLaunchTemplateID string\n    34→\n    35→\t// Agent defaults\n    36→\tDefaultModel      string\n    37→\tDefaultEffort     string\n    38→\tDefaultMaxBudget  float64\n    39→\tDefaultMaxRuntime time.Duration\n    40→\tDefaultMaxTurns   int\n    41→\n    42→\t// GitHub\n    43→\tGitHubToken string\n    44→\n    45→\t// Webhooks\n    46→\tWebhookURL    string\n    47→\tWebhookEvents []string\n    48→\n    49→\t// Database\n    50→\tDBPath string\n    51→\n    52→\t// Orchestrator\n    53→\tPollInterval time.Duration\n    54→}\n    55→\n    56→func (c *Config) MaxConcurrent() int {\n    57→\tif c.AuthMode == AuthModeMaxSubscription {\n    58→\t\treturn 1\n    59→\t}\n    60→\treturn c.MaxInstances * c.ContainersPerInst\n    61→}\n    62→\n    63→func Load() (*Config, error) {\n    64→\tc := &Config{\n    65→\t\tListenAddr:        envOr(\"BACKFLOW_LISTEN_ADDR\", \":8080\"),\n    66→\t\tAuthMode:          AuthMode(envOr(\"BACKFLOW_AUTH_MODE\", string(AuthModeAPIKey))),\n    67→\t\tAnthropicAPIKey:   os.Getenv(\"ANTHROPIC_API_KEY\"),\n    68→\t\tClaudeCredentialsPath: envOr(\"CLAUDE_CREDENTIALS_PATH\", \"\"),\n    69→\t\tAWSRegion:         envOr(\"AWS_REGION\", \"us-east-1\"),\n    70→\t\tInstanceType:      envOr(\"BACKFLOW_INSTANCE_TYPE\", \"t4g.medium\"),\n    71→\t\tAMI:               os.Getenv(\"BACKFLOW_AMI\"),\n    72→\t\tMaxInstances:      envInt(\"BACKFLOW_MAX_INSTANCES\", 5),\n    73→\t\tContainersPerInst: envInt(\"BACKFLOW_CONTAINERS_PER_INSTANCE\", 4),\n    74→\t\tLaunchTemplateID:  os.Getenv(\"BACKFLOW_LAUNCH_TEMPLATE_ID\"),\n    75→\t\tDefaultModel:      envOr(\"BACKFLOW_DEFAULT_MODEL\", \"claude-sonnet-4-6\"),\n    76→\t\tDefaultEffort:     envOr(\"BACKFLOW_DEFAULT_EFFORT\", \"high\"),\n    77→\t\tDefaultMaxBudget:  envFloat(\"BACKFLOW_DEFAULT_MAX_BUDGET\", 10.0),\n    78→\t\tDefaultMaxRuntime: time.Duration(envInt(\"BACKFLOW_DEFAULT_MAX_RUNTIME_MIN\", 30)) * time.Minute,\n    79→\t\tDefaultMaxTurns:   envInt(\"BACKFLOW_DEFAULT_MAX_TURNS\", 200),\n    80→\t\tGitHubToken:       os.Getenv(\"GITHUB_TOKEN\"),\n    81→\t\tWebhookURL:        os.Getenv(\"BACKFLOW_WEBHOOK_URL\"),\n    82→\t\tDBPath:            envOr(\"BACKFLOW_DB_PATH\", \"backflow.db\"),\n    83→\t\tPollInterval:      time.Duration(envInt(\"BACKFLOW_POLL_INTERVAL_SEC\", 5)) * time.Second,\n    84→\t}\n    85→\n    86→\tif events := os.Getenv(\"BACKFLOW_WEBHOOK_EVENTS\"); events != \"\" {\n    87→\t\tc.WebhookEvents = strings.Split(events, \",\")\n    88→\t\tfor i := range c.WebhookEvents {\n    89→\t\t\tc.WebhookEvents[i] = strings.TrimSpace(c.WebhookEvents[i])\n    90→\t\t}\n    91→\t}\n    92→\n    93→\tif c.AuthMode != AuthModeAPIKey && c.AuthMode != AuthModeMaxSubscription {\n    94→\t\treturn nil, fmt.Errorf(\"invalid BACKFLOW_AUTH_MODE: %q (must be %q or %q)\", c.AuthMode, AuthModeAPIKey, AuthModeMaxSubscription)\n    95→\t}\n    96→\n    97→\tif c.AuthMode == AuthModeAPIKey && c.AnthropicAPIKey == \"\" {\n    98→\t\treturn nil, fmt.Errorf(\"ANTHROPIC_API_KEY is required when BACKFLOW_AUTH_MODE=api_key\")\n    99→\t}\n   100→\n   101→\treturn c, nil\n   102→}\n   103→\n   104→func envOr(key, fallback string) string {\n   105→\tif v := os.Getenv(key); v != \"\" {\n   106→\t\treturn v\n   107→\t}\n   108→\treturn fallback\n   109→}\n   110→\n   111→func envInt(key string, fallback int) int {\n   112→\tif v := os.Getenv(key); v != \"\" {\n   113→\t\tif n, err := strconv.Atoi(v); err == nil {\n   114→\t\t\treturn n\n   115→\t\t}\n   116→\t}\n   117→\treturn fallback\n   118→}\n   119→\n   120→func envFloat(key string, fallback float64) float64 {\n   121→\tif v := os.Getenv(key); v != \"\" {\n   122→\t\tif f, err := strconv.ParseFloat(v, 64); err == nil {\n   123→\t\t\treturn f\n   124→\t\t}\n   125→\t}\n   126→\treturn fallback\n   127→}\n   128→"}]},"parent_tool_use_id":null,"session_id":"2af19d51-84dc-4ce3-80b2-7d4b83aa4cbe","uuid":"21a19797-c4e2-41bc-8806-809714814f1c","tool_use_result":{"type":"text","file":{"filePath":"/home/agent/workspace/internal/config/config.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n)\n\ntype AuthMode string\n\nconst (\n\tAuthModeAPIKey          AuthMode = \"api_key\"\n\tAuthModeMaxSubscription AuthMode = \"max_subscription\"\n)\n\ntype Config struct {\n\t// Server\n\tListenAddr string\n\n\t// Auth\n\tAuthMode             AuthMode\n\tAnthropicAPIKey      string\n\tClaudeCredentialsPath string\n\n\t// AWS\n\tAWSRegion        string\n\tInstanceType     string\n\tAMI              string\n\tMaxInstances     int\n\tContainersPerInst int\n\tLaunchTemplateID string\n\n\t// Agent defaults\n\tDefaultModel      string\n\tDefaultEffort     string\n\tDefaultMaxBudget  float64\n\tDefaultMaxRuntime time.Duration\n\tDefaultMaxTurns   int\n\n\t// GitHub\n\tGitHubToken string\n\n\t// Webhooks\n\tWebhookURL    string\n\tWebhookEvents []string\n\n\t// Database\n\tDBPath string\n\n\t// Orchestrator\n\tPollInterval time.Duration\n}\n\nfunc (c *Config) MaxConcurrent() int {\n\tif c.AuthMode == AuthModeMaxSubscription {\n\t\treturn 1\n\t}\n\treturn c.MaxInstances * c.ContainersPerInst\n}\n\nfunc Load() (*Config, error) {\n\tc := &Config{\n\t\tListenAddr:        envOr(\"BACKFLOW_LISTEN_ADDR\", \":8080\"),\n\t\tAuthMode:          AuthMode(envOr(\"BACKFLOW_AUTH_MODE\", string(AuthModeAPIKey))),\n\t\tAnthropicAPIKey:   os.Getenv(\"ANTHROPIC_API_KEY\"),\n\t\tClaudeCredentialsPath: envOr(\"CLAUDE_CREDENTIALS_PATH\", \"\"),\n\t\tAWSRegion:         envOr(\"AWS_REGION\", \"us-east-1\"),\n\t\tInstanceType:      envOr(\"BACKFLOW_INSTANCE_TYPE\", \"t4g.medium\"),\n\t\tAMI:               os.Getenv(\"BACKFLOW_AMI\"),\n\t\tMaxInstances:      envInt(\"BACKFLOW_MAX_INSTANCES\", 5),\n\t\tContainersPerInst: envInt(\"BACKFLOW_CONTAINERS_PER_INSTANCE\", 4),\n\t\tLaunchTemplateID:  os.Getenv(\"BACKFLOW_LAUNCH_TEMPLATE_ID\"),\n\t\tDefaultModel:      envOr(\"BACKFLOW_DEFAULT_MODEL\", \"claude-sonnet-4-6\"),\n\t\tDefaultEffort:     envOr(\"BACKFLOW_DEFAULT_EFFORT\", \"high\"),\n\t\tDefaultMaxBudget:  envFloat(\"BACKFLOW_DEFAULT_MAX_BUDGET\", 10.0),\n\t\tDefaultMaxRuntime: time.Duration(envInt(\"BACKFLOW_DEFAULT_MAX_RUNTIME_MIN\", 30)) * time.Minute,\n\t\tDefaultMaxTurns:   envInt(\"BACKFLOW_DEFAULT_MAX_TURNS\", 200),\n\t\tGitHubToken:       os.Getenv(\"GITHUB_TOKEN\"),\n\t\tWebhookURL:        os.Getenv(\"BACKFLOW_WEBHOOK_URL\"),\n\t\tDBPath:            envOr(\"BACKFLOW_DB_PATH\", \"backflow.db\"),\n\t\tPollInterval:      time.Duration(envInt(\"BACKFLOW_POLL_INTERVAL_SEC\", 5)) * time.Second,\n\t}\n\n\tif events := os.Getenv(\"BACKFLOW_WEBHOOK_EVENTS\"); events != \"\" {\n\t\tc.WebhookEvents = strings.Split(events, \",\")\n\t\tfor i := range c.WebhookEvents {\n\t\t\tc.WebhookEvents[i] = strings.TrimSpace(c.WebhookEvents[i])\n\t\t}\n\t}\n\n\tif c.AuthMode != AuthModeAPIKey && c.AuthMode != AuthModeMaxSubscription {\n\t\treturn nil, fmt.Errorf(\"invalid BACKFLOW_AUTH_MODE: %q (must be %q or %q)\", c.AuthMode, AuthModeAPIKey, AuthModeMaxSubscription)\n\t}\n\n\tif c.AuthMode == AuthModeAPIKey && c.AnthropicAPIKey == \"\" {\n\t\treturn nil, fmt.Errorf(\"ANTHROPIC_API_KEY is required when BACKFLOW_AUTH_MODE=api_key\")\n\t}\n\n\treturn c, nil\n}\n\nfunc envOr(key, fallback string) string {\n\tif v := os.Getenv(key); v != \"\" {\n\t\treturn v\n\t}\n\treturn fallback\n}\n\nfunc envInt(key string, fallback int) int {\n\tif v := os.Getenv(key); v != \"\" {\n\t\tif n, err := strconv.Atoi(v); err == nil {\n\t\t\treturn n\n\t\t}\n\t}\n\treturn fallback\n}\n\nfunc envFloat(key string, fallback float64) float64 {\n\tif v := os.Getenv(key); v != \"\" {\n\t\tif f, err := strconv.ParseFloat(v, 64); err == nil {\n\t\t\treturn f\n\t\t}\n\t}\n\treturn fallback\n}\n","numLines":128,"startLine":1,"totalLines":128}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013L8SCJsxfWr8kLMCqYwcgJ","type":"tool_result","content":"     1→package store\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"database/sql\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"strings\"\n     9→\t\"time\"\n    10→\n    11→\t_ \"github.com/mattn/go-sqlite3\"\n    12→\n    13→\t\"github.com/backflow-labs/backflow/internal/models\"\n    14→)\n    15→\n    16→type SQLiteStore struct {\n    17→\tdb *sql.DB\n    18→}\n    19→\n    20→func NewSQLite(dbPath string) (*SQLiteStore, error) {\n    21→\tdb, err := sql.Open(\"sqlite3\", dbPath+\"?_journal_mode=WAL&_busy_timeout=5000&_foreign_keys=on\")\n    22→\tif err != nil {\n    23→\t\treturn nil, fmt.Errorf(\"open sqlite: %w\", err)\n    24→\t}\n    25→\ts := &SQLiteStore{db: db}\n    26→\tif err := s.migrate(); err != nil {\n    27→\t\tdb.Close()\n    28→\t\treturn nil, fmt.Errorf(\"migrate: %w\", err)\n    29→\t}\n    30→\treturn s, nil\n    31→}\n    32→\n    33→func (s *SQLiteStore) Close() error {\n    34→\treturn s.db.Close()\n    35→}\n    36→\n    37→func (s *SQLiteStore) migrate() error {\n    38→\tschema := `\n    39→\tCREATE TABLE IF NOT EXISTS tasks (\n    40→\t\tid              TEXT PRIMARY KEY,\n    41→\t\tstatus          TEXT NOT NULL DEFAULT 'pending',\n    42→\t\trepo_url        TEXT NOT NULL,\n    43→\t\tbranch          TEXT NOT NULL DEFAULT '',\n    44→\t\ttarget_branch   TEXT NOT NULL DEFAULT '',\n    45→\t\tprompt          TEXT NOT NULL,\n    46→\t\tcontext         TEXT NOT NULL DEFAULT '',\n    47→\t\tmodel           TEXT NOT NULL DEFAULT '',\n    48→\t\teffort          TEXT NOT NULL DEFAULT '',\n    49→\t\tmax_budget_usd  REAL NOT NULL DEFAULT 0,\n    50→\t\tmax_runtime_min INTEGER NOT NULL DEFAULT 0,\n    51→\t\tmax_turns       INTEGER NOT NULL DEFAULT 0,\n    52→\t\tcreate_pr       INTEGER NOT NULL DEFAULT 0,\n    53→\t\tpr_title        TEXT NOT NULL DEFAULT '',\n    54→\t\tpr_body         TEXT NOT NULL DEFAULT '',\n    55→\t\tpr_url          TEXT NOT NULL DEFAULT '',\n    56→\t\tallowed_tools   TEXT NOT NULL DEFAULT '[]',\n    57→\t\tclaude_md       TEXT NOT NULL DEFAULT '',\n    58→\t\tenv_vars        TEXT NOT NULL DEFAULT '{}',\n    59→\t\tinstance_id     TEXT NOT NULL DEFAULT '',\n    60→\t\tcontainer_id    TEXT NOT NULL DEFAULT '',\n    61→\t\tretry_count     INTEGER NOT NULL DEFAULT 0,\n    62→\t\tcost_usd        REAL NOT NULL DEFAULT 0,\n    63→\t\terror           TEXT NOT NULL DEFAULT '',\n    64→\t\tcreated_at      TEXT NOT NULL,\n    65→\t\tupdated_at      TEXT NOT NULL,\n    66→\t\tstarted_at      TEXT,\n    67→\t\tcompleted_at    TEXT\n    68→\t);\n    69→\n    70→\tCREATE INDEX IF NOT EXISTS idx_tasks_status ON tasks(status);\n    71→\tCREATE INDEX IF NOT EXISTS idx_tasks_created ON tasks(created_at);\n    72→\n    73→\tCREATE TABLE IF NOT EXISTS instances (\n    74→\t\tinstance_id        TEXT PRIMARY KEY,\n    75→\t\tinstance_type      TEXT NOT NULL,\n    76→\t\tavailability_zone  TEXT NOT NULL DEFAULT '',\n    77→\t\tprivate_ip         TEXT NOT NULL DEFAULT '',\n    78→\t\tstatus             TEXT NOT NULL DEFAULT 'pending',\n    79→\t\tmax_containers     INTEGER NOT NULL DEFAULT 4,\n    80→\t\trunning_containers INTEGER NOT NULL DEFAULT 0,\n    81→\t\tcreated_at         TEXT NOT NULL,\n    82→\t\tupdated_at         TEXT NOT NULL\n    83→\t);\n    84→\n    85→\tCREATE INDEX IF NOT EXISTS idx_instances_status ON instances(status);\n    86→\t`\n    87→\t_, err := s.db.Exec(schema)\n    88→\treturn err\n    89→}\n    90→\n    91→// --- Tasks ---\n    92→\n    93→func (s *SQLiteStore) CreateTask(ctx context.Context, task *models.Task) error {\n    94→\t_, err := s.db.ExecContext(ctx, `\n    95→\t\tINSERT INTO tasks (\n    96→\t\t\tid, status, repo_url, branch, target_branch, prompt, context,\n    97→\t\t\tmodel, effort, max_budget_usd, max_runtime_min, max_turns,\n    98→\t\t\tcreate_pr, pr_title, pr_body, pr_url,\n    99→\t\t\tallowed_tools, claude_md, env_vars,\n   100→\t\t\tinstance_id, container_id, retry_count, cost_usd, error,\n   101→\t\t\tcreated_at, updated_at, started_at, completed_at\n   102→\t\t) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n   103→\t\ttask.ID, task.Status, task.RepoURL, task.Branch, task.TargetBranch,\n   104→\t\ttask.Prompt, task.Context, task.Model, task.Effort,\n   105→\t\ttask.MaxBudgetUSD, task.MaxRuntimeMin, task.MaxTurns,\n   106→\t\tboolToInt(task.CreatePR), task.PRTitle, task.PRBody, task.PRURL,\n   107→\t\ttask.AllowedToolsJSON(), task.ClaudeMD, task.EnvVarsJSON(),\n   108→\t\ttask.InstanceID, task.ContainerID, task.RetryCount, task.CostUSD, task.Error,\n   109→\t\ttask.CreatedAt.Format(time.RFC3339), task.UpdatedAt.Format(time.RFC3339),\n   110→\t\ttimePtr(task.StartedAt), timePtr(task.CompletedAt),\n   111→\t)\n   112→\treturn err\n   113→}\n   114→\n   115→func (s *SQLiteStore) GetTask(ctx context.Context, id string) (*models.Task, error) {\n   116→\trow := s.db.QueryRowContext(ctx, `SELECT\n   117→\t\tid, status, repo_url, branch, target_branch, prompt, context,\n   118→\t\tmodel, effort, max_budget_usd, max_runtime_min, max_turns,\n   119→\t\tcreate_pr, pr_title, pr_body, pr_url,\n   120→\t\tallowed_tools, claude_md, env_vars,\n   121→\t\tinstance_id, container_id, retry_count, cost_usd, error,\n   122→\t\tcreated_at, updated_at, started_at, completed_at\n   123→\t\tFROM tasks WHERE id = ?`, id)\n   124→\treturn scanTask(row)\n   125→}\n   126→\n   127→func (s *SQLiteStore) ListTasks(ctx context.Context, filter TaskFilter) ([]*models.Task, error) {\n   128→\tquery := \"SELECT id, status, repo_url, branch, target_branch, prompt, context, model, effort, max_budget_usd, max_runtime_min, max_turns, create_pr, pr_title, pr_body, pr_url, allowed_tools, claude_md, env_vars, instance_id, container_id, retry_count, cost_usd, error, created_at, updated_at, started_at, completed_at FROM tasks\"\n   129→\tvar args []any\n   130→\tvar where []string\n   131→\n   132→\tif filter.Status != nil {\n   133→\t\twhere = append(where, \"status = ?\")\n   134→\t\targs = append(args, string(*filter.Status))\n   135→\t}\n   136→\tif len(where) > 0 {\n   137→\t\tquery += \" WHERE \" + strings.Join(where, \" AND \")\n   138→\t}\n   139→\tquery += \" ORDER BY created_at ASC\"\n   140→\tif filter.Limit > 0 {\n   141→\t\tquery += fmt.Sprintf(\" LIMIT %d\", filter.Limit)\n   142→\t}\n   143→\tif filter.Offset > 0 {\n   144→\t\tquery += fmt.Sprintf(\" OFFSET %d\", filter.Offset)\n   145→\t}\n   146→\n   147→\trows, err := s.db.QueryContext(ctx, query, args...)\n   148→\tif err != nil {\n   149→\t\treturn nil, err\n   150→\t}\n   151→\tdefer rows.Close()\n   152→\n   153→\tvar tasks []*models.Task\n   154→\tfor rows.Next() {\n   155→\t\tt, err := scanTaskRows(rows)\n   156→\t\tif err != nil {\n   157→\t\t\treturn nil, err\n   158→\t\t}\n   159→\t\ttasks = append(tasks, t)\n   160→\t}\n   161→\treturn tasks, rows.Err()\n   162→}\n   163→\n   164→func (s *SQLiteStore) UpdateTask(ctx context.Context, task *models.Task) error {\n   165→\ttask.UpdatedAt = time.Now().UTC()\n   166→\t_, err := s.db.ExecContext(ctx, `\n   167→\t\tUPDATE tasks SET\n   168→\t\t\tstatus=?, repo_url=?, branch=?, target_branch=?, prompt=?, context=?,\n   169→\t\t\tmodel=?, effort=?, max_budget_usd=?, max_runtime_min=?, max_turns=?,\n   170→\t\t\tcreate_pr=?, pr_title=?, pr_body=?, pr_url=?,\n   171→\t\t\tallowed_tools=?, claude_md=?, env_vars=?,\n   172→\t\t\tinstance_id=?, container_id=?, retry_count=?, cost_usd=?, error=?,\n   173→\t\t\tupdated_at=?, started_at=?, completed_at=?\n   174→\t\tWHERE id = ?`,\n   175→\t\ttask.Status, task.RepoURL, task.Branch, task.TargetBranch,\n   176→\t\ttask.Prompt, task.Context, task.Model, task.Effort,\n   177→\t\ttask.MaxBudgetUSD, task.MaxRuntimeMin, task.MaxTurns,\n   178→\t\tboolToInt(task.CreatePR), task.PRTitle, task.PRBody, task.PRURL,\n   179→\t\ttask.AllowedToolsJSON(), task.ClaudeMD, task.EnvVarsJSON(),\n   180→\t\ttask.InstanceID, task.ContainerID, task.RetryCount, task.CostUSD, task.Error,\n   181→\t\ttask.UpdatedAt.Format(time.RFC3339), timePtr(task.StartedAt), timePtr(task.CompletedAt),\n   182→\t\ttask.ID,\n   183→\t)\n   184→\treturn err\n   185→}\n   186→\n   187→func (s *SQLiteStore) DeleteTask(ctx context.Context, id string) error {\n   188→\t_, err := s.db.ExecContext(ctx, \"DELETE FROM tasks WHERE id = ?\", id)\n   189→\treturn err\n   190→}\n   191→\n   192→// --- Instances ---\n   193→\n   194→func (s *SQLiteStore) CreateInstance(ctx context.Context, inst *models.Instance) error {\n   195→\t_, err := s.db.ExecContext(ctx, `\n   196→\t\tINSERT INTO instances (instance_id, instance_type, availability_zone, private_ip, status, max_containers, running_containers, created_at, updated_at)\n   197→\t\tVALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n   198→\t\tinst.InstanceID, inst.InstanceType, inst.AvailabilityZone, inst.PrivateIP,\n   199→\t\tinst.Status, inst.MaxContainers, inst.RunningContainers,\n   200→\t\tinst.CreatedAt.Format(time.RFC3339), inst.UpdatedAt.Format(time.RFC3339),\n   201→\t)\n   202→\treturn err\n   203→}\n   204→\n   205→func (s *SQLiteStore) GetInstance(ctx context.Context, id string) (*models.Instance, error) {\n   206→\trow := s.db.QueryRowContext(ctx, `SELECT instance_id, instance_type, availability_zone, private_ip, status, max_containers, running_containers, created_at, updated_at FROM instances WHERE instance_id = ?`, id)\n   207→\treturn scanInstance(row)\n   208→}\n   209→\n   210→func (s *SQLiteStore) ListInstances(ctx context.Context, status *models.InstanceStatus) ([]*models.Instance, error) {\n   211→\tquery := \"SELECT instance_id, instance_type, availability_zone, private_ip, status, max_containers, running_containers, created_at, updated_at FROM instances\"\n   212→\tvar args []any\n   213→\tif status != nil {\n   214→\t\tquery += \" WHERE status = ?\"\n   215→\t\targs = append(args, string(*status))\n   216→\t}\n   217→\tquery += \" ORDER BY created_at ASC\"\n   218→\n   219→\trows, err := s.db.QueryContext(ctx, query, args...)\n   220→\tif err != nil {\n   221→\t\treturn nil, err\n   222→\t}\n   223→\tdefer rows.Close()\n   224→\n   225→\tvar instances []*models.Instance\n   226→\tfor rows.Next() {\n   227→\t\tinst, err := scanInstanceRows(rows)\n   228→\t\tif err != nil {\n   229→\t\t\treturn nil, err\n   230→\t\t}\n   231→\t\tinstances = append(instances, inst)\n   232→\t}\n   233→\treturn instances, rows.Err()\n   234→}\n   235→\n   236→func (s *SQLiteStore) UpdateInstance(ctx context.Context, inst *models.Instance) error {\n   237→\tinst.UpdatedAt = time.Now().UTC()\n   238→\t_, err := s.db.ExecContext(ctx, `\n   239→\t\tUPDATE instances SET\n   240→\t\t\tinstance_type=?, availability_zone=?, private_ip=?, status=?,\n   241→\t\t\tmax_containers=?, running_containers=?, updated_at=?\n   242→\t\tWHERE instance_id = ?`,\n   243→\t\tinst.InstanceType, inst.AvailabilityZone, inst.PrivateIP, inst.Status,\n   244→\t\tinst.MaxContainers, inst.RunningContainers, inst.UpdatedAt.Format(time.RFC3339),\n   245→\t\tinst.InstanceID,\n   246→\t)\n   247→\treturn err\n   248→}\n   249→\n   250→// --- helpers ---\n   251→\n   252→type scanner interface {\n   253→\tScan(dest ...any) error\n   254→}\n   255→\n   256→func scanTask(row scanner) (*models.Task, error) {\n   257→\tvar t models.Task\n   258→\tvar createPR int\n   259→\tvar allowedToolsJSON, envVarsJSON string\n   260→\tvar createdAt, updatedAt string\n   261→\tvar startedAt, completedAt sql.NullString\n   262→\n   263→\terr := row.Scan(\n   264→\t\t&t.ID, &t.Status, &t.RepoURL, &t.Branch, &t.TargetBranch,\n   265→\t\t&t.Prompt, &t.Context, &t.Model, &t.Effort,\n   266→\t\t&t.MaxBudgetUSD, &t.MaxRuntimeMin, &t.MaxTurns,\n   267→\t\t&createPR, &t.PRTitle, &t.PRBody, &t.PRURL,\n   268→\t\t&allowedToolsJSON, &t.ClaudeMD, &envVarsJSON,\n   269→\t\t&t.InstanceID, &t.ContainerID, &t.RetryCount, &t.CostUSD, &t.Error,\n   270→\t\t&createdAt, &updatedAt, &startedAt, &completedAt,\n   271→\t)\n   272→\tif err != nil {\n   273→\t\tif err == sql.ErrNoRows {\n   274→\t\t\treturn nil, nil\n   275→\t\t}\n   276→\t\treturn nil, err\n   277→\t}\n   278→\n   279→\tt.CreatePR = createPR != 0\n   280→\tjson.Unmarshal([]byte(allowedToolsJSON), &t.AllowedTools)\n   281→\tjson.Unmarshal([]byte(envVarsJSON), &t.EnvVars)\n   282→\tt.CreatedAt, _ = time.Parse(time.RFC3339, createdAt)\n   283→\tt.UpdatedAt, _ = time.Parse(time.RFC3339, updatedAt)\n   284→\tif startedAt.Valid {\n   285→\t\tts, _ := time.Parse(time.RFC3339, startedAt.String)\n   286→\t\tt.StartedAt = &ts\n   287→\t}\n   288→\tif completedAt.Valid {\n   289→\t\tts, _ := time.Parse(time.RFC3339, completedAt.String)\n   290→\t\tt.CompletedAt = &ts\n   291→\t}\n   292→\n   293→\treturn &t, nil\n   294→}\n   295→\n   296→func scanTaskRows(rows *sql.Rows) (*models.Task, error) {\n   297→\treturn scanTask(rows)\n   298→}\n   299→\n   300→func scanInstance(row scanner) (*models.Instance, error) {\n   301→\tvar inst models.Instance\n   302→\tvar createdAt, updatedAt string\n   303→\n   304→\terr := row.Scan(\n   305→\t\t&inst.InstanceID, &inst.InstanceType, &inst.AvailabilityZone,\n   306→\t\t&inst.PrivateIP, &inst.Status, &inst.MaxContainers,\n   307→\t\t&inst.RunningContainers, &createdAt, &updatedAt,\n   308→\t)\n   309→\tif err != nil {\n   310→\t\tif err == sql.ErrNoRows {\n   311→\t\t\treturn nil, nil\n   312→\t\t}\n   313→\t\treturn nil, err\n   314→\t}\n   315→\n   316→\tinst.CreatedAt, _ = time.Parse(time.RFC3339, createdAt)\n   317→\tinst.UpdatedAt, _ = time.Parse(time.RFC3339, updatedAt)\n   318→\treturn &inst, nil\n   319→}\n   320→\n   321→func scanInstanceRows(rows *sql.Rows) (*models.Instance, error) {\n   322→\treturn scanInstance(rows)\n   323→}\n   324→\n   325→func boolToInt(b bool) int {\n   326→\tif b {\n   327→\t\treturn 1\n   328→\t}\n   329→\treturn 0\n   330→}\n   331→\n   332→func timePtr(t *time.Time) any {\n   333→\tif t == nil {\n   334→\t\treturn nil\n   335→\t}\n   336→\treturn t.Format(time.RFC3339)\n   337→}\n   338→"}]},"parent_tool_use_id":null,"session_id":"2af19d51-84dc-4ce3-80b2-7d4b83aa4cbe","uuid":"85568331-1a32-480d-84f5-cf11599432a1","tool_use_result":{"type":"text","file":{"filePath":"/home/agent/workspace/internal/store/sqlite.go","content":"package store\n\nimport (\n\t\"context\"\n\t\"database/sql\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"strings\"\n\t\"time\"\n\n\t_ \"github.com/mattn/go-sqlite3\"\n\n\t\"github.com/backflow-labs/backflow/internal/models\"\n)\n\ntype SQLiteStore struct {\n\tdb *sql.DB\n}\n\nfunc NewSQLite(dbPath string) (*SQLiteStore, error) {\n\tdb, err := sql.Open(\"sqlite3\", dbPath+\"?_journal_mode=WAL&_busy_timeout=5000&_foreign_keys=on\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"open sqlite: %w\", err)\n\t}\n\ts := &SQLiteStore{db: db}\n\tif err := s.migrate(); err != nil {\n\t\tdb.Close()\n\t\treturn nil, fmt.Errorf(\"migrate: %w\", err)\n\t}\n\treturn s, nil\n}\n\nfunc (s *SQLiteStore) Close() error {\n\treturn s.db.Close()\n}\n\nfunc (s *SQLiteStore) migrate() error {\n\tschema := `\n\tCREATE TABLE IF NOT EXISTS tasks (\n\t\tid              TEXT PRIMARY KEY,\n\t\tstatus          TEXT NOT NULL DEFAULT 'pending',\n\t\trepo_url        TEXT NOT NULL,\n\t\tbranch          TEXT NOT NULL DEFAULT '',\n\t\ttarget_branch   TEXT NOT NULL DEFAULT '',\n\t\tprompt          TEXT NOT NULL,\n\t\tcontext         TEXT NOT NULL DEFAULT '',\n\t\tmodel           TEXT NOT NULL DEFAULT '',\n\t\teffort          TEXT NOT NULL DEFAULT '',\n\t\tmax_budget_usd  REAL NOT NULL DEFAULT 0,\n\t\tmax_runtime_min INTEGER NOT NULL DEFAULT 0,\n\t\tmax_turns       INTEGER NOT NULL DEFAULT 0,\n\t\tcreate_pr       INTEGER NOT NULL DEFAULT 0,\n\t\tpr_title        TEXT NOT NULL DEFAULT '',\n\t\tpr_body         TEXT NOT NULL DEFAULT '',\n\t\tpr_url          TEXT NOT NULL DEFAULT '',\n\t\tallowed_tools   TEXT NOT NULL DEFAULT '[]',\n\t\tclaude_md       TEXT NOT NULL DEFAULT '',\n\t\tenv_vars        TEXT NOT NULL DEFAULT '{}',\n\t\tinstance_id     TEXT NOT NULL DEFAULT '',\n\t\tcontainer_id    TEXT NOT NULL DEFAULT '',\n\t\tretry_count     INTEGER NOT NULL DEFAULT 0,\n\t\tcost_usd        REAL NOT NULL DEFAULT 0,\n\t\terror           TEXT NOT NULL DEFAULT '',\n\t\tcreated_at      TEXT NOT NULL,\n\t\tupdated_at      TEXT NOT NULL,\n\t\tstarted_at      TEXT,\n\t\tcompleted_at    TEXT\n\t);\n\n\tCREATE INDEX IF NOT EXISTS idx_tasks_status ON tasks(status);\n\tCREATE INDEX IF NOT EXISTS idx_tasks_created ON tasks(created_at);\n\n\tCREATE TABLE IF NOT EXISTS instances (\n\t\tinstance_id        TEXT PRIMARY KEY,\n\t\tinstance_type      TEXT NOT NULL,\n\t\tavailability_zone  TEXT NOT NULL DEFAULT '',\n\t\tprivate_ip         TEXT NOT NULL DEFAULT '',\n\t\tstatus             TEXT NOT NULL DEFAULT 'pending',\n\t\tmax_containers     INTEGER NOT NULL DEFAULT 4,\n\t\trunning_containers INTEGER NOT NULL DEFAULT 0,\n\t\tcreated_at         TEXT NOT NULL,\n\t\tupdated_at         TEXT NOT NULL\n\t);\n\n\tCREATE INDEX IF NOT EXISTS idx_instances_status ON instances(status);\n\t`\n\t_, err := s.db.Exec(schema)\n\treturn err\n}\n\n// --- Tasks ---\n\nfunc (s *SQLiteStore) CreateTask(ctx context.Context, task *models.Task) error {\n\t_, err := s.db.ExecContext(ctx, `\n\t\tINSERT INTO tasks (\n\t\t\tid, status, repo_url, branch, target_branch, prompt, context,\n\t\t\tmodel, effort, max_budget_usd, max_runtime_min, max_turns,\n\t\t\tcreate_pr, pr_title, pr_body, pr_url,\n\t\t\tallowed_tools, claude_md, env_vars,\n\t\t\tinstance_id, container_id, retry_count, cost_usd, error,\n\t\t\tcreated_at, updated_at, started_at, completed_at\n\t\t) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n\t\ttask.ID, task.Status, task.RepoURL, task.Branch, task.TargetBranch,\n\t\ttask.Prompt, task.Context, task.Model, task.Effort,\n\t\ttask.MaxBudgetUSD, task.MaxRuntimeMin, task.MaxTurns,\n\t\tboolToInt(task.CreatePR), task.PRTitle, task.PRBody, task.PRURL,\n\t\ttask.AllowedToolsJSON(), task.ClaudeMD, task.EnvVarsJSON(),\n\t\ttask.InstanceID, task.ContainerID, task.RetryCount, task.CostUSD, task.Error,\n\t\ttask.CreatedAt.Format(time.RFC3339), task.UpdatedAt.Format(time.RFC3339),\n\t\ttimePtr(task.StartedAt), timePtr(task.CompletedAt),\n\t)\n\treturn err\n}\n\nfunc (s *SQLiteStore) GetTask(ctx context.Context, id string) (*models.Task, error) {\n\trow := s.db.QueryRowContext(ctx, `SELECT\n\t\tid, status, repo_url, branch, target_branch, prompt, context,\n\t\tmodel, effort, max_budget_usd, max_runtime_min, max_turns,\n\t\tcreate_pr, pr_title, pr_body, pr_url,\n\t\tallowed_tools, claude_md, env_vars,\n\t\tinstance_id, container_id, retry_count, cost_usd, error,\n\t\tcreated_at, updated_at, started_at, completed_at\n\t\tFROM tasks WHERE id = ?`, id)\n\treturn scanTask(row)\n}\n\nfunc (s *SQLiteStore) ListTasks(ctx context.Context, filter TaskFilter) ([]*models.Task, error) {\n\tquery := \"SELECT id, status, repo_url, branch, target_branch, prompt, context, model, effort, max_budget_usd, max_runtime_min, max_turns, create_pr, pr_title, pr_body, pr_url, allowed_tools, claude_md, env_vars, instance_id, container_id, retry_count, cost_usd, error, created_at, updated_at, started_at, completed_at FROM tasks\"\n\tvar args []any\n\tvar where []string\n\n\tif filter.Status != nil {\n\t\twhere = append(where, \"status = ?\")\n\t\targs = append(args, string(*filter.Status))\n\t}\n\tif len(where) > 0 {\n\t\tquery += \" WHERE \" + strings.Join(where, \" AND \")\n\t}\n\tquery += \" ORDER BY created_at ASC\"\n\tif filter.Limit > 0 {\n\t\tquery += fmt.Sprintf(\" LIMIT %d\", filter.Limit)\n\t}\n\tif filter.Offset > 0 {\n\t\tquery += fmt.Sprintf(\" OFFSET %d\", filter.Offset)\n\t}\n\n\trows, err := s.db.QueryContext(ctx, query, args...)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\n\tvar tasks []*models.Task\n\tfor rows.Next() {\n\t\tt, err := scanTaskRows(rows)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\ttasks = append(tasks, t)\n\t}\n\treturn tasks, rows.Err()\n}\n\nfunc (s *SQLiteStore) UpdateTask(ctx context.Context, task *models.Task) error {\n\ttask.UpdatedAt = time.Now().UTC()\n\t_, err := s.db.ExecContext(ctx, `\n\t\tUPDATE tasks SET\n\t\t\tstatus=?, repo_url=?, branch=?, target_branch=?, prompt=?, context=?,\n\t\t\tmodel=?, effort=?, max_budget_usd=?, max_runtime_min=?, max_turns=?,\n\t\t\tcreate_pr=?, pr_title=?, pr_body=?, pr_url=?,\n\t\t\tallowed_tools=?, claude_md=?, env_vars=?,\n\t\t\tinstance_id=?, container_id=?, retry_count=?, cost_usd=?, error=?,\n\t\t\tupdated_at=?, started_at=?, completed_at=?\n\t\tWHERE id = ?`,\n\t\ttask.Status, task.RepoURL, task.Branch, task.TargetBranch,\n\t\ttask.Prompt, task.Context, task.Model, task.Effort,\n\t\ttask.MaxBudgetUSD, task.MaxRuntimeMin, task.MaxTurns,\n\t\tboolToInt(task.CreatePR), task.PRTitle, task.PRBody, task.PRURL,\n\t\ttask.AllowedToolsJSON(), task.ClaudeMD, task.EnvVarsJSON(),\n\t\ttask.InstanceID, task.ContainerID, task.RetryCount, task.CostUSD, task.Error,\n\t\ttask.UpdatedAt.Format(time.RFC3339), timePtr(task.StartedAt), timePtr(task.CompletedAt),\n\t\ttask.ID,\n\t)\n\treturn err\n}\n\nfunc (s *SQLiteStore) DeleteTask(ctx context.Context, id string) error {\n\t_, err := s.db.ExecContext(ctx, \"DELETE FROM tasks WHERE id = ?\", id)\n\treturn err\n}\n\n// --- Instances ---\n\nfunc (s *SQLiteStore) CreateInstance(ctx context.Context, inst *models.Instance) error {\n\t_, err := s.db.ExecContext(ctx, `\n\t\tINSERT INTO instances (instance_id, instance_type, availability_zone, private_ip, status, max_containers, running_containers, created_at, updated_at)\n\t\tVALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n\t\tinst.InstanceID, inst.InstanceType, inst.AvailabilityZone, inst.PrivateIP,\n\t\tinst.Status, inst.MaxContainers, inst.RunningContainers,\n\t\tinst.CreatedAt.Format(time.RFC3339), inst.UpdatedAt.Format(time.RFC3339),\n\t)\n\treturn err\n}\n\nfunc (s *SQLiteStore) GetInstance(ctx context.Context, id string) (*models.Instance, error) {\n\trow := s.db.QueryRowContext(ctx, `SELECT instance_id, instance_type, availability_zone, private_ip, status, max_containers, running_containers, created_at, updated_at FROM instances WHERE instance_id = ?`, id)\n\treturn scanInstance(row)\n}\n\nfunc (s *SQLiteStore) ListInstances(ctx context.Context, status *models.InstanceStatus) ([]*models.Instance, error) {\n\tquery := \"SELECT instance_id, instance_type, availability_zone, private_ip, status, max_containers, running_containers, created_at, updated_at FROM instances\"\n\tvar args []any\n\tif status != nil {\n\t\tquery += \" WHERE status = ?\"\n\t\targs = append(args, string(*status))\n\t}\n\tquery += \" ORDER BY created_at ASC\"\n\n\trows, err := s.db.QueryContext(ctx, query, args...)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tdefer rows.Close()\n\n\tvar instances []*models.Instance\n\tfor rows.Next() {\n\t\tinst, err := scanInstanceRows(rows)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tinstances = append(instances, inst)\n\t}\n\treturn instances, rows.Err()\n}\n\nfunc (s *SQLiteStore) UpdateInstance(ctx context.Context, inst *models.Instance) error {\n\tinst.UpdatedAt = time.Now().UTC()\n\t_, err := s.db.ExecContext(ctx, `\n\t\tUPDATE instances SET\n\t\t\tinstance_type=?, availability_zone=?, private_ip=?, status=?,\n\t\t\tmax_containers=?, running_containers=?, updated_at=?\n\t\tWHERE instance_id = ?`,\n\t\tinst.InstanceType, inst.AvailabilityZone, inst.PrivateIP, inst.Status,\n\t\tinst.MaxContainers, inst.RunningContainers, inst.UpdatedAt.Format(time.RFC3339),\n\t\tinst.InstanceID,\n\t)\n\treturn err\n}\n\n// --- helpers ---\n\ntype scanner interface {\n\tScan(dest ...any) error\n}\n\nfunc scanTask(row scanner) (*models.Task, error) {\n\tvar t models.Task\n\tvar createPR int\n\tvar allowedToolsJSON, envVarsJSON string\n\tvar createdAt, updatedAt string\n\tvar startedAt, completedAt sql.NullString\n\n\terr := row.Scan(\n\t\t&t.ID, &t.Status, &t.RepoURL, &t.Branch, &t.TargetBranch,\n\t\t&t.Prompt, &t.Context, &t.Model, &t.Effort,\n\t\t&t.MaxBudgetUSD, &t.MaxRuntimeMin, &t.MaxTurns,\n\t\t&createPR, &t.PRTitle, &t.PRBody, &t.PRURL,\n\t\t&allowedToolsJSON, &t.ClaudeMD, &envVarsJSON,\n\t\t&t.InstanceID, &t.ContainerID, &t.RetryCount, &t.CostUSD, &t.Error,\n\t\t&createdAt, &updatedAt, &startedAt, &completedAt,\n\t)\n\tif err != nil {\n\t\tif err == sql.ErrNoRows {\n\t\t\treturn nil, nil\n\t\t}\n\t\treturn nil, err\n\t}\n\n\tt.CreatePR = createPR != 0\n\tjson.Unmarshal([]byte(allowedToolsJSON), &t.AllowedTools)\n\tjson.Unmarshal([]byte(envVarsJSON), &t.EnvVars)\n\tt.CreatedAt, _ = time.Parse(time.RFC3339, createdAt)\n\tt.UpdatedAt, _ = time.Parse(time.RFC3339, updatedAt)\n\tif startedAt.Valid {\n\t\tts, _ := time.Parse(time.RFC3339, startedAt.String)\n\t\tt.StartedAt = &ts\n\t}\n\tif completedAt.Valid {\n\t\tts, _ := time.Parse(time.RFC3339, completedAt.String)\n\t\tt.CompletedAt = &ts\n\t}\n\n\treturn &t, nil\n}\n\nfunc scanTaskRows(rows *sql.Rows) (*models.Task, error) {\n\treturn scanTask(rows)\n}\n\nfunc scanInstance(row scanner) (*models.Instance, error) {\n\tvar inst models.Instance\n\tvar createdAt, updatedAt string\n\n\terr := row.Scan(\n\t\t&inst.InstanceID, &inst.InstanceType, &inst.AvailabilityZone,\n\t\t&inst.PrivateIP, &inst.Status, &inst.MaxContainers,\n\t\t&inst.RunningContainers, &createdAt, &updatedAt,\n\t)\n\tif err != nil {\n\t\tif err == sql.ErrNoRows {\n\t\t\treturn nil, nil\n\t\t}\n\t\treturn nil, err\n\t}\n\n\tinst.CreatedAt, _ = time.Parse(time.RFC3339, createdAt)\n\tinst.UpdatedAt, _ = time.Parse(time.RFC3339, updatedAt)\n\treturn &inst, nil\n}\n\nfunc scanInstanceRows(rows *sql.Rows) (*models.Instance, error) {\n\treturn scanInstance(rows)\n}\n\nfunc boolToInt(b bool) int {\n\tif b {\n\t\treturn 1\n\t}\n\treturn 0\n}\n\nfunc timePtr(t *time.Time) any {\n\tif t == nil {\n\t\treturn nil\n\t}\n\treturn t.Format(time.RFC3339)\n}\n","numLines":338,"startLine":1,"totalLines":338}}}
