{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DteJCfn1GRJV6w1v9bZC7H","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→set -euo pipefail\n     3→\n     4→# Create a task via the Backflow API\n     5→#\n     6→# Usage:\n     7→#   ./scripts/create-task.sh <repo_url> <prompt> [options]\n     8→#\n     9→# Examples:\n    10→#   ./scripts/create-task.sh https://github.com/org/repo \"Fix the login bug\"\n    11→#   ./scripts/create-task.sh https://github.com/org/repo \"Add unit tests\" --pr --model claude-sonnet-4-6\n    12→#   ./scripts/create-task.sh https://github.com/org/repo \"Refactor auth\" --pr --pr-title \"Refactor auth module\" --budget 20\n    13→#   ./scripts/create-task.sh https://github.com/org/repo \"Fix bug\" --effort low --model claude-sonnet-4-6\n    14→\n    15→BACKFLOW_URL=\"${BACKFLOW_URL:-http://localhost:8080}\"\n    16→\n    17→usage() {\n    18→    cat <<USAGE\n    19→Usage: $(basename \"$0\") <repo_url> <prompt> [options]\n    20→\n    21→Options:\n    22→  --branch <name>         Working branch name\n    23→  --target-branch <name>  Target branch (default: main)\n    24→  --model <model>         Claude model to use (default: claude-opus-4-6)\n    25→  --effort <level>        Reasoning effort: low, medium, high (default: high)\n    26→  --budget <usd>          Max budget in USD\n    27→  --runtime <min>         Max runtime in minutes\n    28→  --turns <n>             Max conversation turns\n    29→  --pr                    Create a pull request\n    30→  --pr-title <title>      PR title\n    31→  --pr-body <body>        PR body\n    32→  --claude-md <text>      Extra CLAUDE.md content to inject\n    33→  --context <text>        Additional context for the prompt\n    34→  --env <KEY=VALUE>       Environment variable (can repeat)\n    35→USAGE\n    36→    exit 1\n    37→}\n    38→\n    39→if [ $# -lt 2 ]; then\n    40→    usage\n    41→fi\n    42→\n    43→REPO_URL=\"$1\"\n    44→PROMPT=\"$2\"\n    45→shift 2\n    46→\n    47→# Defaults\n    48→BRANCH=\"\"\n    49→TARGET_BRANCH=\"\"\n    50→MODEL=\"claude-opus-4-6\"\n    51→EFFORT=\"high\"\n    52→BUDGET=\"\"\n    53→RUNTIME=\"\"\n    54→TURNS=\"\"\n    55→CREATE_PR=false\n    56→PR_TITLE=\"\"\n    57→PR_BODY=\"\"\n    58→CLAUDE_MD=\"\"\n    59→CONTEXT=\"\"\n    60→declare -a ENV_VARS=()\n    61→\n    62→while [ $# -gt 0 ]; do\n    63→    case \"$1\" in\n    64→        --branch)       BRANCH=\"$2\"; shift 2 ;;\n    65→        --target-branch) TARGET_BRANCH=\"$2\"; shift 2 ;;\n    66→        --model)        MODEL=\"$2\"; shift 2 ;;\n    67→        --effort)       EFFORT=\"$2\"; shift 2 ;;\n    68→        --budget)       BUDGET=\"$2\"; shift 2 ;;\n    69→        --runtime)      RUNTIME=\"$2\"; shift 2 ;;\n    70→        --turns)        TURNS=\"$2\"; shift 2 ;;\n    71→        --pr)           CREATE_PR=true; shift ;;\n    72→        --pr-title)     PR_TITLE=\"$2\"; shift 2 ;;\n    73→        --pr-body)      PR_BODY=\"$2\"; shift 2 ;;\n    74→        --claude-md)    CLAUDE_MD=\"$2\"; shift 2 ;;\n    75→        --context)      CONTEXT=\"$2\"; shift 2 ;;\n    76→        --env)          ENV_VARS+=(\"$2\"); shift 2 ;;\n    77→        *)              echo \"Unknown option: $1\"; usage ;;\n    78→    esac\n    79→done\n    80→\n    81→# Build JSON payload\n    82→JSON=$(jq -n \\\n    83→    --arg repo_url \"$REPO_URL\" \\\n    84→    --arg prompt \"$PROMPT\" \\\n    85→    --arg branch \"$BRANCH\" \\\n    86→    --arg target_branch \"$TARGET_BRANCH\" \\\n    87→    --arg model \"$MODEL\" \\\n    88→    --arg effort \"$EFFORT\" \\\n    89→    --arg budget \"$BUDGET\" \\\n    90→    --arg runtime \"$RUNTIME\" \\\n    91→    --arg turns \"$TURNS\" \\\n    92→    --argjson create_pr \"$CREATE_PR\" \\\n    93→    --arg pr_title \"$PR_TITLE\" \\\n    94→    --arg pr_body \"$PR_BODY\" \\\n    95→    --arg claude_md \"$CLAUDE_MD\" \\\n    96→    --arg context \"$CONTEXT\" \\\n    97→    '{\n    98→        repo_url: $repo_url,\n    99→        prompt: $prompt,\n   100→        create_pr: $create_pr\n   101→    }\n   102→    + if $branch != \"\" then {branch: $branch} else {} end\n   103→    + if $target_branch != \"\" then {target_branch: $target_branch} else {} end\n   104→    + if $model != \"\" then {model: $model} else {} end\n   105→    + if $effort != \"\" then {effort: $effort} else {} end\n   106→    + if $budget != \"\" then {max_budget_usd: ($budget | tonumber)} else {} end\n   107→    + if $runtime != \"\" then {max_runtime_min: ($runtime | tonumber)} else {} end\n   108→    + if $turns != \"\" then {max_turns: ($turns | tonumber)} else {} end\n   109→    + if $pr_title != \"\" then {pr_title: $pr_title} else {} end\n   110→    + if $pr_body != \"\" then {pr_body: $pr_body} else {} end\n   111→    + if $claude_md != \"\" then {claude_md: $claude_md} else {} end\n   112→    + if $context != \"\" then {context: $context} else {} end\n   113→    ')\n   114→\n   115→# Add env vars if any\n   116→if [ ${#ENV_VARS[@]} -gt 0 ]; then\n   117→    ENV_JSON=\"{}\"\n   118→    for pair in \"${ENV_VARS[@]}\"; do\n   119→        key=\"${pair%%=*}\"\n   120→        value=\"${pair#*=}\"\n   121→        ENV_JSON=$(echo \"$ENV_JSON\" | jq --arg k \"$key\" --arg v \"$value\" '. + {($k): $v}')\n   122→    done\n   123→    JSON=$(echo \"$JSON\" | jq --argjson env \"$ENV_JSON\" '. + {env_vars: $env}')\n   124→fi\n   125→\n   126→# Send request\n   127→RESPONSE=$(curl -s -w \"\\n%{http_code}\" \\\n   128→    -X POST \"${BACKFLOW_URL}/api/v1/tasks\" \\\n   129→    -H \"Content-Type: application/json\" \\\n   130→    -d \"$JSON\")\n   131→\n   132→HTTP_CODE=$(echo \"$RESPONSE\" | tail -1)\n   133→BODY=$(echo \"$RESPONSE\" | sed '$d')\n   134→\n   135→if [ \"$HTTP_CODE\" = \"201\" ]; then\n   136→    echo \"$BODY\" | jq .\n   137→    TASK_ID=$(echo \"$BODY\" | jq -r '.data.id')\n   138→    echo \"\"\n   139→    echo \"Useful commands:\"\n   140→    echo \"  # Get task status\"\n   141→    echo \"  curl -s ${BACKFLOW_URL}/api/v1/tasks/${TASK_ID} | jq .\"\n   142→    echo \"\"\n   143→    echo \"  # Stream logs\"\n   144→    echo \"  curl -s ${BACKFLOW_URL}/api/v1/tasks/${TASK_ID}/logs\"\n   145→    echo \"\"\n   146→    echo \"  # Stream logs (last 50 lines)\"\n   147→    echo \"  curl -s '${BACKFLOW_URL}/api/v1/tasks/${TASK_ID}/logs?tail=50'\"\n   148→    echo \"\"\n   149→    echo \"  # Cancel task\"\n   150→    echo \"  curl -s -X DELETE ${BACKFLOW_URL}/api/v1/tasks/${TASK_ID} | jq .\"\n   151→else\n   152→    echo \"Error (HTTP $HTTP_CODE):\" >&2\n   153→    echo \"$BODY\" | jq . 2>/dev/null || echo \"$BODY\" >&2\n   154→    exit 1\n   155→fi\n   156→"}]},"parent_tool_use_id":"toolu_01WjBDJU9gqMDSiqbdYofAYA","session_id":"2af19d51-84dc-4ce3-80b2-7d4b83aa4cbe","uuid":"66c24195-eeb9-4413-9c2f-03fd8531de38"}
