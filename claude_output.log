{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ary5b27nxmGW9ggzeNG85t","type":"tool_result","content":"     1→package orchestrator\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"strings\"\n     6→\t\"time\"\n     7→\n     8→\t\"github.com/aws/aws-sdk-go-v2/aws\"\n     9→\tawsconfig \"github.com/aws/aws-sdk-go-v2/config\"\n    10→\t\"github.com/aws/aws-sdk-go-v2/service/ec2/types\"\n    11→\t\"github.com/aws/aws-sdk-go-v2/service/ssm\"\n    12→\tssmtypes \"github.com/aws/aws-sdk-go-v2/service/ssm/types\"\n    13→\t\"github.com/rs/zerolog/log\"\n    14→\n    15→\t\"github.com/backflow-labs/backflow/internal/config\"\n    16→\t\"github.com/backflow-labs/backflow/internal/models\"\n    17→\t\"github.com/backflow-labs/backflow/internal/store\"\n    18→)\n    19→\n    20→const idleTimeout = 5 * time.Minute\n    21→\n    22→type Scaler struct {\n    23→\tstore     store.Store\n    24→\tec2       *EC2Manager\n    25→\tdocker    *DockerManager\n    26→\tconfig    *config.Config\n    27→\tssmClient *ssm.Client\n    28→}\n    29→\n    30→func NewScaler(s store.Store, ec2 *EC2Manager, docker *DockerManager, cfg *config.Config) *Scaler {\n    31→\treturn &Scaler{store: s, ec2: ec2, docker: docker, config: cfg}\n    32→}\n    33→\n    34→func (s *Scaler) ensureSSMClient(ctx context.Context) error {\n    35→\tif s.ssmClient != nil {\n    36→\t\treturn nil\n    37→\t}\n    38→\tcfg, err := awsconfig.LoadDefaultConfig(ctx, awsconfig.WithRegion(s.config.AWSRegion))\n    39→\tif err != nil {\n    40→\t\treturn err\n    41→\t}\n    42→\ts.ssmClient = ssm.NewFromConfig(cfg)\n    43→\treturn nil\n    44→}\n    45→\n    46→// isSSMReady checks if the SSM agent on the instance is online and ready.\n    47→func (s *Scaler) isSSMReady(ctx context.Context, instanceID string) bool {\n    48→\tif err := s.ensureSSMClient(ctx); err != nil {\n    49→\t\treturn false\n    50→\t}\n    51→\tout, err := s.ssmClient.DescribeInstanceInformation(ctx, &ssm.DescribeInstanceInformationInput{\n    52→\t\tFilters: []ssmtypes.InstanceInformationStringFilter{\n    53→\t\t\t{Key: aws.String(\"InstanceIds\"), Values: []string{instanceID}},\n    54→\t\t},\n    55→\t})\n    56→\tif err != nil {\n    57→\t\treturn false\n    58→\t}\n    59→\tfor _, info := range out.InstanceInformationList {\n    60→\t\tif info.PingStatus == ssmtypes.PingStatusOnline {\n    61→\t\t\treturn true\n    62→\t\t}\n    63→\t}\n    64→\treturn false\n    65→}\n    66→\n    67→// isDockerReady checks if Docker is running and the agent image is available.\n    68→func (s *Scaler) isDockerReady(ctx context.Context, instanceID string) bool {\n    69→\tout, err := s.docker.runSSMCommand(ctx, instanceID, \"docker image inspect backflow-agent:latest >/dev/null 2>&1 && echo ready\")\n    70→\tif err != nil {\n    71→\t\treturn false\n    72→\t}\n    73→\treturn strings.TrimSpace(out) == \"ready\"\n    74→}\n    75→\n    76→// Evaluate checks pending instances, and scales down idle ones.\n    77→func (s *Scaler) Evaluate(ctx context.Context) {\n    78→\ts.reconcilePending(ctx)\n    79→\ts.reconcileRunning(ctx)\n    80→\ts.scaleDown(ctx)\n    81→}\n    82→\n    83→// RequestScaleUp launches a new instance if under the max and none are already pending.\n    84→func (s *Scaler) RequestScaleUp(ctx context.Context) {\n    85→\t// Count all non-terminated instances (pending + running)\n    86→\tallInstances, err := s.store.ListInstances(ctx, nil)\n    87→\tif err != nil {\n    88→\t\tlog.Error().Err(err).Msg(\"scaler: failed to list instances\")\n    89→\t\treturn\n    90→\t}\n    91→\n    92→\tactive := 0\n    93→\tfor _, inst := range allInstances {\n    94→\t\tif inst.Status == models.InstanceStatusPending || inst.Status == models.InstanceStatusRunning {\n    95→\t\t\tactive++\n    96→\t\t}\n    97→\t\t// Don't launch if there's already a pending instance booting up\n    98→\t\tif inst.Status == models.InstanceStatusPending {\n    99→\t\t\tlog.Debug().Str(\"instance_id\", inst.InstanceID).Msg(\"scaler: instance already pending, skipping scale-up\")\n   100→\t\t\treturn\n   101→\t\t}\n   102→\t}\n   103→\n   104→\tif active >= s.config.MaxInstances {\n   105→\t\tlog.Debug().Int(\"active\", active).Int(\"max\", s.config.MaxInstances).Msg(\"scaler: at max instances\")\n   106→\t\treturn\n   107→\t}\n   108→\n   109→\tinstanceID, err := s.ec2.LaunchSpotInstance(ctx)\n   110→\tif err != nil {\n   111→\t\tlog.Error().Err(err).Msg(\"scaler: failed to launch instance\")\n   112→\t\treturn\n   113→\t}\n   114→\n   115→\tnow := time.Now().UTC()\n   116→\tinst := &models.Instance{\n   117→\t\tInstanceID:    instanceID,\n   118→\t\tInstanceType:  s.config.InstanceType,\n   119→\t\tStatus:        models.InstanceStatusPending,\n   120→\t\tMaxContainers: s.config.ContainersPerInst,\n   121→\t\tCreatedAt:     now,\n   122→\t\tUpdatedAt:     now,\n   123→\t}\n   124→\n   125→\tif err := s.store.CreateInstance(ctx, inst); err != nil {\n   126→\t\tlog.Error().Err(err).Str(\"instance_id\", instanceID).Msg(\"scaler: failed to save instance\")\n   127→\t\treturn\n   128→\t}\n   129→\n   130→\tlog.Info().Str(\"instance_id\", instanceID).Msg(\"scaler: launched new instance\")\n   131→}\n   132→\n   133→// reconcilePending checks if pending instances have become running (or failed).\n   134→func (s *Scaler) reconcilePending(ctx context.Context) {\n   135→\tpending := models.InstanceStatusPending\n   136→\tinstances, err := s.store.ListInstances(ctx, &pending)\n   137→\tif err != nil {\n   138→\t\treturn\n   139→\t}\n   140→\n   141→\tfor _, inst := range instances {\n   142→\t\tec2Inst, err := s.ec2.DescribeInstance(ctx, inst.InstanceID)\n   143→\t\tif err != nil {\n   144→\t\t\t// If instance not found, mark terminated\n   145→\t\t\tlog.Warn().Err(err).Str(\"instance_id\", inst.InstanceID).Msg(\"scaler: failed to describe pending instance\")\n   146→\t\t\tif time.Since(inst.CreatedAt) > 5*time.Minute {\n   147→\t\t\t\tinst.Status = models.InstanceStatusTerminated\n   148→\t\t\t\ts.store.UpdateInstance(ctx, inst)\n   149→\t\t\t}\n   150→\t\t\tcontinue"}]},"parent_tool_use_id":"toolu_01WjBDJU9gqMDSiqbdYofAYA","session_id":"2af19d51-84dc-4ce3-80b2-7d4b83aa4cbe","uuid":"65f77b54-9df4-4497-aad5-3511ac74a747"}
