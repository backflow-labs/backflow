{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012uSGS7EGDvKYaC2a7JvVLS","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→set -euo pipefail\n     3→\n     4→# --- Configuration from environment ---\n     5→REPO_URL=\"${REPO_URL:?REPO_URL is required}\"\n     6→PROMPT=\"${PROMPT:?PROMPT is required}\"\n     7→AUTH_MODE=\"${AUTH_MODE:-api_key}\"\n     8→BRANCH=\"${BRANCH:-backflow/${TASK_ID:-$(date +%s)}}\"\n     9→TARGET_BRANCH=\"${TARGET_BRANCH:-main}\"\n    10→MODEL=\"${MODEL:-claude-sonnet-4-6}\"\n    11→EFFORT=\"${EFFORT:-high}\"\n    12→MAX_BUDGET_USD=\"${MAX_BUDGET_USD:-10}\"\n    13→MAX_TURNS=\"${MAX_TURNS:-200}\"\n    14→CREATE_PR=\"${CREATE_PR:-false}\"\n    15→PR_TITLE=\"${PR_TITLE:-}\"\n    16→PR_BODY=\"${PR_BODY:-}\"\n    17→CLAUDE_MD=\"${CLAUDE_MD:-}\"\n    18→TASK_CONTEXT=\"${TASK_CONTEXT:-}\"\n    19→MAX_RETRIES=\"${MAX_RETRIES:-3}\"\n    20→\n    21→WORKSPACE=\"/home/agent/workspace\"\n    22→STATUS_FILE=\"${WORKSPACE}/status.json\"\n    23→\n    24→write_status() {\n    25→    local exit_code=\"$1\"\n    26→    local complete=\"$2\"\n    27→    local needs_input=\"$3\"\n    28→    local question=\"$4\"\n    29→    local error_msg=\"$5\"\n    30→\n    31→    cat > \"$STATUS_FILE\" <<STATUSEOF\n    32→{\n    33→  \"exit_code\": ${exit_code},\n    34→  \"complete\": ${complete},\n    35→  \"needs_input\": ${needs_input},\n    36→  \"question\": $(echo \"$question\" | jq -R .),\n    37→  \"error\": $(echo \"$error_msg\" | jq -R .)\n    38→}\n    39→STATUSEOF\n    40→}\n    41→\n    42→# --- Clone ---\n    43→echo \"==> Cloning ${REPO_URL} (depth 50)...\"\n    44→git clone --depth 50 \"$REPO_URL\" \"$WORKSPACE\"\n    45→cd \"$WORKSPACE\"\n    46→\n    47→# Checkout target branch if it's not the default\n    48→git fetch origin \"$TARGET_BRANCH\" 2>/dev/null || true\n    49→git checkout \"$TARGET_BRANCH\" 2>/dev/null || true\n    50→\n    51→# Create working branch\n    52→git checkout -b \"$BRANCH\"\n    53→echo \"==> Working on branch: ${BRANCH}\"\n    54→\n    55→# --- Inject CLAUDE.md ---\n    56→if [ -n \"$CLAUDE_MD\" ]; then\n    57→    echo \"==> Injecting CLAUDE.md content...\"\n    58→    if [ -f CLAUDE.md ]; then\n    59→        echo \"\" >> CLAUDE.md\n    60→        echo \"$CLAUDE_MD\" >> CLAUDE.md\n    61→    else\n    62→        echo \"$CLAUDE_MD\" > CLAUDE.md\n    63→    fi\n    64→fi\n    65→\n    66→# --- Build prompt ---\n    67→FULL_PROMPT=\"$PROMPT\"\n    68→if [ -n \"$TASK_CONTEXT\" ]; then\n    69→    FULL_PROMPT=\"Context: ${TASK_CONTEXT}\n    70→\n    71→${FULL_PROMPT}\"\n    72→fi\n    73→\n    74→# --- GitHub auth ---\n    75→if [ -n \"${GITHUB_TOKEN:-}\" ]; then\n    76→    echo \"$GITHUB_TOKEN\" | gh auth login --with-token 2>/dev/null || true\n    77→    gh auth setup-git 2>/dev/null || true\n    78→fi\n    79→\n    80→# --- Auth mode setup ---\n    81→echo \"==> Auth mode: ${AUTH_MODE}\"\n    82→echo \"==> Model: ${MODEL}, effort: ${EFFORT}\"\n    83→if [ \"$AUTH_MODE\" = \"api_key\" ]; then\n    84→    if [ -z \"${ANTHROPIC_API_KEY:-}\" ]; then\n    85→        echo \"ERROR: ANTHROPIC_API_KEY is required in api_key mode\" >&2\n    86→        exit 1\n    87→    fi\n    88→elif [ \"$AUTH_MODE\" = \"max_subscription\" ]; then\n    89→    if [ ! -d \"$HOME/.claude\" ]; then\n    90→        echo \"ERROR: ~/.claude credentials not mounted (required for max_subscription mode)\" >&2\n    91→        exit 1\n    92→    fi\n    93→    echo \"==> Using Max subscription credentials from ~/.claude\"\n    94→else\n    95→    echo \"ERROR: Unknown AUTH_MODE: ${AUTH_MODE}\" >&2\n    96→    exit 1\n    97→fi\n    98→\n    99→# --- Build claude command args ---\n   100→CLAUDE_ARGS=(\n   101→    -p \"$FULL_PROMPT\"\n   102→    --dangerously-skip-permissions\n   103→    --model \"$MODEL\"\n   104→    --effort \"$EFFORT\"\n   105→    --max-turns \"$MAX_TURNS\"\n   106→    --output-format json\n   107→    --verbose\n   108→)\n   109→\n   110→# --max-budget-usd only applies to API key mode (billed per token)\n   111→if [ \"$AUTH_MODE\" = \"api_key\" ]; then\n   112→    CLAUDE_ARGS+=(--max-budget-usd \"$MAX_BUDGET_USD\")\n   113→fi\n   114→\n   115→# --- Run Claude Code with retries ---\n   116→ATTEMPT=0\n   117→CLAUDE_EXIT=1\n   118→CLAUDE_OUTPUT=\"\"\n   119→\n   120→while [ $ATTEMPT -lt \"$MAX_RETRIES\" ]; do\n   121→    ATTEMPT=$((ATTEMPT + 1))\n   122→    echo \"==> Running Claude Code (attempt ${ATTEMPT}/${MAX_RETRIES})...\"\n   123→\n   124→    set +e\n   125→    CLAUDE_OUTPUT=$(claude \"${CLAUDE_ARGS[@]}\" 2>&1)\n   126→    CLAUDE_EXIT=$?\n   127→    set -e\n   128→\n   129→    if [ $CLAUDE_EXIT -eq 0 ]; then\n   130→        echo \"==> Claude Code completed successfully\"\n   131→        break\n   132→    fi\n   133→\n   134→    echo \"==> Claude Code exited with code ${CLAUDE_EXIT} (attempt ${ATTEMPT})\"\n   135→    echo \"$CLAUDE_OUTPUT\" | tail -30\n   136→\n   137→    if [ $ATTEMPT -lt \"$MAX_RETRIES\" ]; then\n   138→        # Add error context to prompt for retry\n   139→        ERROR_TAIL=$(echo \"$CLAUDE_OUTPUT\" | tail -20)\n   140→        FULL_PROMPT=\"Previous attempt failed with error:\n   141→${ERROR_TAIL}\n   142→\n   143→Please try again:\n   144→${PROMPT}\"\n   145→        # Rebuild args with updated prompt\n   146→        CLAUDE_ARGS=( -p \"$FULL_PROMPT\" --dangerously-skip-permissions --model \"$MODEL\" --effort \"$EFFORT\" --max-turns \"$MAX_TURNS\" --output-format json --verbose )\n   147→        if [ \"$AUTH_MODE\" = \"api_key\" ]; then\n   148→            CLAUDE_ARGS+=(--max-budget-usd \"$MAX_BUDGET_USD\")\n   149→        fi\n   150→    fi\n   151→done\n   152→\n   153→# --- Detect needs_input ---\n   154→NEEDS_INPUT=false\n   155→QUESTION=\"\"\n   156→\n   157→if echo \"$CLAUDE_OUTPUT\" | jq -e '.result' 2>/dev/null | grep -qi 'question\\|decision\\|should I\\|which approach\\|do you want\\|please clarify'; then\n   158→    NEEDS_INPUT=true\n   159→    QUESTION=$(echo \"$CLAUDE_OUTPUT\" | jq -r '.result // empty' 2>/dev/null | tail -5)\n   160→fi\n   161→\n   162→# If claude ran out of turns without completing\n   163→if echo \"$CLAUDE_OUTPUT\" | jq -e '.is_error' 2>/dev/null | grep -q 'true'; then\n   164→    if echo \"$CLAUDE_OUTPUT\" | jq -r '.error_type // empty' 2>/dev/null | grep -q 'max_turns'; then\n   165→        NEEDS_INPUT=true\n   166→        QUESTION=\"Agent ran out of turns (${MAX_TURNS}) without completing the task\"\n   167→    fi\n   168→fi\n   169→\n   170→# --- Write status ---\n   171→COMPLETE=false\n   172→if [ $CLAUDE_EXIT -eq 0 ]; then\n   173→    COMPLETE=true\n   174→fi\n   175→ERROR_MSG=\"\"\n   176→if [ $CLAUDE_EXIT -ne 0 ]; then\n   177→    ERROR_MSG=$(echo \"$CLAUDE_OUTPUT\" | tail -5)\n   178→fi\n   179→write_status \"$CLAUDE_EXIT\" \"$COMPLETE\" \"$NEEDS_INPUT\" \"$QUESTION\" \"$ERROR_MSG\"\n   180→\n   181→# --- Commit remaining changes ---\n   182→echo \"==> Committing any remaining changes...\"\n   183→git add -A\n   184→if ! git diff --cached --quiet; then\n   185→    COMMIT_MSG=\"backflow: agent work on task ${TASK_ID:-unknown}\n   186→\n   187→Automated commit by backflow agent.\n   188→Model: ${MODEL}\"\n   189→    if [ \"$AUTH_MODE\" = \"api_key\" ]; then\n   190→        COMMIT_MSG=\"${COMMIT_MSG}\n   191→Budget: \\$${MAX_BUDGET_USD}\"\n   192→    fi\n   193→    git commit -m \"$COMMIT_MSG\"\n   194→fi\n   195→\n   196→# --- Push ---\n   197→echo \"==> Pushing branch ${BRANCH}...\"\n   198→git push origin \"$BRANCH\" --force-with-lease 2>/dev/null || git push origin \"$BRANCH\"\n   199→\n   200→# --- Create PR ---\n   201→if [ \"$CREATE_PR\" = \"true\" ]; then\n   202→    echo \"==> Creating pull request...\"\n   203→    PR_TITLE_FINAL=\"${PR_TITLE:-[backflow] ${PROMPT:0:60}}\"\n   204→\n   205→    if [ -z \"$PR_BODY\" ]; then\n   206→        PR_BODY=\"## Automated PR by Backflow\n   207→\n   208→**Task:** ${PROMPT}\n   209→\n   210→**Model:** ${MODEL}\"\n   211→        if [ \"$AUTH_MODE\" = \"api_key\" ]; then\n   212→            PR_BODY=\"${PR_BODY}\n   213→**Budget:** \\$${MAX_BUDGET_USD}\"\n   214→        else\n   215→            PR_BODY=\"${PR_BODY}\n   216→**Auth:** Max subscription\"\n   217→        fi\n   218→        PR_BODY=\"${PR_BODY}\n   219→\n   220→---\n   221→*Created by [backflow](https://github.com/backflow-labs/backflow) agent*\"\n   222→    fi\n   223→\n   224→    PR_URL=$(gh pr create \\\n   225→        --title \"$PR_TITLE_FINAL\" \\\n   226→        --body \"$PR_BODY\" \\\n   227→        --base \"$TARGET_BRANCH\" \\\n   228→        --head \"$BRANCH\" 2>&1) || true\n   229→\n   230→    if [ -n \"$PR_URL\" ]; then\n   231→        echo \"==> PR created: ${PR_URL}\"\n   232→    fi\n   233→fi\n   234→\n   235→echo \"==> Done (exit code: ${CLAUDE_EXIT})\"\n   236→exit $CLAUDE_EXIT\n   237→"}]},"parent_tool_use_id":"toolu_01WjBDJU9gqMDSiqbdYofAYA","session_id":"2af19d51-84dc-4ce3-80b2-7d4b83aa4cbe","uuid":"30c92df5-ad0f-4f53-b181-d0d2e5de1762"}
