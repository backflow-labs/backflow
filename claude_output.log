{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NLKWh2XLZh3mpKnZULmaW1","type":"tool_result","content":"     1→package api\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"net/http\"\n     7→\t\"strconv\"\n     8→\t\"time\"\n     9→\n    10→\t\"github.com/go-chi/chi/v5\"\n    11→\t\"github.com/oklog/ulid/v2\"\n    12→\n    13→\t\"github.com/backflow-labs/backflow/internal/config\"\n    14→\t\"github.com/backflow-labs/backflow/internal/models\"\n    15→\t\"github.com/backflow-labs/backflow/internal/store\"\n    16→)\n    17→\n    18→// LogFetcher retrieves container logs for a running task.\n    19→type LogFetcher interface {\n    20→\tGetLogs(ctx context.Context, instanceID, containerID string, tail int) (string, error)\n    21→}\n    22→\n    23→type Handlers struct {\n    24→\tstore  store.Store\n    25→\tconfig *config.Config\n    26→\tlogs   LogFetcher\n    27→}\n    28→\n    29→func NewHandlers(s store.Store, cfg *config.Config, logs LogFetcher) *Handlers {\n    30→\treturn &Handlers{store: s, config: cfg, logs: logs}\n    31→}\n    32→\n    33→func (h *Handlers) CreateTask(w http.ResponseWriter, r *http.Request) {\n    34→\tvar req models.CreateTaskRequest\n    35→\tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n    36→\t\twriteError(w, http.StatusBadRequest, \"invalid JSON: \"+err.Error())\n    37→\t\treturn\n    38→\t}\n    39→\tif err := req.Validate(); err != nil {\n    40→\t\twriteError(w, http.StatusBadRequest, err.Error())\n    41→\t\treturn\n    42→\t}\n    43→\n    44→\tnow := time.Now().UTC()\n    45→\ttask := &models.Task{\n    46→\t\tID:            \"bf_\" + ulid.Make().String(),\n    47→\t\tStatus:        models.TaskStatusPending,\n    48→\t\tRepoURL:       req.RepoURL,\n    49→\t\tBranch:        req.Branch,\n    50→\t\tTargetBranch:  req.TargetBranch,\n    51→\t\tPrompt:        req.Prompt,\n    52→\t\tContext:       req.Context,\n    53→\t\tModel:         withDefault(req.Model, h.config.DefaultModel),\n    54→\t\tEffort:        withDefault(req.Effort, h.config.DefaultEffort),\n    55→\t\tMaxBudgetUSD:  withDefaultFloat(req.MaxBudgetUSD, h.config.DefaultMaxBudget),\n    56→\t\tMaxRuntimeMin: withDefaultInt(req.MaxRuntimeMin, int(h.config.DefaultMaxRuntime.Minutes())),\n    57→\t\tMaxTurns:      withDefaultInt(req.MaxTurns, h.config.DefaultMaxTurns),\n    58→\t\tCreatePR:      req.CreatePR,\n    59→\t\tPRTitle:       req.PRTitle,\n    60→\t\tPRBody:        req.PRBody,\n    61→\t\tAllowedTools:  req.AllowedTools,\n    62→\t\tClaudeMD:      req.ClaudeMD,\n    63→\t\tEnvVars:       req.EnvVars,\n    64→\t\tCreatedAt:     now,\n    65→\t\tUpdatedAt:     now,\n    66→\t}\n    67→\n    68→\tif err := h.store.CreateTask(r.Context(), task); err != nil {\n    69→\t\twriteError(w, http.StatusInternalServerError, \"failed to create task\")\n    70→\t\treturn\n    71→\t}\n    72→\n    73→\twriteJSON(w, http.StatusCreated, task)\n    74→}\n    75→\n    76→func (h *Handlers) GetTask(w http.ResponseWriter, r *http.Request) {\n    77→\tid := chi.URLParam(r, \"id\")\n    78→\ttask, err := h.store.GetTask(r.Context(), id)\n    79→\tif err != nil {\n    80→\t\twriteError(w, http.StatusInternalServerError, \"failed to get task\")\n    81→\t\treturn\n    82→\t}\n    83→\tif task == nil {\n    84→\t\twriteError(w, http.StatusNotFound, \"task not found\")\n    85→\t\treturn\n    86→\t}\n    87→\twriteJSON(w, http.StatusOK, task)\n    88→}\n    89→\n    90→func (h *Handlers) ListTasks(w http.ResponseWriter, r *http.Request) {\n    91→\tfilter := store.TaskFilter{\n    92→\t\tLimit:  50,\n    93→\t\tOffset: 0,\n    94→\t}\n    95→\tif s := r.URL.Query().Get(\"status\"); s != \"\" {\n    96→\t\tstatus := models.TaskStatus(s)\n    97→\t\tfilter.Status = &status\n    98→\t}\n    99→\tif l := r.URL.Query().Get(\"limit\"); l != \"\" {\n   100→\t\tif n, err := strconv.Atoi(l); err == nil && n > 0 {\n   101→\t\t\tfilter.Limit = n\n   102→\t\t}\n   103→\t}\n   104→\tif o := r.URL.Query().Get(\"offset\"); o != \"\" {\n   105→\t\tif n, err := strconv.Atoi(o); err == nil && n >= 0 {\n   106→\t\t\tfilter.Offset = n\n   107→\t\t}\n   108→\t}\n   109→\n   110→\ttasks, err := h.store.ListTasks(r.Context(), filter)\n   111→\tif err != nil {\n   112→\t\twriteError(w, http.StatusInternalServerError, \"failed to list tasks\")\n   113→\t\treturn\n   114→\t}\n   115→\tif tasks == nil {\n   116→\t\ttasks = []*models.Task{}\n   117→\t}\n   118→\twriteJSON(w, http.StatusOK, tasks)\n   119→}\n   120→\n   121→func (h *Handlers) DeleteTask(w http.ResponseWriter, r *http.Request) {\n   122→\tid := chi.URLParam(r, \"id\")\n   123→\ttask, err := h.store.GetTask(r.Context(), id)\n   124→\tif err != nil {\n   125→\t\twriteError(w, http.StatusInternalServerError, \"failed to get task\")\n   126→\t\treturn\n   127→\t}\n   128→\tif task == nil {\n   129→\t\twriteError(w, http.StatusNotFound, \"task not found\")\n   130→\t\treturn\n   131→\t}\n   132→\n   133→\t// If running, mark as cancelled (orchestrator will kill the container)\n   134→\tif task.Status == models.TaskStatusRunning || task.Status == models.TaskStatusProvisioning {\n   135→\t\ttask.Status = models.TaskStatusCancelled\n   136→\t\tnow := time.Now().UTC()\n   137→\t\ttask.CompletedAt = &now\n   138→\t\tif err := h.store.UpdateTask(r.Context(), task); err != nil {\n   139→\t\t\twriteError(w, http.StatusInternalServerError, \"failed to cancel task\")\n   140→\t\t\treturn\n   141→\t\t}\n   142→\t} else if !task.Status.IsTerminal() {\n   143→\t\tif err := h.store.DeleteTask(r.Context(), id); err != nil {\n   144→\t\t\twriteError(w, http.StatusInternalServerError, \"failed to delete task\")\n   145→\t\t\treturn\n   146→\t\t}\n   147→\t}\n   148→\n   149→\tw.WriteHeader(http.StatusNoContent)\n   150→}\n   151→\n   152→func (h *Handlers) GetTaskLogs(w http.ResponseWriter, r *http.Request) {\n   153→\tid := chi.URLParam(r, \"id\")\n   154→\ttask, err := h.store.GetTask(r.Context(), id)\n   155→\tif err != nil {\n   156→\t\twriteError(w, http.StatusInternalServerError, \"failed to get task\")\n   157→\t\treturn\n   158→\t}\n   159→\tif task == nil {\n   160→\t\twriteError(w, http.StatusNotFound, \"task not found\")\n   161→\t\treturn\n   162→\t}\n   163→\n   164→\tif task.InstanceID == \"\" || task.ContainerID == \"\" {\n   165→\t\tw.Header().Set(\"Content-Type\", \"text/plain\")\n   166→\t\tw.WriteHeader(http.StatusOK)\n   167→\t\tmsg := \"status: \" + string(task.Status) + \"\\n\"\n   168→\t\tif task.Error != \"\" {\n   169→\t\t\tmsg += \"error: \" + task.Error + \"\\n\"\n   170→\t\t}\n   171→\t\tw.Write([]byte(msg))\n   172→\t\treturn\n   173→\t}\n   174→\n   175→\ttail := 100\n   176→\tif t := r.URL.Query().Get(\"tail\"); t != \"\" {\n   177→\t\tif n, err := strconv.Atoi(t); err == nil && n > 0 {\n   178→\t\t\ttail = n\n   179→\t\t}\n   180→\t}\n   181→\n   182→\tlogs, err := h.logs.GetLogs(r.Context(), task.InstanceID, task.ContainerID, tail)\n   183→\tif err != nil {\n   184→\t\twriteError(w, http.StatusBadGateway, \"failed to fetch logs: \"+err.Error())\n   185→\t\treturn\n   186→\t}\n   187→\n   188→\tw.Header().Set(\"Content-Type\", \"text/plain\")\n   189→\tw.WriteHeader(http.StatusOK)\n   190→\tw.Write([]byte(logs))\n   191→}\n   192→\n   193→func (h *Handlers) HealthCheck(w http.ResponseWriter, r *http.Request) {\n   194→\twriteJSON(w, http.StatusOK, map[string]string{\n   195→\t\t\"status\":    \"ok\",\n   196→\t\t\"auth_mode\": string(h.config.AuthMode),\n   197→\t})\n   198→}\n   199→\n   200→func withDefault(val, fallback string) string {\n   201→\tif val == \"\" {\n   202→\t\treturn fallback\n   203→\t}\n   204→\treturn val\n   205→}\n   206→\n   207→func withDefaultFloat(val, fallback float64) float64 {\n   208→\tif val == 0 {\n   209→\t\treturn fallback\n   210→\t}\n   211→\treturn val\n   212→}\n   213→\n   214→func withDefaultInt(val, fallback int) int {\n   215→\tif val == 0 {\n   216→\t\treturn fallback\n   217→\t}\n   218→\treturn val\n   219→}\n   220→"}]},"parent_tool_use_id":"toolu_01WjBDJU9gqMDSiqbdYofAYA","session_id":"2af19d51-84dc-4ce3-80b2-7d4b83aa4cbe","uuid":"32852ee4-f63f-4e42-935e-5db871eae5b6"}
