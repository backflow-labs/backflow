{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DVQtJxKLdpRds6EmzAzwAT","type":"tool_result","content":"     1→package config\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"os\"\n     6→\t\"strconv\"\n     7→\t\"strings\"\n     8→\t\"time\"\n     9→)\n    10→\n    11→type AuthMode string\n    12→\n    13→const (\n    14→\tAuthModeAPIKey          AuthMode = \"api_key\"\n    15→\tAuthModeMaxSubscription AuthMode = \"max_subscription\"\n    16→)\n    17→\n    18→type Config struct {\n    19→\t// Server\n    20→\tListenAddr string\n    21→\n    22→\t// Auth\n    23→\tAuthMode             AuthMode\n    24→\tAnthropicAPIKey      string\n    25→\tClaudeCredentialsPath string\n    26→\n    27→\t// AWS\n    28→\tAWSRegion        string\n    29→\tInstanceType     string\n    30→\tAMI              string\n    31→\tMaxInstances     int\n    32→\tContainersPerInst int\n    33→\tLaunchTemplateID string\n    34→\n    35→\t// Agent defaults\n    36→\tDefaultModel      string\n    37→\tDefaultEffort     string\n    38→\tDefaultMaxBudget  float64\n    39→\tDefaultMaxRuntime time.Duration\n    40→\tDefaultMaxTurns   int\n    41→\n    42→\t// GitHub\n    43→\tGitHubToken string\n    44→\n    45→\t// Webhooks\n    46→\tWebhookURL    string\n    47→\tWebhookEvents []string\n    48→\n    49→\t// Database\n    50→\tDBPath string\n    51→\n    52→\t// Orchestrator\n    53→\tPollInterval time.Duration\n    54→}\n    55→\n    56→func (c *Config) MaxConcurrent() int {\n    57→\tif c.AuthMode == AuthModeMaxSubscription {\n    58→\t\treturn 1\n    59→\t}\n    60→\treturn c.MaxInstances * c.ContainersPerInst\n    61→}\n    62→\n    63→func Load() (*Config, error) {\n    64→\tc := &Config{\n    65→\t\tListenAddr:        envOr(\"BACKFLOW_LISTEN_ADDR\", \":8080\"),\n    66→\t\tAuthMode:          AuthMode(envOr(\"BACKFLOW_AUTH_MODE\", string(AuthModeAPIKey))),\n    67→\t\tAnthropicAPIKey:   os.Getenv(\"ANTHROPIC_API_KEY\"),\n    68→\t\tClaudeCredentialsPath: envOr(\"CLAUDE_CREDENTIALS_PATH\", \"\"),\n    69→\t\tAWSRegion:         envOr(\"AWS_REGION\", \"us-east-1\"),\n    70→\t\tInstanceType:      envOr(\"BACKFLOW_INSTANCE_TYPE\", \"t4g.medium\"),\n    71→\t\tAMI:               os.Getenv(\"BACKFLOW_AMI\"),\n    72→\t\tMaxInstances:      envInt(\"BACKFLOW_MAX_INSTANCES\", 5),\n    73→\t\tContainersPerInst: envInt(\"BACKFLOW_CONTAINERS_PER_INSTANCE\", 4),\n    74→\t\tLaunchTemplateID:  os.Getenv(\"BACKFLOW_LAUNCH_TEMPLATE_ID\"),\n    75→\t\tDefaultModel:      envOr(\"BACKFLOW_DEFAULT_MODEL\", \"claude-sonnet-4-6\"),\n    76→\t\tDefaultEffort:     envOr(\"BACKFLOW_DEFAULT_EFFORT\", \"high\"),\n    77→\t\tDefaultMaxBudget:  envFloat(\"BACKFLOW_DEFAULT_MAX_BUDGET\", 10.0),\n    78→\t\tDefaultMaxRuntime: time.Duration(envInt(\"BACKFLOW_DEFAULT_MAX_RUNTIME_MIN\", 30)) * time.Minute,\n    79→\t\tDefaultMaxTurns:   envInt(\"BACKFLOW_DEFAULT_MAX_TURNS\", 200),\n    80→\t\tGitHubToken:       os.Getenv(\"GITHUB_TOKEN\"),\n    81→\t\tWebhookURL:        os.Getenv(\"BACKFLOW_WEBHOOK_URL\"),\n    82→\t\tDBPath:            envOr(\"BACKFLOW_DB_PATH\", \"backflow.db\"),\n    83→\t\tPollInterval:      time.Duration(envInt(\"BACKFLOW_POLL_INTERVAL_SEC\", 5)) * time.Second,\n    84→\t}\n    85→\n    86→\tif events := os.Getenv(\"BACKFLOW_WEBHOOK_EVENTS\"); events != \"\" {\n    87→\t\tc.WebhookEvents = strings.Split(events, \",\")\n    88→\t\tfor i := range c.WebhookEvents {\n    89→\t\t\tc.WebhookEvents[i] = strings.TrimSpace(c.WebhookEvents[i])\n    90→\t\t}\n    91→\t}\n    92→\n    93→\tif c.AuthMode != AuthModeAPIKey && c.AuthMode != AuthModeMaxSubscription {\n    94→\t\treturn nil, fmt.Errorf(\"invalid BACKFLOW_AUTH_MODE: %q (must be %q or %q)\", c.AuthMode, AuthModeAPIKey, AuthModeMaxSubscription)\n    95→\t}\n    96→\n    97→\tif c.AuthMode == AuthModeAPIKey && c.AnthropicAPIKey == \"\" {\n    98→\t\treturn nil, fmt.Errorf(\"ANTHROPIC_API_KEY is required when BACKFLOW_AUTH_MODE=api_key\")\n    99→\t}\n   100→\n   101→\treturn c, nil\n   102→}\n   103→\n   104→func envOr(key, fallback string) string {\n   105→\tif v := os.Getenv(key); v != \"\" {\n   106→\t\treturn v\n   107→\t}\n   108→\treturn fallback\n   109→}\n   110→\n   111→func envInt(key string, fallback int) int {\n   112→\tif v := os.Getenv(key); v != \"\" {\n   113→\t\tif n, err := strconv.Atoi(v); err == nil {\n   114→\t\t\treturn n\n   115→\t\t}\n   116→\t}\n   117→\treturn fallback\n   118→}\n   119→\n   120→func envFloat(key string, fallback float64) float64 {\n   121→\tif v := os.Getenv(key); v != \"\" {\n   122→\t\tif f, err := strconv.ParseFloat(v, 64); err == nil {\n   123→\t\t\treturn f\n   124→\t\t}\n   125→\t}\n   126→\treturn fallback\n   127→}\n   128→"}]},"parent_tool_use_id":"toolu_01WjBDJU9gqMDSiqbdYofAYA","session_id":"2af19d51-84dc-4ce3-80b2-7d4b83aa4cbe","uuid":"2689e78d-d752-438a-9369-e6285605ced2"}
