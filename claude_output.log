{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PMbRZ21FSRkayeW4Vq1YkD","type":"tool_result","content":"     1→package orchestrator\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"strings\"\n     8→\t\"time\"\n     9→\n    10→\t\"github.com/aws/aws-sdk-go-v2/aws\"\n    11→\tawsconfig \"github.com/aws/aws-sdk-go-v2/config\"\n    12→\t\"github.com/aws/aws-sdk-go-v2/service/ssm\"\n    13→\t\"github.com/rs/zerolog/log\"\n    14→\n    15→\t\"github.com/backflow-labs/backflow/internal/config\"\n    16→\t\"github.com/backflow-labs/backflow/internal/models\"\n    17→)\n    18→\n    19→type ContainerStatus struct {\n    20→\tDone       bool\n    21→\tExitCode   int\n    22→\tNeedsInput bool\n    23→\tQuestion   string\n    24→\tError      string\n    25→\tLogTail    string\n    26→}\n    27→\n    28→type DockerManager struct {\n    29→\tconfig    *config.Config\n    30→\tssmClient *ssm.Client\n    31→}\n    32→\n    33→func NewDockerManager(cfg *config.Config) *DockerManager {\n    34→\treturn &DockerManager{config: cfg}\n    35→}\n    36→\n    37→func (m *DockerManager) ensureClient(ctx context.Context) error {\n    38→\tif m.ssmClient != nil {\n    39→\t\treturn nil\n    40→\t}\n    41→\tcfg, err := awsconfig.LoadDefaultConfig(ctx, awsconfig.WithRegion(m.config.AWSRegion))\n    42→\tif err != nil {\n    43→\t\treturn fmt.Errorf(\"load AWS config: %w\", err)\n    44→\t}\n    45→\tm.ssmClient = ssm.NewFromConfig(cfg)\n    46→\treturn nil\n    47→}\n    48→\n    49→func (m *DockerManager) RunAgent(ctx context.Context, instance *models.Instance, task *models.Task) (string, error) {\n    50→\tif err := m.ensureClient(ctx); err != nil {\n    51→\t\treturn \"\", err\n    52→\t}\n    53→\n    54→\tenvFlags := []string{\n    55→\t\tfmt.Sprintf(\"-e TASK_ID=%s\", task.ID),\n    56→\t\tfmt.Sprintf(\"-e REPO_URL=%s\", shellEscape(task.RepoURL)),\n    57→\t\tfmt.Sprintf(\"-e BRANCH=%s\", shellEscape(task.Branch)),\n    58→\t\tfmt.Sprintf(\"-e TARGET_BRANCH=%s\", shellEscape(task.TargetBranch)),\n    59→\t\tfmt.Sprintf(\"-e PROMPT=%s\", shellEscape(task.Prompt)),\n    60→\t\tfmt.Sprintf(\"-e MODEL=%s\", shellEscape(task.Model)),\n    61→\t\tfmt.Sprintf(\"-e EFFORT=%s\", shellEscape(task.Effort)),\n    62→\t\tfmt.Sprintf(\"-e MAX_BUDGET_USD=%g\", task.MaxBudgetUSD),\n    63→\t\tfmt.Sprintf(\"-e MAX_TURNS=%d\", task.MaxTurns),\n    64→\t\tfmt.Sprintf(\"-e CREATE_PR=%t\", task.CreatePR),\n    65→\t}\n    66→\n    67→\tif task.PRTitle != \"\" {\n    68→\t\tenvFlags = append(envFlags, fmt.Sprintf(\"-e PR_TITLE=%s\", shellEscape(task.PRTitle)))\n    69→\t}\n    70→\tif task.PRBody != \"\" {\n    71→\t\tenvFlags = append(envFlags, fmt.Sprintf(\"-e PR_BODY=%s\", shellEscape(task.PRBody)))\n    72→\t}\n    73→\tif task.ClaudeMD != \"\" {\n    74→\t\tenvFlags = append(envFlags, fmt.Sprintf(\"-e CLAUDE_MD=%s\", shellEscape(task.ClaudeMD)))\n    75→\t}\n    76→\tif task.Context != \"\" {\n    77→\t\tenvFlags = append(envFlags, fmt.Sprintf(\"-e TASK_CONTEXT=%s\", shellEscape(task.Context)))\n    78→\t}\n    79→\n    80→\t// Auth mode\n    81→\tenvFlags = append(envFlags, fmt.Sprintf(\"-e AUTH_MODE=%s\", string(m.config.AuthMode)))\n    82→\tif m.config.AuthMode == config.AuthModeAPIKey {\n    83→\t\tenvFlags = append(envFlags, fmt.Sprintf(\"-e ANTHROPIC_API_KEY=%s\", m.config.AnthropicAPIKey))\n    84→\t}\n    85→\n    86→\tif m.config.GitHubToken != \"\" {\n    87→\t\tenvFlags = append(envFlags, fmt.Sprintf(\"-e GITHUB_TOKEN=%s\", m.config.GitHubToken))\n    88→\t}\n    89→\n    90→\t// Custom env vars from task\n    91→\tfor k, v := range task.EnvVars {\n    92→\t\tenvFlags = append(envFlags, fmt.Sprintf(\"-e %s=%s\", k, shellEscape(v)))\n    93→\t}\n    94→\n    95→\tvolumeFlags := \"\"\n    96→\tif m.config.AuthMode == config.AuthModeMaxSubscription && m.config.ClaudeCredentialsPath != \"\" {\n    97→\t\tvolumeFlags = fmt.Sprintf(\"-v %s:/home/agent/.claude:ro\", m.config.ClaudeCredentialsPath)\n    98→\t}\n    99→\n   100→\tcmd := fmt.Sprintf(\n   101→\t\t\"docker run -d --cpus=1 --memory=3g %s %s backflow-agent\",\n   102→\t\tvolumeFlags,\n   103→\t\tstrings.Join(envFlags, \" \"),\n   104→\t)\n   105→\n   106→\toutput, err := m.runSSMCommand(ctx, instance.InstanceID, cmd)\n   107→\tif err != nil {\n   108→\t\treturn \"\", fmt.Errorf(\"run container: %w\", err)\n   109→\t}\n   110→\n   111→\tcontainerID := strings.TrimSpace(output)\n   112→\tif containerID == \"\" {\n   113→\t\treturn \"\", fmt.Errorf(\"empty container ID returned\")\n   114→\t}\n   115→\n   116→\t// Docker container IDs are 64-char hex strings; reject anything else\n   117→\t// (e.g. error messages captured via 2>&1)\n   118→\tif !isHexString(containerID) {\n   119→\t\treturn \"\", fmt.Errorf(\"docker run failed: %s\", containerID)\n   120→\t}\n   121→\n   122→\tlog.Debug().Str(\"container\", containerID[:12]).Str(\"instance\", instance.InstanceID).Msg(\"started agent container\")\n   123→\treturn containerID, nil\n   124→}\n   125→\n   126→func (m *DockerManager) InspectContainer(ctx context.Context, instanceID, containerID string) (ContainerStatus, error) {\n   127→\tif err := m.ensureClient(ctx); err != nil {\n   128→\t\treturn ContainerStatus{}, err\n   129→\t}\n   130→\n   131→\tcmd := fmt.Sprintf(\"docker inspect --format '{{.State.Status}} {{.State.ExitCode}}' %s 2>/dev/null && docker logs --tail 20 %s 2>&1\", containerID, containerID)\n   132→\toutput, err := m.runSSMCommand(ctx, instanceID, cmd)\n   133→\tif err != nil {\n   134→\t\treturn ContainerStatus{}, err\n   135→\t}\n   136→\n   137→\tlines := strings.SplitN(output, \"\\n\", 2)\n   138→\tif len(lines) == 0 {\n   139→\t\treturn ContainerStatus{}, fmt.Errorf(\"empty inspect output\")\n   140→\t}\n   141→\n   142→\tparts := strings.Fields(lines[0])\n   143→\tif len(parts) < 2 {\n   144→\t\treturn ContainerStatus{}, fmt.Errorf(\"unexpected inspect format: %s\", lines[0])\n   145→\t}\n   146→\n   147→\tstatus := ContainerStatus{}\n   148→\tif len(lines) > 1 {\n   149→\t\tstatus.LogTail = lines[1]\n   150→\t}\n   151→\n   152→\tdockerStatus := parts[0]\n   153→\tif dockerStatus == \"exited\" || dockerStatus == \"dead\" {\n   154→\t\tstatus.Done = true\n   155→\t\tfmt.Sscanf(parts[1], \"%d\", &status.ExitCode)\n   156→\n   157→\t\tif status.ExitCode != 0 {\n   158→\t\t\tstatus.Error = fmt.Sprintf(\"container exited with code %d\", status.ExitCode)\n   159→\t\t}\n   160→\n   161→\t\t// Check for status.json written by entrypoint\n   162→\t\tstatusCmd := fmt.Sprintf(\"docker cp %s:/home/agent/workspace/status.json /dev/stdout 2>/dev/null\", containerID)\n   163→\t\tif statusJSON, err := m.runSSMCommand(ctx, instanceID, statusCmd); err == nil {\n   164→\t\t\tvar agentStatus struct {\n   165→\t\t\t\tNeedsInput bool   `json:\"needs_input\"`\n   166→\t\t\t\tQuestion   string `json:\"question\"`\n   167→\t\t\t\tComplete   bool   `json:\"complete\"`\n   168→\t\t\t\tError      string `json:\"error\"`\n   169→\t\t\t}\n   170→\t\t\tif json.Unmarshal([]byte(statusJSON), &agentStatus) == nil {\n   171→\t\t\t\tstatus.NeedsInput = agentStatus.NeedsInput\n   172→\t\t\t\tstatus.Question = agentStatus.Question\n   173→\t\t\t\tif agentStatus.Error != \"\" {\n   174→\t\t\t\t\tstatus.Error = agentStatus.Error\n   175→\t\t\t\t}\n   176→\t\t\t}\n   177→\t\t}\n   178→\t}\n   179→\n   180→\treturn status, nil\n   181→}\n   182→\n   183→func (m *DockerManager) StopContainer(ctx context.Context, instanceID, containerID string) error {\n   184→\tif err := m.ensureClient(ctx); err != nil {\n   185→\t\treturn err\n   186→\t}\n   187→\n   188→\tcmd := fmt.Sprintf(\"docker stop -t 30 %s 2>/dev/null; docker rm %s 2>/dev/null\", containerID, containerID)\n   189→\t_, err := m.runSSMCommand(ctx, instanceID, cmd)\n   190→\treturn err\n   191→}\n   192→\n   193→func (m *DockerManager) GetLogs(ctx context.Context, instanceID, containerID string, tail int) (string, error) {\n   194→\tif err := m.ensureClient(ctx); err != nil {\n   195→\t\treturn \"\", err\n   196→\t}\n   197→\n   198→\tcmd := fmt.Sprintf(\"docker logs --tail %d %s 2>&1\", tail, containerID)\n   199→\treturn m.runSSMCommand(ctx, instanceID, cmd)\n   200→}\n   201→\n   202→func (m *DockerManager) runSSMCommand(ctx context.Context, instanceID, command string) (string, error) {\n   203→\tif err := m.ensureClient(ctx); err != nil {\n   204→\t\treturn \"\", err\n   205→\t}\n   206→\n   207→\tinput := &ssm.SendCommandInput{\n   208→\t\tInstanceIds:  []string{instanceID},\n   209→\t\tDocumentName: aws.String(\"AWS-RunShellScript\"),\n   210→\t\tParameters: map[string][]string{\n   211→\t\t\t\"commands\": {command},\n   212→\t\t},\n   213→\t}\n   214→\n   215→\tresult, err := m.ssmClient.SendCommand(ctx, input)\n   216→\tif err != nil {\n   217→\t\treturn \"\", fmt.Errorf(\"ssm send command: %w\", err)\n   218→\t}\n   219→\n   220→\tcmdID := aws.ToString(result.Command.CommandId)\n   221→\n   222→\t// Wait for command to complete\n   223→\twaiter := ssm.NewCommandExecutedWaiter(m.ssmClient)\n   224→\tgetOutput := &ssm.GetCommandInvocationInput{\n   225→\t\tCommandId:  aws.String(cmdID),\n   226→\t\tInstanceId: aws.String(instanceID),\n   227→\t}\n   228→\n   229→\tif err := waiter.Wait(ctx, getOutput, 5*time.Minute); err != nil {\n   230→\t\t// Fetch output even on failure to get stderr/diagnostics\n   231→\t\tif out, getErr := m.ssmClient.GetCommandInvocation(ctx, getOutput); getErr == nil {\n   232→\t\t\tstderr := strings.TrimSpace(aws.ToString(out.StandardErrorContent))\n   233→\t\t\tstdout := strings.TrimSpace(aws.ToString(out.StandardOutputContent))\n   234→\t\t\tstatus := string(out.Status)\n   235→\t\t\tdetail := stderr\n   236→\t\t\tif detail == \"\" {\n   237→\t\t\t\tdetail = stdout\n   238→\t\t\t}\n   239→\t\t\tif detail != \"\" {\n   240→\t\t\t\treturn \"\", fmt.Errorf(\"ssm command failed (status=%s): %s\", status, detail)\n   241→\t\t\t}\n   242→\t\t\treturn \"\", fmt.Errorf(\"ssm command failed (status=%s): %w\", status, err)\n   243→\t\t}\n   244→\t\treturn \"\", fmt.Errorf(\"wait for command: %w\", err)\n   245→\t}\n   246→\n   247→\tout, err := m.ssmClient.GetCommandInvocation(ctx, getOutput)\n   248→\tif err != nil {\n   249→\t\treturn \"\", fmt.Errorf(\"get command output: %w\", err)\n   250→\t}\n   251→\n   252→\treturn aws.ToString(out.StandardOutputContent), nil\n   253→}\n   254→\n   255→func isHexString(s string) bool {\n   256→\tif len(s) == 0 {\n   257→\t\treturn false\n   258→\t}\n   259→\tfor _, c := range s {\n   260→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n   261→\t\t\treturn false\n   262→\t\t}\n   263→\t}\n   264→\treturn true\n   265→}\n   266→\n   267→func shellEscape(s string) string {\n   268→\treturn \"'\" + strings.ReplaceAll(s, \"'\", \"'\\\"'\\\"'\") + \"'\"\n   269→}\n   270→"}]},"parent_tool_use_id":"toolu_01WjBDJU9gqMDSiqbdYofAYA","session_id":"2af19d51-84dc-4ce3-80b2-7d4b83aa4cbe","uuid":"ea152345-6b2b-40ad-9e51-742bbc476920"}
