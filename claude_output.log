{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E4nZfNHbRCrj7Wk2EFVsDq","type":"tool_result","content":"     1→package orchestrator\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"sync\"\n     7→\t\"time\"\n     8→\n     9→\t\"github.com/rs/zerolog/log\"\n    10→\n    11→\t\"github.com/backflow-labs/backflow/internal/config\"\n    12→\t\"github.com/backflow-labs/backflow/internal/models\"\n    13→\t\"github.com/backflow-labs/backflow/internal/notify\"\n    14→\t\"github.com/backflow-labs/backflow/internal/store\"\n    15→)\n    16→\n    17→type Orchestrator struct {\n    18→\tstore    store.Store\n    19→\tconfig   *config.Config\n    20→\tnotifier notify.Notifier\n    21→\tec2      *EC2Manager\n    22→\tdocker   *DockerManager\n    23→\tscaler   *Scaler\n    24→\tspot     *SpotHandler\n    25→\n    26→\tmu             sync.Mutex\n    27→\trunning        int\n    28→\tstopCh         chan struct{}\n    29→\tinspectFailures map[string]int // task ID -> consecutive inspect failure count\n    30→}\n    31→\n    32→func New(s store.Store, cfg *config.Config, notifier notify.Notifier) *Orchestrator {\n    33→\tec2 := NewEC2Manager(cfg)\n    34→\tdocker := NewDockerManager(cfg)\n    35→\treturn &Orchestrator{\n    36→\t\tstore:    s,\n    37→\t\tconfig:   cfg,\n    38→\t\tnotifier: notifier,\n    39→\t\tec2:      ec2,\n    40→\t\tdocker:   docker,\n    41→\t\tscaler:   NewScaler(s, ec2, docker, cfg),\n    42→\t\tspot:     NewSpotHandler(s, ec2),\n    43→\t\tstopCh:          make(chan struct{}),\n    44→\t\tinspectFailures: make(map[string]int),\n    45→\t}\n    46→}\n    47→\n    48→// Docker returns the DockerManager for use by the API logs endpoint.\n    49→func (o *Orchestrator) Docker() *DockerManager {\n    50→\treturn o.docker\n    51→}\n    52→\n    53→func (o *Orchestrator) Start(ctx context.Context) {\n    54→\tlog.Info().\n    55→\t\tStr(\"auth_mode\", string(o.config.AuthMode)).\n    56→\t\tInt(\"max_concurrent\", o.config.MaxConcurrent()).\n    57→\t\tDur(\"poll_interval\", o.config.PollInterval).\n    58→\t\tMsg(\"orchestrator started\")\n    59→\n    60→\tticker := time.NewTicker(o.config.PollInterval)\n    61→\tdefer ticker.Stop()\n    62→\n    63→\tfor {\n    64→\t\tselect {\n    65→\t\tcase <-ctx.Done():\n    66→\t\t\tlog.Info().Msg(\"orchestrator stopping\")\n    67→\t\t\treturn\n    68→\t\tcase <-o.stopCh:\n    69→\t\t\tlog.Info().Msg(\"orchestrator stopped\")\n    70→\t\t\treturn\n    71→\t\tcase <-ticker.C:\n    72→\t\t\to.tick(ctx)\n    73→\t\t}\n    74→\t}\n    75→}\n    76→\n    77→func (o *Orchestrator) Stop() {\n    78→\tclose(o.stopCh)\n    79→}\n    80→\n    81→func (o *Orchestrator) tick(ctx context.Context) {\n    82→\to.monitorRunning(ctx)\n    83→\to.dispatchPending(ctx)\n    84→\to.scaler.Evaluate(ctx)\n    85→}\n    86→\n    87→func (o *Orchestrator) dispatchPending(ctx context.Context) {\n    88→\to.mu.Lock()\n    89→\tmaxConcurrent := o.config.MaxConcurrent()\n    90→\tavailable := maxConcurrent - o.running\n    91→\to.mu.Unlock()\n    92→\n    93→\tif available <= 0 {\n    94→\t\treturn\n    95→\t}\n    96→\n    97→\tpending := models.TaskStatusPending\n    98→\ttasks, err := o.store.ListTasks(ctx, store.TaskFilter{\n    99→\t\tStatus: &pending,\n   100→\t\tLimit:  available,\n   101→\t})\n   102→\tif err != nil {\n   103→\t\tlog.Error().Err(err).Msg(\"failed to list pending tasks\")\n   104→\t\treturn\n   105→\t}\n   106→\n   107→\tfor _, task := range tasks {\n   108→\t\tif err := o.dispatch(ctx, task); err != nil {\n   109→\t\t\tlog.Error().Err(err).Str(\"task_id\", task.ID).Msg(\"failed to dispatch task\")\n   110→\t\t\ttask.Status = models.TaskStatusFailed\n   111→\t\t\ttask.Error = err.Error()\n   112→\t\t\to.store.UpdateTask(ctx, task)\n   113→\t\t\to.notifier.Notify(notify.Event{\n   114→\t\t\t\tType:      notify.EventTaskFailed,\n   115→\t\t\t\tTaskID:    task.ID,\n   116→\t\t\t\tRepoURL:   task.RepoURL,\n   117→\t\t\t\tPrompt:    task.Prompt,\n   118→\t\t\t\tMessage:   \"Failed to dispatch: \" + err.Error(),\n   119→\t\t\t\tTimestamp: time.Now().UTC(),\n   120→\t\t\t})\n   121→\t\t\tcontinue\n   122→\t\t}\n   123→\t}\n   124→}\n   125→\n   126→func (o *Orchestrator) dispatch(ctx context.Context, task *models.Task) error {\n   127→\t// Find an instance with capacity\n   128→\tinstance, err := o.findAvailableInstance(ctx)\n   129→\tif err != nil {\n   130→\t\t// Request scale-up and re-queue for next tick\n   131→\t\to.scaler.RequestScaleUp(ctx)\n   132→\t\treturn nil\n   133→\t}\n   134→\n   135→\t// Update task status to provisioning\n   136→\ttask.Status = models.TaskStatusProvisioning\n   137→\ttask.InstanceID = instance.InstanceID\n   138→\tif err := o.store.UpdateTask(ctx, task); err != nil {\n   139→\t\treturn err\n   140→\t}\n   141→\n   142→\t// Start container\n   143→\tcontainerID, err := o.docker.RunAgent(ctx, instance, task)\n   144→\tif err != nil {\n   145→\t\treturn err\n   146→\t}\n   147→\n   148→\tnow := time.Now().UTC()\n   149→\ttask.Status = models.TaskStatusRunning\n   150→\ttask.ContainerID = containerID\n   151→\ttask.StartedAt = &now\n   152→\tif err := o.store.UpdateTask(ctx, task); err != nil {\n   153→\t\treturn err\n   154→\t}\n   155→\n   156→\to.mu.Lock()\n   157→\to.running++\n   158→\to.mu.Unlock()\n   159→\n   160→\t// Update instance container count\n   161→\tinstance.RunningContainers++\n   162→\to.store.UpdateInstance(ctx, instance)\n   163→\n   164→\to.notifier.Notify(notify.Event{\n   165→\t\tType:      notify.EventTaskRunning,\n   166→\t\tTaskID:    task.ID,\n   167→\t\tRepoURL:   task.RepoURL,\n   168→\t\tPrompt:    task.Prompt,\n   169→\t\tTimestamp: now,\n   170→\t})\n   171→\n   172→\tlog.Info().Str(\"task_id\", task.ID).Str(\"container\", containerID).Str(\"instance\", instance.InstanceID).Msg(\"task dispatched\")\n   173→\treturn nil\n   174→}\n   175→\n   176→func (o *Orchestrator) findAvailableInstance(ctx context.Context) (*models.Instance, error) {\n   177→\trunning := models.InstanceStatusRunning\n   178→\tinstances, err := o.store.ListInstances(ctx, &running)\n   179→\tif err != nil {\n   180→\t\treturn nil, err\n   181→\t}\n   182→\n   183→\tfor _, inst := range instances {\n   184→\t\tif inst.RunningContainers < inst.MaxContainers {\n   185→\t\t\treturn inst, nil\n   186→\t\t}\n   187→\t}\n   188→\n   189→\treturn nil, errNoCapacity\n   190→}\n   191→\n   192→func (o *Orchestrator) monitorRunning(ctx context.Context) {\n   193→\trunning := models.TaskStatusRunning\n   194→\ttasks, err := o.store.ListTasks(ctx, store.TaskFilter{Status: &running})\n   195→\tif err != nil {\n   196→\t\tlog.Error().Err(err).Msg(\"failed to list running tasks\")\n   197→\t\treturn\n   198→\t}\n   199→\n   200→\tfor _, task := range tasks {\n   201→\t\t// Check timeout\n   202→\t\tif task.StartedAt != nil && task.MaxRuntimeMin > 0 {\n   203→\t\t\tdeadline := task.StartedAt.Add(time.Duration(task.MaxRuntimeMin) * time.Minute)\n   204→\t\t\tif time.Now().UTC().After(deadline) {\n   205→\t\t\t\tlog.Warn().Str(\"task_id\", task.ID).Msg(\"task exceeded max runtime, killing\")\n   206→\t\t\t\to.killTask(ctx, task, \"exceeded max runtime\")\n   207→\t\t\t\tcontinue\n   208→\t\t\t}\n   209→\t\t}\n   210→\n   211→\t\t// Check container status\n   212→\t\tstatus, err := o.docker.InspectContainer(ctx, task.InstanceID, task.ContainerID)\n   213→\t\tif err != nil {\n   214→\t\t\to.inspectFailures[task.ID]++\n   215→\t\t\tcount := o.inspectFailures[task.ID]\n   216→\t\t\tlog.Warn().Err(err).Str(\"task_id\", task.ID).Int(\"consecutive_failures\", count).Msg(\"failed to inspect container\")\n   217→\t\t\tif count >= 3 {\n   218→\t\t\t\tdelete(o.inspectFailures, task.ID)\n   219→\t\t\t\to.killTask(ctx, task, fmt.Sprintf(\"container unreachable after %d inspect failures: %v\", count, err))\n   220→\t\t\t}\n   221→\t\t\tcontinue\n   222→\t\t}\n   223→\n   224→\t\tdelete(o.inspectFailures, task.ID)\n   225→\n   226→\t\tif status.Done {\n   227→\t\t\to.handleCompletion(ctx, task, status)\n   228→\t\t}\n   229→\t}\n   230→}\n   231→\n   232→func (o *Orchestrator) handleCompletion(ctx context.Context, task *models.Task, status ContainerStatus) {\n   233→\tnow := time.Now().UTC()\n   234→\ttask.CompletedAt = &now\n   235→\n   236→\tif status.ExitCode == 0 {\n   237→\t\ttask.Status = models.TaskStatusCompleted\n   238→\t\to.notifier.Notify(notify.Event{\n   239→\t\t\tType:         notify.EventTaskCompleted,\n   240→\t\t\tTaskID:       task.ID,\n   241→\t\t\tRepoURL:      task.RepoURL,\n   242→\t\t\tPrompt:       task.Prompt,\n   243→\t\t\tAgentLogTail: status.LogTail,\n   244→\t\t\tTimestamp:    now,\n   245→\t\t})\n   246→\t} else if status.NeedsInput {\n   247→\t\ttask.Status = models.TaskStatusFailed\n   248→\t\ttask.Error = \"agent needs input\"\n   249→\t\to.notifier.Notify(notify.Event{\n   250→\t\t\tType:         notify.EventTaskNeedsInput,\n   251→\t\t\tTaskID:       task.ID,\n   252→\t\t\tRepoURL:      task.RepoURL,\n   253→\t\t\tPrompt:       task.Prompt,\n   254→\t\t\tMessage:      status.Question,\n   255→\t\t\tAgentLogTail: status.LogTail,\n   256→\t\t\tTimestamp:    now,\n   257→\t\t})\n   258→\t} else {\n   259→\t\ttask.Status = models.TaskStatusFailed\n   260→\t\ttask.Error = status.Error\n   261→\t\to.notifier.Notify(notify.Event{\n   262→\t\t\tType:         notify.EventTaskFailed,\n   263→\t\t\tTaskID:       task.ID,\n   264→\t\t\tRepoURL:      task.RepoURL,\n   265→\t\t\tPrompt:       task.Prompt,\n   266→\t\t\tMessage:      status.Error,\n   267→\t\t\tAgentLogTail: status.LogTail,\n   268→\t\t\tTimestamp:    now,\n   269→\t\t})\n   270→\t}\n   271→\n   272→\to.store.UpdateTask(ctx, task)\n   273→\n   274→\to.mu.Lock()\n   275→\to.running--\n   276→\to.mu.Unlock()\n   277→\n   278→\t// Decrement instance container count\n   279→\tif task.InstanceID != \"\" {\n   280→\t\tif inst, err := o.store.GetInstance(ctx, task.InstanceID); err == nil && inst != nil {\n   281→\t\t\tinst.RunningContainers--\n   282→\t\t\tif inst.RunningContainers < 0 {\n   283→\t\t\t\tinst.RunningContainers = 0\n   284→\t\t\t}\n   285→\t\t\to.store.UpdateInstance(ctx, inst)\n   286→\t\t}\n   287→\t}\n   288→\n   289→\tlog.Info().Str(\"task_id\", task.ID).Str(\"status\", string(task.Status)).Msg(\"task completed\")\n   290→}\n   291→\n   292→func (o *Orchestrator) killTask(ctx context.Context, task *models.Task, reason string) {\n   293→\tif task.ContainerID != \"\" {\n   294→\t\to.docker.StopContainer(ctx, task.InstanceID, task.ContainerID)\n   295→\t}\n   296→\n   297→\tnow := time.Now().UTC()\n   298→\ttask.Status = models.TaskStatusFailed\n   299→\ttask.Error = reason\n   300→\ttask.CompletedAt = &now\n   301→\to.store.UpdateTask(ctx, task)\n   302→\n   303→\to.mu.Lock()\n   304→\to.running--\n   305→\to.mu.Unlock()\n   306→\n   307→\tif task.InstanceID != \"\" {\n   308→\t\tif inst, err := o.store.GetInstance(ctx, task.InstanceID); err == nil && inst != nil {\n   309→\t\t\tinst.RunningContainers--\n   310→\t\t\tif inst.RunningContainers < 0 {\n   311→\t\t\t\tinst.RunningContainers = 0\n   312→\t\t\t}\n   313→\t\t\to.store.UpdateInstance(ctx, inst)\n   314→\t\t}\n   315→\t}\n   316→\n   317→\to.notifier.Notify(notify.Event{\n   318→\t\tType:      notify.EventTaskFailed,\n   319→\t\tTaskID:    task.ID,\n   320→\t\tRepoURL:   task.RepoURL,\n   321→\t\tPrompt:    task.Prompt,\n   322→\t\tMessage:   reason,\n   323→\t\tTimestamp: now,\n   324→\t})\n   325→}\n   326→\n   327→var errNoCapacity = fmt.Errorf(\"no instance capacity available\")\n   328→"}]},"parent_tool_use_id":"toolu_01WjBDJU9gqMDSiqbdYofAYA","session_id":"2af19d51-84dc-4ce3-80b2-7d4b83aa4cbe","uuid":"38dbfc09-6657-42be-b1af-9ee86b2cd13a"}
