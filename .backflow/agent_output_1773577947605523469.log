{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SV7Wx6THgKyVZsYZekPkKF","type":"tool_result","content":"     1→package orchestrator\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"time\"\n     6→\n     7→\t\"github.com/rs/zerolog/log\"\n     8→\n     9→\t\"github.com/backflow-labs/backflow/internal/models\"\n    10→\t\"github.com/backflow-labs/backflow/internal/store\"\n    11→)\n    12→\n    13→type SpotHandler struct {\n    14→\tstore store.Store\n    15→\tec2   *EC2Manager\n    16→}\n    17→\n    18→func NewSpotHandler(s store.Store, ec2 *EC2Manager) *SpotHandler {\n    19→\treturn &SpotHandler{store: s, ec2: ec2}\n    20→}\n    21→\n    22→// CheckInterruptions polls running instances for spot termination notices.\n    23→// Called periodically by the orchestrator.\n    24→func (h *SpotHandler) CheckInterruptions(ctx context.Context) {\n    25→\trunning := models.InstanceStatusRunning\n    26→\tinstances, err := h.store.ListInstances(ctx, &running)\n    27→\tif err != nil {\n    28→\t\tlog.Error().Err(err).Msg(\"spot: failed to list running instances\")\n    29→\t\treturn\n    30→\t}\n    31→\n    32→\tfor _, inst := range instances {\n    33→\t\tinterrupted, err := h.isInterrupted(ctx, inst.InstanceID)\n    34→\t\tif err != nil {\n    35→\t\t\tlog.Warn().Err(err).Str(\"instance\", inst.InstanceID).Msg(\"spot: failed to check interruption\")\n    36→\t\t\tcontinue\n    37→\t\t}\n    38→\t\tif interrupted {\n    39→\t\t\tlog.Warn().Str(\"instance\", inst.InstanceID).Msg(\"spot: termination notice detected\")\n    40→\t\t\th.handleInterruption(ctx, inst)\n    41→\t\t}\n    42→\t}\n    43→}\n    44→\n    45→func (h *SpotHandler) isInterrupted(ctx context.Context, instanceID string) (bool, error) {\n    46→\tinst, err := h.ec2.DescribeInstance(ctx, instanceID)\n    47→\tif err != nil {\n    48→\t\treturn false, err\n    49→\t}\n    50→\n    51→\t// Check if the instance state indicates it's being terminated\n    52→\tif inst.State != nil {\n    53→\t\tstate := inst.State.Name\n    54→\t\tif state == \"shutting-down\" || state == \"terminated\" {\n    55→\t\t\treturn true, nil\n    56→\t\t}\n    57→\t}\n    58→\n    59→\treturn false, nil\n    60→}\n    61→\n    62→func (h *SpotHandler) handleInterruption(ctx context.Context, inst *models.Instance) {\n    63→\t// Mark instance as draining\n    64→\tinst.Status = models.InstanceStatusDraining\n    65→\th.store.UpdateInstance(ctx, inst)\n    66→\n    67→\t// Find all running tasks on this instance and re-queue them\n    68→\trunning := models.TaskStatusRunning\n    69→\ttasks, err := h.store.ListTasks(ctx, store.TaskFilter{Status: &running})\n    70→\tif err != nil {\n    71→\t\tlog.Error().Err(err).Msg(\"spot: failed to list running tasks for re-queue\")\n    72→\t\treturn\n    73→\t}\n    74→\n    75→\tfor _, task := range tasks {\n    76→\t\tif task.InstanceID != inst.InstanceID {\n    77→\t\t\tcontinue\n    78→\t\t}\n    79→\n    80→\t\tlog.Info().Str(\"task_id\", task.ID).Msg(\"spot: re-queuing interrupted task\")"}]},"parent_tool_use_id":"toolu_015W9rgrmaZu78aSJETJC1Gh","session_id":"13b20e59-6472-468f-b07a-3e492441f548","uuid":"9c698940-d0d9-4e9a-8140-71db8bfffb6a"}
