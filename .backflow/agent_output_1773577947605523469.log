{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AYiF3x4vGoyTB8UKp588MH","type":"tool_result","content":"     1→package config\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"os\"\n     6→\t\"strconv\"\n     7→\t\"strings\"\n     8→\t\"time\"\n     9→)\n    10→\n    11→type Mode string\n    12→\n    13→const (\n    14→\tModeEC2   Mode = \"ec2\"\n    15→\tModeLocal Mode = \"local\"\n    16→)\n    17→\n    18→type AuthMode string\n    19→\n    20→const (\n    21→\tAuthModeAPIKey          AuthMode = \"api_key\"\n    22→\tAuthModeMaxSubscription AuthMode = \"max_subscription\"\n    23→)\n    24→\n    25→type Config struct {\n    26→\t// Mode\n    27→\tMode Mode\n    28→\n    29→\t// Server\n    30→\tListenAddr string\n    31→\n    32→\t// Auth\n    33→\tAuthMode             AuthMode\n    34→\tAnthropicAPIKey      string\n    35→\tClaudeCredentialsPath string\n    36→\n    37→\t// AWS\n    38→\tAWSRegion        string\n    39→\tInstanceType     string\n    40→\tAMI              string\n    41→\tMaxInstances     int\n    42→\tContainersPerInst int\n    43→\tLaunchTemplateID string\n    44→\n    45→\t// Agent defaults\n    46→\tDefaultModel      string\n    47→\tDefaultEffort     string\n    48→\tDefaultMaxBudget  float64\n    49→\tDefaultMaxRuntime time.Duration\n    50→\tDefaultMaxTurns   int\n    51→\n    52→\t// GitHub\n    53→\tGitHubToken string\n    54→\n    55→\t// Webhooks\n    56→\tWebhookURL    string\n    57→\tWebhookEvents []string\n    58→\n    59→\t// Database\n    60→\tDBPath string\n    61→\n    62→\t// Orchestrator\n    63→\tPollInterval time.Duration\n    64→}\n    65→\n    66→func (c *Config) MaxConcurrent() int {\n    67→\tif c.AuthMode == AuthModeMaxSubscription {\n    68→\t\treturn 1\n    69→\t}\n    70→\tif c.Mode == ModeLocal {\n    71→\t\treturn c.ContainersPerInst\n    72→\t}\n    73→\treturn c.MaxInstances * c.ContainersPerInst\n    74→}\n    75→\n    76→func Load() (*Config, error) {\n    77→\tc := &Config{\n    78→\t\tMode:              Mode(envOr(\"BACKFLOW_MODE\", string(ModeEC2))),\n    79→\t\tListenAddr:        envOr(\"BACKFLOW_LISTEN_ADDR\", \":8080\"),\n    80→\t\tAuthMode:          AuthMode(envOr(\"BACKFLOW_AUTH_MODE\", string(AuthModeAPIKey))),\n    81→\t\tAnthropicAPIKey:   os.Getenv(\"ANTHROPIC_API_KEY\"),\n    82→\t\tClaudeCredentialsPath: envOr(\"CLAUDE_CREDENTIALS_PATH\", \"\"),\n    83→\t\tAWSRegion:         envOr(\"AWS_REGION\", \"us-east-1\"),\n    84→\t\tInstanceType:      envOr(\"BACKFLOW_INSTANCE_TYPE\", \"t4g.medium\"),\n    85→\t\tAMI:               os.Getenv(\"BACKFLOW_AMI\"),\n    86→\t\tMaxInstances:      envInt(\"BACKFLOW_MAX_INSTANCES\", 5),\n    87→\t\tContainersPerInst: envInt(\"BACKFLOW_CONTAINERS_PER_INSTANCE\", 4),\n    88→\t\tLaunchTemplateID:  os.Getenv(\"BACKFLOW_LAUNCH_TEMPLATE_ID\"),\n    89→\t\tDefaultModel:      envOr(\"BACKFLOW_DEFAULT_MODEL\", \"claude-sonnet-4-6\"),\n    90→\t\tDefaultEffort:     envOr(\"BACKFLOW_DEFAULT_EFFORT\", \"high\"),\n    91→\t\tDefaultMaxBudget:  envFloat(\"BACKFLOW_DEFAULT_MAX_BUDGET\", 10.0),\n    92→\t\tDefaultMaxRuntime: time.Duration(envInt(\"BACKFLOW_DEFAULT_MAX_RUNTIME_MIN\", 30)) * time.Minute,\n    93→\t\tDefaultMaxTurns:   envInt(\"BACKFLOW_DEFAULT_MAX_TURNS\", 200),\n    94→\t\tGitHubToken:       os.Getenv(\"GITHUB_TOKEN\"),\n    95→\t\tWebhookURL:        os.Getenv(\"BACKFLOW_WEBHOOK_URL\"),\n    96→\t\tDBPath:            envOr(\"BACKFLOW_DB_PATH\", \"backflow.db\"),\n    97→\t\tPollInterval:      time.Duration(envInt(\"BACKFLOW_POLL_INTERVAL_SEC\", 5)) * time.Second,\n    98→\t}\n    99→\n   100→\tif events := os.Getenv(\"BACKFLOW_WEBHOOK_EVENTS\"); events != \"\" {\n   101→\t\tc.WebhookEvents = strings.Split(events, \",\")\n   102→\t\tfor i := range c.WebhookEvents {\n   103→\t\t\tc.WebhookEvents[i] = strings.TrimSpace(c.WebhookEvents[i])\n   104→\t\t}\n   105→\t}\n   106→\n   107→\tif c.Mode != ModeEC2 && c.Mode != ModeLocal {\n   108→\t\treturn nil, fmt.Errorf(\"invalid BACKFLOW_MODE: %q (must be %q or %q)\", c.Mode, ModeEC2, ModeLocal)\n   109→\t}\n   110→\n   111→\tif c.AuthMode != AuthModeAPIKey && c.AuthMode != AuthModeMaxSubscription {\n   112→\t\treturn nil, fmt.Errorf(\"invalid BACKFLOW_AUTH_MODE: %q (must be %q or %q)\", c.AuthMode, AuthModeAPIKey, AuthModeMaxSubscription)\n   113→\t}\n   114→\n   115→\tif c.AuthMode == AuthModeAPIKey && c.AnthropicAPIKey == \"\" {\n   116→\t\treturn nil, fmt.Errorf(\"ANTHROPIC_API_KEY is required when BACKFLOW_AUTH_MODE=api_key\")\n   117→\t}\n   118→\n   119→\treturn c, nil\n   120→}\n   121→\n   122→func envOr(key, fallback string) string {\n   123→\tif v := os.Getenv(key); v != \"\" {\n   124→\t\treturn v\n   125→\t}\n   126→\treturn fallback\n   127→}\n   128→\n   129→func envInt(key string, fallback int) int {\n   130→\tif v := os.Getenv(key); v != \"\" {\n   131→\t\tif n, err := strconv.Atoi(v); err == nil {\n   132→\t\t\treturn n\n   133→\t\t}\n   134→\t}\n   135→\treturn fallback\n   136→}\n   137→\n   138→func envFloat(key string, fallback float64) float64 {\n   139→\tif v := os.Getenv(key); v != \"\" {\n   140→\t\tif f, err := strconv.ParseFloat(v, 64); err == nil {\n   141→\t\t\treturn f\n   142→\t\t}\n   143→\t}\n   144→\treturn fallback\n   145→}\n   146→"}]},"parent_tool_use_id":"toolu_015W9rgrmaZu78aSJETJC1Gh","session_id":"13b20e59-6472-468f-b07a-3e492441f548","uuid":"d5ee825f-4e97-4b9d-983c-0ef0fe401746"}
