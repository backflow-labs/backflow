{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012GsXxfkwVF3LGFvyCJ354G","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→set -euo pipefail\n     3→\n     4→# --- Configuration from environment ---\n     5→REPO_URL=\"${REPO_URL:?REPO_URL is required}\"\n     6→PROMPT=\"${PROMPT:?PROMPT is required}\"\n     7→AUTH_MODE=\"${AUTH_MODE:-api_key}\"\n     8→BRANCH=\"${BRANCH:-backflow/${TASK_ID:-$(date +%s)}}\"\n     9→TARGET_BRANCH=\"${TARGET_BRANCH:-main}\"\n    10→MODEL=\"${MODEL:-claude-sonnet-4-6}\"\n    11→EFFORT=\"${EFFORT:-high}\"\n    12→MAX_BUDGET_USD=\"${MAX_BUDGET_USD:-10}\"\n    13→MAX_TURNS=\"${MAX_TURNS:-200}\"\n    14→CREATE_PR=\"${CREATE_PR:-false}\"\n    15→PR_TITLE=\"${PR_TITLE:-}\"\n    16→PR_BODY=\"${PR_BODY:-}\"\n    17→CLAUDE_MD=\"${CLAUDE_MD:-}\"\n    18→TASK_CONTEXT=\"${TASK_CONTEXT:-}\"\n    19→SELF_REVIEW=\"${SELF_REVIEW:-false}\"\n    20→MAX_RETRIES=\"${MAX_RETRIES:-3}\"\n    21→\n    22→WORKSPACE=\"/home/agent/workspace\"\n    23→STATUS_FILE=\"${WORKSPACE}/status.json\"\n    24→\n    25→write_status() {\n    26→    local exit_code=\"$1\"\n    27→    local complete=\"$2\"\n    28→    local needs_input=\"$3\"\n    29→    local question=\"$4\"\n    30→    local error_msg=\"$5\"\n    31→    local pr_url=\"${6:-}\"\n    32→\n    33→    cat > \"$STATUS_FILE\" <<STATUSEOF\n    34→{\n    35→  \"exit_code\": ${exit_code},\n    36→  \"complete\": ${complete},\n    37→  \"needs_input\": ${needs_input},\n    38→  \"question\": $(echo \"$question\" | jq -R .),\n    39→  \"error\": $(echo \"$error_msg\" | jq -R .),\n    40→  \"pr_url\": $(echo \"$pr_url\" | jq -R .)\n    41→}\n    42→STATUSEOF\n    43→}\n    44→\n    45→# --- Clone ---\n    46→echo \"==> Cloning ${REPO_URL} (depth 50)...\"\n    47→git clone --depth 50 \"$REPO_URL\" \"$WORKSPACE\"\n    48→cd \"$WORKSPACE\"\n    49→\n    50→# Checkout target branch if it's not the default\n    51→git fetch origin \"$TARGET_BRANCH\" 2>/dev/null || true\n    52→git checkout \"$TARGET_BRANCH\" 2>/dev/null || true\n    53→\n    54→# Create working branch\n    55→git checkout -b \"$BRANCH\"\n    56→echo \"==> Working on branch: ${BRANCH}\"\n    57→\n    58→# --- Inject CLAUDE.md ---\n    59→if [ -n \"$CLAUDE_MD\" ]; then\n    60→    echo \"==> Injecting CLAUDE.md content...\"\n    61→    if [ -f CLAUDE.md ]; then\n    62→        echo \"\" >> CLAUDE.md\n    63→        echo \"$CLAUDE_MD\" >> CLAUDE.md\n    64→    else\n    65→        echo \"$CLAUDE_MD\" > CLAUDE.md\n    66→    fi\n    67→fi\n    68→\n    69→# --- Build prompt ---\n    70→FULL_PROMPT=\"$PROMPT\"\n    71→if [ -n \"$TASK_CONTEXT\" ]; then\n    72→    FULL_PROMPT=\"Context: ${TASK_CONTEXT}\n    73→\n    74→${FULL_PROMPT}\"\n    75→fi\n    76→\n    77→# Always instruct the agent to commit and push\n    78→GIT_INSTRUCTIONS=\"\n    79→\n    80→After completing the coding task, you MUST do the following git operations:\n    81→\n    82→1. Stage and commit all your changes with a descriptive commit message.\n    83→2. Push the branch '${BRANCH}' to origin.\"\n    84→\n    85→# Append PR creation instructions if requested\n    86→if [ \"$CREATE_PR\" = \"true\" ]; then\n    87→    GIT_INSTRUCTIONS=\"${GIT_INSTRUCTIONS}\n    88→3. Create a pull request using the gh CLI:\n    89→   - Base branch: ${TARGET_BRANCH}\n    90→   - Head branch: ${BRANCH}\"\n    91→\n    92→    if [ -n \"$PR_TITLE\" ]; then\n    93→        GIT_INSTRUCTIONS=\"${GIT_INSTRUCTIONS}\n    94→   - Title: ${PR_TITLE}\"\n    95→    else\n    96→        GIT_INSTRUCTIONS=\"${GIT_INSTRUCTIONS}\n    97→   - Title: [backflow] <generate a concise, descriptive title based on the changes you made>\"\n    98→    fi\n    99→\n   100→    if [ -n \"$PR_BODY\" ]; then\n   101→        GIT_INSTRUCTIONS=\"${GIT_INSTRUCTIONS}\n   102→   - Body: ${PR_BODY}\"\n   103→    else\n   104→        GIT_INSTRUCTIONS=\"${GIT_INSTRUCTIONS}\n   105→   - Write a clear PR description summarizing what you changed and why.\"\n   106→    fi\n   107→\n   108→    GIT_INSTRUCTIONS=\"${GIT_INSTRUCTIONS}\n   109→\n   110→Do NOT skip the PR creation step. The PR must exist on GitHub when you are done.\"\n   111→fi\n   112→\n   113→FULL_PROMPT=\"${FULL_PROMPT}${GIT_INSTRUCTIONS}\"\n   114→\n   115→# --- GitHub auth ---\n   116→if [ -n \"${GITHUB_TOKEN:-}\" ]; then\n   117→    echo \"$GITHUB_TOKEN\" | gh auth login --with-token 2>/dev/null || true\n   118→    gh auth setup-git 2>/dev/null || true\n   119→fi\n   120→\n   121→# --- Auth mode setup ---\n   122→echo \"==> Auth mode: ${AUTH_MODE}\"\n   123→echo \"==> Model: ${MODEL}, effort: ${EFFORT}\"\n   124→if [ \"$AUTH_MODE\" = \"api_key\" ]; then\n   125→    if [ -z \"${ANTHROPIC_API_KEY:-}\" ]; then\n   126→        echo \"ERROR: ANTHROPIC_API_KEY is required in api_key mode\" >&2\n   127→        exit 1\n   128→    fi\n   129→elif [ \"$AUTH_MODE\" = \"max_subscription\" ]; then\n   130→    if [ ! -d \"$HOME/.claude\" ]; then\n   131→        echo \"ERROR: ~/.claude credentials not mounted (required for max_subscription mode)\" >&2\n   132→        exit 1\n   133→    fi\n   134→    echo \"==> Using Max subscription credentials from ~/.claude\"\n   135→else\n   136→    echo \"ERROR: Unknown AUTH_MODE: ${AUTH_MODE}\" >&2\n   137→    exit 1\n   138→fi\n   139→\n   140→# --- Build claude command args ---\n   141→CLAUDE_ARGS=(\n   142→    -p \"$FULL_PROMPT\"\n   143→    --dangerously-skip-permissions\n   144→    --model \"$MODEL\"\n   145→    --effort \"$EFFORT\"\n   146→    --max-turns \"$MAX_TURNS\"\n   147→    --output-format stream-json\n   148→    --verbose\n   149→)\n   150→\n   151→# --max-budget-usd only applies to API key mode (billed per token)\n   152→if [ \"$AUTH_MODE\" = \"api_key\" ]; then\n   153→    CLAUDE_ARGS+=(--max-budget-usd \"$MAX_BUDGET_USD\")\n   154→fi\n   155→\n   156→# --- Run Claude Code with retries ---\n   157→ATTEMPT=0\n   158→CLAUDE_EXIT=1\n   159→CLAUDE_OUTPUT=\"\"\n   160→\n   161→while [ $ATTEMPT -lt \"$MAX_RETRIES\" ]; do\n   162→    ATTEMPT=$((ATTEMPT + 1))\n   163→    echo \"==> Running Claude Code (attempt ${ATTEMPT}/${MAX_RETRIES})...\"\n   164→\n   165→    CLAUDE_LOG=\"${WORKSPACE}/claude_output.log\"\n   166→    set +e\n   167→    claude \"${CLAUDE_ARGS[@]}\" 2>&1 | tee \"$CLAUDE_LOG\"\n   168→    CLAUDE_EXIT=${PIPESTATUS[0]}\n   169→    CLAUDE_OUTPUT=$(cat \"$CLAUDE_LOG\")\n   170→    set -e\n   171→\n   172→    if [ $CLAUDE_EXIT -eq 0 ]; then\n   173→        echo \"==> Claude Code completed successfully\"\n   174→        break\n   175→    fi\n   176→\n   177→    echo \"==> Claude Code exited with code ${CLAUDE_EXIT} (attempt ${ATTEMPT})\"\n   178→    echo \"$CLAUDE_OUTPUT\" | tail -30\n   179→\n   180→    if [ $ATTEMPT -lt \"$MAX_RETRIES\" ]; then\n   181→        # Add error context to prompt for retry\n   182→        ERROR_TAIL=$(echo \"$CLAUDE_OUTPUT\" | tail -20)\n   183→        FULL_PROMPT=\"Previous attempt failed with error:\n   184→${ERROR_TAIL}\n   185→\n   186→Please try again:\n   187→${PROMPT}${GIT_INSTRUCTIONS}\"\n   188→        # Rebuild args with updated prompt\n   189→        CLAUDE_ARGS=( -p \"$FULL_PROMPT\" --dangerously-skip-permissions --model \"$MODEL\" --effort \"$EFFORT\" --max-turns \"$MAX_TURNS\" --output-format stream-json --verbose )\n   190→        if [ \"$AUTH_MODE\" = \"api_key\" ]; then\n   191→            CLAUDE_ARGS+=(--max-budget-usd \"$MAX_BUDGET_USD\")\n   192→        fi\n   193→    fi\n   194→done\n   195→\n   196→# --- Parse result from stream-json output ---\n   197→# stream-json emits one JSON object per line; the final \"result\" message has the outcome.\n   198→RESULT_LINE=$(echo \"$CLAUDE_OUTPUT\" | grep '\"type\":\"result\"' | tail -1)\n   199→NEEDS_INPUT=false\n   200→QUESTION=\"\""}]},"parent_tool_use_id":"toolu_015W9rgrmaZu78aSJETJC1Gh","session_id":"13b20e59-6472-468f-b07a-3e492441f548","uuid":"4df74052-6953-4ce0-98a3-1ed536763fa5"}
