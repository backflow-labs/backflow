v %s:/home/agent/.claude:ro\", m.config.ClaudeCredentialsPath)\n    99→\t}\n   100→\n   101→\tcmd := fmt.Sprintf(\n   102→\t\t\"docker run -d --cpus=1 --memory=3g %s %s backflow-agent\",\n   103→\t\tvolumeFlags,\n   104→\t\tstrings.Join(envFlags, \" \"),\n   105→\t)\n   106→\n   107→\toutput, err := m.runCommand(ctx, instance.InstanceID, cmd)\n   108→\tif err != nil {\n   109→\t\treturn \"\", fmt.Errorf(\"run container: %w\", err)\n   110→\t}\n   111→\n   112→\tcontainerID := strings.TrimSpace(output)\n   113→\tif containerID == \"\" {\n   114→\t\treturn \"\", fmt.Errorf(\"empty container ID returned\")\n   115→\t}\n   116→\n   117→\t// Docker container IDs are 64-char hex strings; reject anything else\n   118→\t// (e.g. error messages captured via 2>&1)\n   119→\tif !isHexString(containerID) {\n   120→\t\treturn \"\", fmt.Errorf(\"docker run failed: %s\", containerID)\n   121→\t}\n   122→\n   123→\tlog.Debug().Str(\"container\", containerID[:12]).Str(\"instance\", instance.InstanceID).Msg(\"started agent container\")\n   124→\treturn containerID, nil\n   125→}\n   126→\n   127→func (m *DockerManager) InspectContainer(ctx context.Context, instanceID, containerID string) (ContainerStatus, error) {\n   128→\tcmd := fmt.Sprintf(\"docker inspect --format '{{.State.Status}} {{.State.ExitCode}}' %s 2>/dev/null && docker logs --tail 20 %s 2>&1\", containerID, containerID)\n   129→\toutput, err := m.runCommand(ctx, instanceID, cmd)\n   130→\tif err != nil {\n   131→\t\treturn ContainerStatus{}, err\n   132→\t}\n   133→\n   134→\tlines := strings.SplitN(output, \"\\n\", 2)\n   135→\tif len(lines) == 0 {\n   136→\t\treturn ContainerStatus{}, fmt.Errorf(\"empty inspect output\")\n   137→\t}\n   138→\n   139→\tparts := strings.Fields(lines[0])\n   140→\tif len(parts) < 2 {\n   141→\t\treturn ContainerStatus{}, fmt.Errorf(\"unexpected inspect format: %s\", lines[0])\n   142→\t}\n   143→\n   144→\tstatus := ContainerStatus{}\n   145→\tif len(lines) > 1 {\n   146→\t\tstatus.LogTai