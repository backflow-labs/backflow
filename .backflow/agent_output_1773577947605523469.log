/`local`)\n- **notify/** — `Notifier` interface, `WebhookNotifier` (HTTP POST, 3 retries, event filtering), `NoopNotifier`"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":875,"cache_read_input_tokens":27202,"cache_creation":{"ephemeral_5m_input_tokens":875,"ephemeral_1h_input_tokens":0},"output_tokens":18,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"13b20e59-6472-468f-b07a-3e492441f548","uuid":"d8d1f278-c981-4204-b375-b6703bd2bda7"}
