{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ezd3rehhRjjJ4xR1FsszHa","type":"tool_result","content":"   200→QUESTION=\"\"\n   201→\n   202→if [ -n \"$RESULT_LINE\" ]; then\n   203→    RESULT_TEXT=$(echo \"$RESULT_LINE\" | jq -r '.result // empty' 2>/dev/null)\n   204→    if echo \"$RESULT_TEXT\" | grep -qi 'question\\|decision\\|should I\\|which approach\\|do you want\\|please clarify'; then\n   205→        NEEDS_INPUT=true\n   206→        QUESTION=$(echo \"$RESULT_TEXT\" | tail -5)\n   207→    fi\n   208→\n   209→    # If claude ran out of turns without completing\n   210→    IS_ERROR=$(echo \"$RESULT_LINE\" | jq -r '.is_error // false' 2>/dev/null)\n   211→    if [ \"$IS_ERROR\" = \"true\" ]; then\n   212→        ERROR_TYPE=$(echo \"$RESULT_LINE\" | jq -r '.error_type // empty' 2>/dev/null)\n   213→        if [ \"$ERROR_TYPE\" = \"max_turns\" ]; then\n   214→            NEEDS_INPUT=true\n   215→            QUESTION=\"Agent ran out of turns (${MAX_TURNS}) without completing the task\"\n   216→        fi\n   217→    fi\n   218→fi\n   219→\n   220→# --- Determine completion status ---\n   221→COMPLETE=false\n   222→if [ $CLAUDE_EXIT -eq 0 ]; then\n   223→    COMPLETE=true\n   224→fi\n   225→ERROR_MSG=\"\"\n   226→if [ $CLAUDE_EXIT -ne 0 ]; then\n   227→    ERROR_MSG=$(echo \"$CLAUDE_OUTPUT\" | tail -5)\n   228→fi\n   229→\n   230→# --- Extract PR URL ---\n   231→PR_URL=\"\"\n   232→if [ \"$CREATE_PR\" = \"true\" ] && [ \"$COMPLETE\" = \"true\" ]; then\n   233→    echo \"==> Looking up PR URL...\"\n   234→    PR_URL=$(gh pr list --head \"$BRANCH\" --base \"$TARGET_BRANCH\" --json url --jq '.[0].url' 2>/dev/null || true)\n   235→    if [ -n \"$PR_URL\" ]; then\n   236→        echo \"==> PR found: ${PR_URL}\"\n   237→    else\n   238→        echo \"==> No PR found for branch ${BRANCH}\"\n   239→    fi\n   240→fi\n   241→\n   242→# --- Self-review phase ---\n   243→if [ \"$SELF_REVIEW\" = \"true\" ] && [ -n \"$PR_URL\" ]; then\n   244→    echo \"==> Starting self-review phase...\"\n   245→\n   246→    # Cap review budget at 20% of coding budget (minimum $2)\n   247→    REVIEW_BUDGET=$(echo \"$MAX_BUDGET_USD\" | awk '{b = $1 * 0.2; print (b < 2) ? 2 : b}')\n   248→\n   249→    REVIEW_PROMPT=\"You are reviewing a pull request that you (a different instance) just created.\n   250→\n   251→PR URL: ${PR_URL}\n   252→\n   253→Review the PR by:\n   254→1. Read the full diff with: gh pr diff ${PR_URL}\n   255→2. Look at the PR description with: gh pr view ${PR_URL}\n   256→\n   257→Focus on:\n   258→- Bugs and logic errors\n   259→- Security issues\n   260→- Missing error handling that could cause failures\n   261→- Correctness of the implementation vs the PR description\n   262→\n   263→Do NOT comment on:\n   264→- Code style or formatting\n   265→- Minor naming preferences\n   266→- Things that are working correctly\n   267→\n   268→Respond with your review findings. If everything looks good, say so. If there are real issues, explain what needs fixing.\"\n   269→\n   270→    REVIEW_ARGS=(\n   271→        -p \"$REVIEW_PROMPT\"\n   272→        --dangerously-skip-permissions\n   273→        --model \"$MODEL\"\n   274→        --max-turns 10\n   275→        --output-format stream-json\n   276→        --verbose\n   277→    )\n   278→    if [ \"$AUTH_MODE\" = \"api_key\" ]; then\n   279→        REVIEW_ARGS+=(--max-budget-usd \"$REVIEW_BUDGET\")\n   280→    fi\n   281→\n   282→    REVIEW_LOG=\"${WORKSPACE}/review_output.log\"\n   283→    set +e\n   284→    claude \"${REVIEW_ARGS[@]}\" 2>&1 | tee \"$REVIEW_LOG\"\n   285→    REVIEW_EXIT=${PIPESTATUS[0]}\n   286→    set -e\n   287→\n   288→    if [ $REVIEW_EXIT -eq 0 ]; then\n   289→        echo \"==> Self-review completed successfully\"\n   290→\n   291→        # Extract review text from stream-json result line\n   292→        REVIEW_TEXT=$(grep '\"type\":\"result\"' \"$REVIEW_LOG\" | tail -1 | jq -r '.result // empty' 2>/dev/null)\n   293→        if [ -n \"$REVIEW_TEXT\" ]; then\n   294→            echo \"==> Posting review feedback as PR comment...\"\n   295→            COMMENT_BODY=\"## Self-Review (automated)\n   296→\n   297→${REVIEW_TEXT}\"\n   298→            gh pr comment \"$PR_URL\" --body \"$COMMENT_BODY\" 2>/dev/null || echo \"==> Failed to post review comment\"\n   299→        else\n   300→            echo \"==> No review text to post\"\n   301→        fi\n   302→    else\n   303→        echo \"==> Self-review failed (exit code: ${REVIEW_EXIT}), continuing anyway\"\n   304→    fi\n   305→fi\n   306→\n   307→# --- Write status ---\n   308→write_status \"$CLAUDE_EXIT\" \"$COMPLETE\" \"$NEEDS_INPUT\" \"$QUESTION\" \"$ERROR_MSG\" \"$PR_URL\"\n   309→\n   310→echo \"==> Done (exit code: ${CLAUDE_EXIT})\"\n   311→exit $CLAUDE_EXIT\n   312→"}]},"parent_tool_use_id":"toolu_015W9rgrmaZu78aSJETJC1Gh","session_id":"13b20e59-6472-468f-b07a-3e492441f548","uuid":"d1f3d4d1-ddae-4df1-8f6e-ef9989a2c272"}
