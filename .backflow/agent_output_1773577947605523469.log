tring(task.Status)).Msg(\"task completed\")\n   331→}\n   332→\n   333→func (o *Orchestrator) killTask(ctx context.Context, task *models.Task, reason string) {\n   334→\tif task.ContainerID != \"\" {\n   335→\t\to.docker.StopContainer(ctx, task.InstanceID, task.ContainerID)\n   336→\t}\n   337→\n   338→\tnow := time.Now().UTC()\n   339→\ttask.Status = models.TaskStatusFailed\n   340→\ttask.Error = reason\n   341→\ttask.CompletedAt = &now\n   342→\to.store.UpdateTask(ctx, task)\n   343→\n   344→\to.mu.Lock()\n   345→\to.running--\n   346→\to.mu.Unlock()\n   347→\n   348→\tif task.InstanceID != \"\" {\n   349→\t\tif inst, err := o.store.GetInstance(ctx, task.InstanceID); err == nil && inst != nil {\n   350→\t\t\tinst.RunningContainers--\n   351→\t\t\tif inst.RunningContainers < 0 {\n   352→\t\t\t\tinst.RunningContainers = 0\n   353→\t\t\t}\n   354→\t\t\to.store.UpdateInstance(ctx, inst)\n   355→\t\t}\n   356→\t}\n   357→\n   358→\to.notifier.Notify(notify.Event{\n   359→\t\tType:      notify.EventTaskFailed,\n   360→\t\tTaskID:    task.ID,\n   361→\t\tRepoURL:   task.RepoURL,\n   362→\t\tPrompt:    task.Prompt,\n   363→\t\tMessage:   reason,\n   364→\t\tTimestamp: now,\n   365→\t})\n   366→}\n   367→\n   368→var errNoCapacity = fmt.Errorf(\"no instance capacity available\")\n   369→"}]},"parent_tool_use_id":"toolu_015W9rgrmaZu78aSJETJC1Gh","session_id":"13b20e59-6472-468f-b07a-3e492441f548","uuid":"70c77b0a-0e86-4468-ac10-b623869ca070"}
