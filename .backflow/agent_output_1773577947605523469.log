{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Uuw1zfdir4zxAiEWDA8W69","type":"tool_result","content":"     1→package store\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\n     6→\t\"github.com/backflow-labs/backflow/internal/models\"\n     7→)\n     8→\n     9→// TaskFilter controls listing behavior.\n    10→type TaskFilter struct {\n    11→\tStatus *models.TaskStatus\n    12→\tLimit  int\n    13→\tOffset int\n    14→}\n    15→\n    16→// Store is the persistence interface for tasks and instances.\n    17→type Store interface {\n    18→\t// Tasks\n    19→\tCreateTask(ctx context.Context, task *models.Task) error\n    20→\tGetTask(ctx context.Context, id string) (*models.Task, error)\n    21→\tListTasks(ctx context.Context, filter TaskFilter) ([]*models.Task, error)\n    22→\tUpdateTask(ctx context.Context, task *models.Task) error\n    23→\tDeleteTask(ctx context.Context, id string) error\n    24→\n    25→\t// Instances\n    26→\tCreateInstance(ctx context.Context, inst *models.Instance) error\n    27→\tGetInstance(ctx context.Context, id string) (*models.Instance, error)\n    28→\tListInstances(ctx context.Context, status *models.InstanceStatus) ([]*models.Instance, error)\n    29→\tUpdateInstance(ctx context.Context, inst *models.Instance) error\n    30→\n    31→\tClose() error\n    32→}\n    33→"}]},"parent_tool_use_id":"toolu_015W9rgrmaZu78aSJETJC1Gh","session_id":"13b20e59-6472-468f-b07a-3e492441f548","uuid":"61593370-acae-4d6c-9161-717c06d8a0f0"}
