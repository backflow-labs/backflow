er(t)\n    63→\n    64→\tbody := `{\"repo_url\":\"https://github.com/test/repo\",\"prompt\":\"Fix the bug\",\"create_pr\":true}`\n    65→\treq := httptest.NewRequest(http.MethodPost, \"/api/v1/tasks\", bytes.NewBufferString(body))\n    66→\treq.Header.Set(\"Content-Type\", \"application/json\")\n    67→\tw := httptest.NewRecorder()\n    68→\n    69→\tsrv.ServeHTTP(w, req)\n    70→\n    71→\tif w.Code != http.StatusCreated {\n    72→\t\tt.Fatalf(\"create status = %d, want %d, body: %s\", w.Code, http.StatusCreated, w.Body.String())\n    73→\t}\n    74→\n    75→\tvar resp struct {\n    76→\t\tData struct {\n    77→\t\t\tID     string `json:\"id\"`\n    78→\t\t\tStatus string `json:\"status\"`\n    79→\t\t} `json:\"data\"`\n    80→\t}\n    81→\tjson.NewDecoder(w.Body).Decode(&resp)\n    82→\n    83→\tif resp.Data.ID == \"\" {\n    84→\t\tt.Fatal(\"expected non-empty task ID\")\n    85→\t}\n    86→\tif resp.Data.Status != \"pending\" {\n    87→\t\tt.Errorf(\"status = %q, want pending\", resp.Data.Status)\n    88→\t}\n    89→\n    90→\t// Get the task\n    91→\treq2 := httptest.NewRequest(http.MethodGet, \"/api/v1/tasks/\"+resp.Data.ID, nil)\n    92→\tw2 := httptest.NewRecorder()\n    93→\tsrv.ServeHTTP(w2, req2)\n    94→\n    95→\tif w2.Code != http.StatusOK {\n    96→\t\tt.Errorf(\"get status = %d, want %d\", w2.Code, http.StatusOK)\n    97→\t}\n    98→}\n    99→\n   100→func TestListTasks(t *testing.T) {"}]},"parent_tool_use_id":"toolu_01PDcBuJDkTbrVDZqqd8XFxc","session_id":"8cc67d88-77a2-42c6-8a46-47b1ddf8c38f","uuid":"d869f708-1337-4391-99b0-b121df8fa8c1"}
