{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011K6BaQkek23QzLTfCAif1F","type":"tool_result","content":"     1→package notify\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"net/http\"\n     8→\t\"time\"\n     9→\n    10→\t\"github.com/rs/zerolog/log\"\n    11→)\n    12→\n    13→type EventType string\n    14→\n    15→const (\n    16→\tEventTaskCreated     EventType = \"task.created\"\n    17→\tEventTaskRunning     EventType = \"task.running\"\n    18→\tEventTaskCompleted   EventType = \"task.completed\"\n    19→\tEventTaskFailed      EventType = \"task.failed\"\n    20→\tEventTaskNeedsInput  EventType = \"task.needs_input\"\n    21→\tEventTaskInterrupted EventType = \"task.interrupted\"\n    22→)\n    23→\n    24→type Event struct {\n    25→\tType           EventType `json:\"event\"`\n    26→\tTaskID         string    `json:\"task_id\"`\n    27→\tRepoURL        string    `json:\"repo_url,omitempty\"`\n    28→\tPrompt         string    `json:\"prompt,omitempty\"`\n    29→\tMessage        string    `json:\"message,omitempty\"`\n    30→\tPRURL          string    `json:\"pr_url,omitempty\"`\n    31→\tAgentLogTail   string    `json:\"agent_log_tail,omitempty\"`\n    32→\tTimestamp      time.Time `json:\"timestamp\"`\n    33→}\n    34→\n    35→// Notifier sends notifications for task lifecycle events.\n    36→type Notifier interface {\n    37→\tNotify(event Event) error\n    38→}\n    39→\n    40→// NoopNotifier discards all events.\n    41→type NoopNotifier struct{}\n    42→\n    43→func (NoopNotifier) Notify(Event) error { return nil }\n    44→\n    45→// WebhookNotifier sends HTTP POST notifications.\n    46→type WebhookNotifier struct {\n    47→\turl        string\n    48→\tevents     map[EventType]bool // nil = all events\n    49→\thttpClient *http.Client\n    50→}\n    51→\n    52→func NewWebhookNotifier(url string, filterEvents []string) *WebhookNotifier {\n    53→\tw := &WebhookNotifier{\n    54→\t\turl: url,\n    55→\t\thttpClient: &http.Client{\n    56→\t\t\tTimeout: 10 * time.Second,\n    57→\t\t},\n    58→\t}\n    59→\tif len(filterEvents) > 0 {\n    60→\t\tw.events = make(map[EventType]bool, len(filterEvents))\n    61→\t\tfor _, e := range filterEvents {\n    62→\t\t\tw.events[EventType(e)] = true\n    63→\t\t}\n    64→\t}\n    65→\treturn w\n    66→}\n    67→\n    68→func (w *WebhookNotifier) Notify(event Event) error {\n    69→\tif w.events != nil && !w.events[event.Type] {\n    70→\t\treturn nil\n    71→\t}\n    72→\n    73→\tbody, err := json.Marshal(event)\n    74→\tif err != nil {\n    75→\t\treturn fmt.Errorf(\"marshal event: %w\", err)\n    76→\t}\n    77→\n    78→\tvar lastErr error\n    79→\tfor attempt := 0; attempt < 3; attempt++ {\n    80→\t\tif attempt > 0 {\n    81→\t\t\ttime.Sleep(time.Duration(attempt) * 2 * time.Second)\n    82→\t\t}\n    83→\n    84→\t\treq, err := http.NewRequest(http.MethodPost, w.url, bytes.NewReader(body))\n    85→\t\tif err != nil {\n    86→\t\t\treturn fmt.Errorf(\"create request: %w\", err)\n    87→\t\t}\n    88→\t\treq.Header.Set(\"Content-Type\", \"application/json\")\n    89→\t\treq.Header.Set(\"User-Agent\", \"backflow-webhook/1.0\")\n    90→\n    91→\t\tresp, err := w.httpClient.Do(req)\n    92→\t\tif err != nil {\n    93→\t\t\tlastErr = err\n    94→\t\t\tlog.Warn().Err(err).Int(\"attempt\", attempt+1).Str(\"event\", string(event.Type)).Msg(\"webhook request failed\")\n    95→\t\t\tcontinue\n    96→\t\t}\n    97→\t\tresp.Body.Close()\n    98→\n    99→\t\tif resp.StatusCode >= 200 && resp.StatusCode < 300 {\n   100→\t\t\tlog.Debug().Str(\"event\", string(event.Type)).Str(\"task_id\", event.TaskID).Msg(\"webhook sent\")\n   101→\t\t\treturn nil\n   102→\t\t}\n   103→\t\tlastErr = fmt.Errorf(\"webhook returned status %d\", resp.StatusCode)\n   104→\t\tlog.Warn().Int(\"status\", resp.StatusCode).Int(\"attempt\", attempt+1).Msg(\"webhook non-2xx response\")\n   105→\t}\n   106→\n   107→\treturn fmt.Errorf(\"webhook failed after 3 attempts: %w\", lastErr)\n   108→}\n   109→"}]},"parent_tool_use_id":"toolu_01PDcBuJDkTbrVDZqqd8XFxc","session_id":"8cc67d88-77a2-42c6-8a46-47b1ddf8c38f","uuid":"e3db9ac1-d316-43a1-8e39-d4015060c834"}
