pr_body,omitempty\"`\n    42→\tPRURL         string            `json:\"pr_url,omitempty\"`\n    43→\tAllowedTools  []string          `json:\"allowed_tools,omitempty\"`\n    44→\tClaudeMD      string            `json:\"claude_md,omitempty\"`\n    45→\tEnvVars       map[string]string `json:\"env_vars,omitempty\"`\n    46→\tInstanceID    string            `json:\"instance_id,omitempty\"`\n    47→\tContainerID   string            `json:\"container_id,omitempty\"`\n    48→\tRetryCount    int               `json:\"retry_count\"`\n    49→\tCostUSD       float64           `json:\"cost_usd,omitempty\"`\n    50→\tError         string            `json:\"error,omitempty\"`\n    51→\tCreatedAt     time.Time         `json:\"created_at\"`\n    52→\tUpdatedAt     time.Time         `json:\"updated_at\"`\n    53→\tStartedAt     *time.Time        `json:\"started_at,omitempty\"`\n    54→\tCompletedAt   *time.Time        `json:\"completed_at,omitempty\"`\n    55→}\n    56→\n    57→// AllowedToolsJSON returns the JSON representation for DB storage.\n    58→func (t *Task) AllowedToolsJSON() string {\n    59→\tif len(t.AllowedTools) == 0 {\n    60→\t\treturn \"[]\"\n    61→\t}\n    62→\tb, _ := json.Marshal(t.AllowedTools)\n    63→\treturn string(b)\n    64→}\n    65→\n    66→// EnvVarsJSON returns the JSON representation for DB storage.\n    67→func (t *Task) EnvVarsJSON() string {\n    68→\tif len(t.EnvVars) == 0 {\n    69→\t\treturn \"{}\"\n    70→\t}\n    71→\tb, _ := json.Marshal(t.EnvVars)\n    72→\treturn string(b)\n    73→}\n    74→\n    75→// CreateTaskRequest is the API input for creating a task.\n    76→type CreateTaskRequest struct {\n    77→\tRepoURL       string            `json:\"repo_url\"`\n    78→\tBranch        string            `json:\"branch,omitempty\"`\n    79→\tTargetBranch  string            `json:\"target_branch,omitempty\"`\n    80→\tPrompt        string            `json:\"prompt\"`\n    81→\tContext       string            `json:\"context,omitempty\"`\n    82→\tModel         string            `json:\"model,omitempty\"`\n    83→\tEffort        string            `json:\"effort,omitempty\"`\n    84→\tMaxBudgetUSD  float64           `json:\"max_budget_usd,omitempty\"`\n    85→\tMaxRuntimeMin int               `json:\"max_runtime_min,omitempty\"`\n    86→\tMaxTurns      int               `json:\"max_turns,omitempty\"`\n    87→\tCreatePR      bool              `json:\"create_pr\"`\n    88→\tSelfReview    bool              `json:\"self_review\"`\n    89→\tPRTitle       string            `json:\"pr_title,omitempty\"`\n    90→\tPRBody        string            `json:\"pr_body,omitempty\"`\n    91→\tAllowedTools  []string          `json:\"allowed_tools,omitempty\"`\n    92→\tClaudeMD      string            `json:\"claude_md,omitempty\"`\n    93→\tEnvVars       map[string]string `json:\"env_vars,omitempty\"`\n    94→}\n    95→\n    96→func (r *CreateTaskRequest) Validate() error {\n    97→\tif r.RepoURL == \"\" {\n    98→\t\treturn fmt.Errorf(\"repo_url is required\")\n    99→\t}\n   100→\tif r.Prompt == \"\" {\n   101→\t\treturn fmt.Errorf(\"prompt is required\")\n   102→\t}\n   103→\tif r.MaxBudgetUSD < 0 {\n   104→\t\treturn fmt.Errorf(\"max_budget_usd must be non-negative\")\n   105→\t}\n   106→\tif r.MaxRuntimeMin < 0 {\n   107→\t\treturn fmt.Errorf(\"max_runtime_min must be non-negative\")\n   108→\t}\n   109→\tif r.Effort != \"\" {\n   110→\t\tswitch r.Effort {\n   111→\t\tcase \"low\", \"medium\", \"high\", \"xhigh\":\n   112→\t\tdefault:\n   113→\t\t\treturn fmt.Errorf(\"effort must be low, medium, high, or xhigh\")\n   114→\t\t}\n   115→\t}\n   116→\treturn nil\n   117→}\n   118→"}]},"parent_tool_use_id":"toolu_01PDcBuJDkTbrVDZqqd8XFxc","session_id":"8cc67d88-77a2-42c6-8a46-47b1ddf8c38f","uuid":"55795da2-9fe2-40f1-ad30-f89b5576480e"}
