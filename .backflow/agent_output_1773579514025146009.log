{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DUbAhMpdso3Q3DYsPPE3DS","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"net/http\"\n     6→\t\"os\"\n     7→\t\"os/signal\"\n     8→\t\"syscall\"\n     9→\t\"time\"\n    10→\n    11→\t\"github.com/rs/zerolog\"\n    12→\t\"github.com/rs/zerolog/log\"\n    13→\n    14→\t\"github.com/backflow-labs/backflow/internal/api\"\n    15→\t\"github.com/backflow-labs/backflow/internal/config\"\n    16→\t\"github.com/backflow-labs/backflow/internal/notify\"\n    17→\t\"github.com/backflow-labs/backflow/internal/orchestrator\"\n    18→\t\"github.com/backflow-labs/backflow/internal/store\"\n    19→)\n    20→\n    21→func main() {\n    22→\tlog.Logger = zerolog.New(zerolog.ConsoleWriter{Out: os.Stderr, TimeFormat: time.RFC3339}).\n    23→\t\tWith().Timestamp().Caller().Logger()\n    24→\n    25→\tcfg, err := config.Load()\n    26→\tif err != nil {\n    27→\t\tlog.Fatal().Err(err).Msg(\"failed to load config\")\n    28→\t}\n    29→\n    30→\tdb, err := store.NewSQLite(cfg.DBPath)\n    31→\tif err != nil {\n    32→\t\tlog.Fatal().Err(err).Msg(\"failed to open database\")\n    33→\t}\n    34→\tdefer db.Close()\n    35→\n    36→\tvar notifier notify.Notifier\n    37→\tif cfg.WebhookURL != \"\" {\n    38→\t\tnotifier = notify.NewWebhookNotifier(cfg.WebhookURL, cfg.WebhookEvents)\n    39→\t\tlog.Info().Str(\"url\", cfg.WebhookURL).Msg(\"webhook notifications enabled\")\n    40→\t} else {\n    41→\t\tnotifier = notify.NoopNotifier{}\n    42→\t}\n    43→\n    44→\torch := orchestrator.New(db, cfg, notifier)\n    45→\n    46→\tsrv := &http.Server{\n    47→\t\tAddr:         cfg.ListenAddr,\n    48→\t\tHandler:      api.NewServer(db, cfg, orch.Docker()),\n    49→\t\tReadTimeout:  10 * time.Second,\n    50→\t\tWriteTimeout: 30 * time.Second,\n    51→\t\tIdleTimeout:  60 * time.Second,\n    52→\t}\n    53→\n    54→\tctx, cancel := context.WithCancel(context.Background())\n    55→\tdefer cancel()\n    56→\n    57→\t// Start orchestrator in background\n    58→\tgo orch.Start(ctx)\n    59→\n    60→\t// Start HTTP server\n    61→\tgo func() {\n    62→\t\tlog.Info().Str(\"addr\", cfg.ListenAddr).Msg(\"API server starting\")\n    63→\t\tif err := srv.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n    64→\t\t\tlog.Fatal().Err(err).Msg(\"server failed\")\n    65→\t\t}\n    66→\t}()\n    67→\n    68→\t// Wait for shutdown signal\n    69→\tquit := make(chan os.Signal, 1)\n    70→\tsignal.Notify(quit, syscall.SIGINT, syscall.SIGTERM)\n    71→\t<-quit\n    72→\n    73→\tlog.Info().Msg(\"shutting down...\")\n    74→\tcancel()\n    75→\torch.Stop()\n    76→\n    77→\tshutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 10*time.Second)\n    78→\tdefer shutdownCancel()\n    79→\n    80→\tif err := srv.Shutdown(shutdownCtx); err != nil {\n    81→\t\tlog.Error().Err(err).Msg(\"server shutdown error\")\n    82→\t}\n    83→\n    84→\tlog.Info().Msg(\"shutdown complete\")\n    85→}\n    86→"}]},"parent_tool_use_id":"toolu_01PDcBuJDkTbrVDZqqd8XFxc","session_id":"8cc67d88-77a2-42c6-8a46-47b1ddf8c38f","uuid":"4a8bb5e4-5bc0-4e23-aec1-51350af44b51"}
