{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01W2YfgmaBnQADx3eGu8RKNj","type":"tool_result","content":"     1→package orchestrator\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"sync\"\n     7→\t\"time\"\n     8→\n     9→\t\"github.com/rs/zerolog/log\"\n    10→\n    11→\t\"github.com/backflow-labs/backflow/internal/config\"\n    12→\t\"github.com/backflow-labs/backflow/internal/models\"\n    13→\t\"github.com/backflow-labs/backflow/internal/notify\"\n    14→\t\"github.com/backflow-labs/backflow/internal/store\"\n    15→)\n    16→\n    17→type Orchestrator struct {\n    18→\tstore    store.Store\n    19→\tconfig   *config.Config\n    20→\tnotifier notify.Notifier\n    21→\tec2      *EC2Manager\n    22→\tdocker   *DockerManager\n    23→\tscaler   scaler\n    24→\tspot     *SpotHandler\n    25→\n    26→\tmu             sync.Mutex\n    27→\trunning        int\n    28→\tstopCh         chan struct{}\n    29→\tinspectFailures map[string]int // task ID -> consecutive inspect failure count\n    30→}\n    31→\n    32→func New(s store.Store, cfg *config.Config, notifier notify.Notifier) *Orchestrator {\n    33→\tdocker := NewDockerManager(cfg)\n    34→\n    35→\to := &Orchestrator{\n    36→\t\tstore:           s,\n    37→\t\tconfig:          cfg,\n    38→\t\tnotifier:        notifier,\n    39→\t\tdocker:          docker,\n    40→\t\tstopCh:          make(chan struct{}),\n    41→\t\tinspectFailures: make(map[string]int),\n    42→\t}\n    43→\n    44→\tif cfg.Mode == config.ModeLocal {\n    45→\t\to.scaler = localScaler{}\n    46→\t\t// Seed a local instance so findAvailableInstance works without EC2.\n    47→\t\t// If it already exists (server restart), reset it to running state.\n    48→\t\tnow := time.Now().UTC()\n    49→\t\tinst, _ := s.GetInstance(context.Background(), \"local\")\n    50→\t\tif inst != nil {\n    51→\t\t\tinst.Status = models.InstanceStatusRunning\n    52→\t\t\tinst.MaxContainers = cfg.ContainersPerInst\n    53→\t\t\tinst.RunningContainers = 0\n    54→\t\t\tinst.UpdatedAt = now\n    55→\t\t\ts.UpdateInstance(context.Background(), inst)\n    56→\t\t} else {\n    57→\t\t\tinst = &models.Instance{\n    58→\t\t\t\tInstanceID:    \"local\",\n    59→\t\t\t\tInstanceType:  \"local\",\n    60→\t\t\t\tStatus:        models.InstanceStatusRunning,\n    61→\t\t\t\tMaxContainers: cfg.ContainersPerInst,\n    62→\t\t\t\tPrivateIP:     \"127.0.0.1\",\n    63→\t\t\t\tCreatedAt:     now,\n    64→\t\t\t\tUpdatedAt:     now,\n    65→\t\t\t}\n    66→\t\t\ts.CreateInstance(context.Background(), inst)\n    67→\t\t}\n    68→\t} else {\n    69→\t\tec2 := NewEC2Manager(cfg)\n    70→\t\to.ec2 = ec2\n    71→\t\to.scaler = NewScaler(s, ec2, docker, cfg)\n    72→\t\to.spot = NewSpotHandler(s, ec2)\n    73→\n    74→\t\t// Clean up leftover local instance from a previous local-mode run.\n    75→\t\tif inst, _ := s.GetInstance(context.Background(), \"local\"); inst != nil && inst.Status != models.InstanceStatusTerminated {\n    76→\t\t\tinst.Status = models.InstanceStatusTerminated\n    77→\t\t\tinst.RunningContainers = 0\n    78→\t\t\ts.UpdateInstance(context.Background(), inst)\n    79→\t\t}\n    80→\t}\n    81→\n    82→\treturn o\n    83→}\n    84→\n    85→// Docker returns the DockerManager for use by the API logs endpoint.\n    86→func (o *Orchestrator) Docker() *DockerManager {\n    87→\treturn o.docker\n    88→}\n    89→\n    90→func (o *Orchestrator) Start(ctx context.Context) {\n    91→\tlog.Info().\n    92→\t\tStr(\"mode\", string(o.config.Mode)).\n    93→\t\tStr(\"auth_mode\", string(o.config.AuthMode)).\n    94→\t\tInt(\"max_concurrent\", o.config.MaxConcurrent()).\n    95→\t\tDur(\"poll_interval\", o.config.PollInterval).\n    96→\t\tMsg(\"orchestrator started\")\n    97→\n    98→\tticker := time.NewTicker(o.config.PollInterval)\n    99→\tdefer ticker.Stop()\n   100→\n   101→\tfor {\n   102→\t\tselect {\n   103→\t\tcase <-ctx.Done():\n   104→\t\t\tlog.Info().Msg(\"orchestrator stopping\")\n   105→\t\t\treturn\n   106→\t\tcase <-o.stopCh:\n   107→\t\t\tlog.Info().Msg(\"orchestrator stopped\")\n   108→\t\t\treturn\n   109→\t\tcase <-ticker.C:\n   110→\t\t\to.tick(ctx)\n   111→\t\t}\n   112→\t}\n   113→}\n   114→\n   115→func (o *Orchestrator) Stop() {\n   116→\tclose(o.stopCh)\n   117→}\n   118→\n   119→func (o *Orchestrator) tick(ctx context.Context) {\n   120→\to.monitorRunning(ctx)\n   121→\to.dispatchPending(ctx)\n   122→\to.scaler.Evaluate(ctx)\n   123→}\n   124→\n   125→func (o *Orchestrator) dispatchPending(ctx context.Context) {\n   126→\to.mu.Lock()\n   127→\tmaxConcurrent := o.config.MaxConcurrent()\n   128→\tavailable := maxConcurrent - o.running\n   129→\to.mu.Unlock()\n   130→\n   131→\tif available <= 0 {\n   132→\t\treturn\n   133→\t}\n   134→\n   135→\tpending := models.TaskStatusPending\n   136→\ttasks, err := o.store.ListTasks(ctx, store.TaskFilter{\n   137→\t\tStatus: &pending,\n   138→\t\tLimit:  available,\n   139→\t})\n   140→\tif err != nil {\n   141→\t\tlog.Error().Err(err).Msg(\"failed to list pending tasks\")\n   142→\t\treturn\n   143→\t}\n   144→\n   145→\tfor _, task := range tasks {\n   146→\t\tif err := o.dispatch(ctx, task); err != nil {\n   147→\t\t\tlog.Error().Err(err).Str(\"task_id\", task.ID).Msg(\"failed to dispatch task\")\n   148→\t\t\ttask.Status = models.TaskStatusFailed\n   149→\t\t\ttask.Error = err.Error()\n   150→\t\t\to.store.UpdateTask(ctx, task)\n   151→\t\t\to.notifier.Notify(notify.Event{\n   152→\t\t\t\tType:      notify.EventTaskFailed,\n   153→\t\t\t\tTaskID:    task.ID,\n   154→\t\t\t\tRepoURL:   task.RepoURL,\n   155→\t\t\t\tPrompt:    task.Prompt,\n   156→\t\t\t\tMessage:   \"Failed to dispatch: \" + err.Error(),\n   157→\t\t\t\tTimestamp: time.Now().UTC(),\n   158→\t\t\t})\n   159→\t\t\tcontinue\n   160→\t\t}\n   161→\t}\n   162→}\n   163→\n   164→func (o *Orchestrator) dispatch(ctx context.Context, task *models.Task) error {\n   165→\t// Find an instance with capacity\n   166→\tinstance, err := o.findAvailableInstance(ctx)\n   167→\tif err != nil {\n   168→\t\t// Request scale-up and re-queue for next tick\n   169→\t\to.scaler.RequestScaleUp(ctx)\n   170→\t\treturn nil\n   171→\t}\n   172→\n   173→\t// Update task status to provisioning\n   174→\ttask.Status = models.TaskStatusProvisioning\n   175→\ttask.InstanceID = instance.InstanceID\n   176→\tif err := o.store.UpdateTask(ctx, task); err != nil {\n   177→\t\treturn err\n   178→\t}\n   179→\n   180→\t// Start container\n   181→\tcontainerID, err := o.docker.RunAgent(ctx, instance, task)\n   182→\tif err != nil {\n   183→\t\treturn err\n   184→\t}\n   185→\n   186→\tnow := time.Now().UTC()\n   187→\ttask.Status = models.TaskStatusRunning\n   188→\ttask.ContainerID = containerID\n   189→\ttask.StartedAt = &now\n   190→\tif err := o.store.UpdateTask(ctx, task); err != nil {\n   191→\t\treturn err\n   192→\t}\n   193→\n   194→\to.mu.Lock()\n   195→\to.running++\n   196→\to.mu.Unlock()\n   197→\n   198→\t// Update instance container count\n   199→\tinstance.RunningContainers++\n   200→\to.store.UpdateInstance(ctx, instance)\n   201→\n   202→\to.notifier.Notify(notify.Event{\n   203→\t\tType:      notify.EventTaskRunning,\n   204→\t\tTaskID:    task.ID,\n   205→\t\tRepoURL:   task.RepoURL,\n   206→\t\tPrompt:    task.Prompt,\n   207→\t\tTimestamp: now,\n   208→\t})\n   209→\n   210→\tlog.Info().Str(\"task_id\", task.ID).Str(\"container\", containerID).Str(\"instance\", instance.InstanceID).Msg(\"task dispatched\")\n   211→\treturn nil\n   212→}\n   213→\n   214→func (o *Orchestrator) findAvailableInstance(ctx context.Context) (*models.Instance, error) {\n   215→\trunning := models.InstanceStatusRunning\n   216→\tinstances, err := o.store.ListInstances(ctx, &running)\n   217→\tif err != nil {\n   218→\t\treturn nil, err\n   219→\t}\n   220→\n   221→\tfor _, inst := range instances {\n   222→\t\tif inst.RunningContainers < inst.MaxContainers {\n   223→\t\t\treturn inst, nil\n   224→\t\t}\n   225→\t}\n   226→\n   227→\treturn nil, errNoCapacity\n   228→}\n   229→\n   230→func (o *Orchestrator) monitorRunning(ctx context.Context) {\n   231→\trunning := models.TaskStatusRunning\n   232→\ttasks, err := o.store.ListTasks(ctx, store.TaskFilter{Status: &running})\n   233→\tif err != nil {\n   234→\t\tlog.Error().Err(err).Msg(\"failed to list running tasks\")\n   235→\t\treturn\n   236→\t}\n   237→\n   238→\tfor _, task := range tasks {\n   239→\t\t// Check timeout\n   240→\t\tif task.StartedAt != nil && task.MaxRuntimeMin > 0 {\n   241→\t\t\tdeadline := task.StartedAt.Add(time.Duration(task.MaxRuntimeMin) * time.Minute)\n   242→\t\t\tif time.Now().UTC().After(deadline) {\n   243→\t\t\t\tlog.Warn().Str(\"task_id\", task.ID).Msg(\"task exceeded max runtime, killing\")\n   244→\t\t\t\to.killTask(ctx, task, \"exceeded max runtime\")\n   245→\t\t\t\tcontinue\n   246→\t\t\t}\n   247→\t\t}\n   248→\n   249→\t\t// Check container status\n   250→\t\tstatus, err := o.docker.InspectContainer(ctx, task.InstanceID, task.ContainerID)\n   251→\t\tif err != nil {\n   252→\t\t\to.inspectFailures[task.ID]++\n   253→\t\t\tcount := o.inspectFailures[task.ID]\n   254→\t\t\tlog.Warn().Err(err).Str(\"task_id\", task.ID).Int(\"consecutive_failures\", count).Msg(\"failed to inspect container\")\n   255→\t\t\tif count >= 3 {\n   256→\t\t\t\tdelete(o.inspectFailures, task.ID)\n   257→\t\t\t\to.killTask(ctx, task, fmt.Sprintf(\"container unreachable after %d inspect failures: %v\", count, err))\n   258→\t\t\t}\n   259→\t\t\tcontinue\n   260→\t\t}\n   261→\n   262→\t\tdelete(o.inspectFailures, task.ID)\n   263→\n   264→\t\tif status.Done {\n   265→\t\t\to.handleCompletion(ctx, task, status)\n   266→\t\t}\n   267→\t}\n   268→}\n   269→\n   270→func (o *Orchestrator) handleCompletion(ctx context.Context, task *models.Task, status ContainerStatus) {\n   271→\tnow := time.Now().UTC()\n   272→\ttask.CompletedAt = &now\n   273→\n   274→\ttask.PRURL = status.PRURL\n   275→\n   276→\tif status.ExitCode == 0 {\n   277→\t\ttask.Status = models.TaskStatusCompleted\n   278→\t\to.notifier.Notify(notify.Event{\n   279→\t\t\tType:           notify.EventTaskCompleted,\n   280→\t\t\tTaskID:         task.ID,\n   281→\t\t\tRepoURL:        task.RepoURL,\n   282→\t\t\tPrompt:         task.Prompt,\n   283→\t\t\tPRURL:          status.PRURL,\n   284→\t\t\tAgentLogTail:   status.LogTail,\n   285→\t\t\tTimestamp:      now,\n   286→\t\t})\n   287→\t} else if status.NeedsInput {\n   288→\t\ttask.Status = models.TaskStatusFailed\n   289→\t\ttask.Error = \"agent needs input\"\n   290→\t\to.notifier.Notify(notify.Event{\n   291→\t\t\tType:         notify.EventTaskNeedsInput,\n   292→\t\t\tTaskID:       task.ID,\n   293→\t\t\tRepoURL:      task.RepoURL,\n   294→\t\t\tPrompt:       task.Prompt,\n   295→\t\t\tMessage:      status.Question,\n   296→\t\t\tAgentLogTail: status.LogTail,\n   297→\t\t\tTimestamp:    now,\n   298→\t\t})\n   299→\t} else {\n   300→\t\ttask.Status = models.TaskStatusFailed\n   301→\t\ttask.Error = status.Error\n   302→\t\to.notifier.Notify(notify.Event{\n   303→\t\t\tType:         notify.EventTaskFailed,\n   304→\t\t\tTaskID:       task.ID,\n   305→\t\t\tRepoURL:      task.RepoURL,\n   306→\t\t\tPrompt:       task.Prompt,\n   307→\t\t\tMessage:      status.Error,\n   308→\t\t\tAgentLogTail: status.LogTail,\n   309→\t\t\tTimestamp:    now,\n   310→\t\t})\n   311→\t}\n   312→\n   313→\to.store.UpdateTask(ctx, task)\n   314→\n   315→\to.mu.Lock()\n   316→\to.running--\n   317→\to.mu.Unlock()\n   318→\n   319→\t// Decrement instance container count\n   320→\tif task.InstanceID != \"\" {\n   321→\t\tif inst, err := o.store.GetInstance(ctx, task.InstanceID); err == nil && inst != nil {\n   322→\t\t\tinst.RunningContainers--\n   323→\t\t\tif inst.RunningContainers < 0 {\n   324→\t\t\t\tinst.RunningContainers = 0\n   325→\t\t\t}\n   326→\t\t\to.store.UpdateInstance(ctx, inst)\n   327→\t\t}\n   328→\t}\n   329→\n   330→\tlog.Info().Str(\"task_id\", task.ID).Str(\"status\", string(task.Status)).Msg(\"task completed\")\n   331→}\n   332→\n   333→func (o *Orchestrator) killTask(ctx context.Context, task *models.Task, reason string) {\n   334→\tif task.ContainerID != \"\" {\n   335→\t\to.docker.StopContainer(ctx, task.InstanceID, task.ContainerID)\n   336→\t}\n   337→\n   338→\tnow := time.Now().UTC()\n   339→\ttask.Status = models.TaskStatusFailed\n   340→\ttask.Error = reason\n   341→\ttask.CompletedAt = &now\n   342→\to.store.UpdateTask(ctx, task)\n   343→\n   344→\to.mu.Lock()\n   345→\to.running--\n   346→\to.mu.Unlock()\n   347→\n   348→\tif task.InstanceID != \"\" {\n   349→\t\tif inst, err := o.store.GetInstance(ctx, task.InstanceID); err == nil && inst != nil {\n   350→\t\t\tinst.RunningContainers--\n   351→\t\t\tif inst.RunningContainers < 0 {\n   352→\t\t\t\tinst.RunningContainers = 0\n   353→\t\t\t}\n   354→\t\t\to.store.UpdateInstance(ctx, inst)\n   355→\t\t}\n   356→\t}\n   357→\n   358→\to.notifier.Notify(notify.Event{\n   359→\t\tType:      notify.EventTaskFailed,\n   360→\t\tTaskID:    task.ID,\n   361→\t\tRepoURL:   task.RepoURL,\n   362→\t\tPrompt:    task.Prompt,\n   363→\t\tMessage:   reason,\n   364→\t\tTimestamp: now,\n   365→\t})\n   366→}\n   367→\n   368→var errNoCapacity = fmt.Errorf(\"no instance capacity available\")\n   369→"}]},"parent_tool_use_id":"toolu_01PDcBuJDkTbrVDZqqd8XFxc","session_id":"8cc67d88-77a2-42c6-8a46-47b1ddf8c38f","uuid":"394e2393-f708-42c5-8f93-2602de7ebc1f"}
