{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BGcczaDjy214GSjq2a3Vwx","type":"tool_result","content":"     1→package api\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"net/http\"\n     7→\t\"strconv\"\n     8→\t\"time\"\n     9→\n    10→\t\"github.com/go-chi/chi/v5\"\n    11→\t\"github.com/oklog/ulid/v2\"\n    12→\n    13→\t\"github.com/backflow-labs/backflow/internal/config\"\n    14→\t\"github.com/backflow-labs/backflow/internal/models\"\n    15→\t\"github.com/backflow-labs/backflow/internal/store\"\n    16→)\n    17→\n    18→// LogFetcher retrieves container logs for a running task.\n    19→type LogFetcher interface {\n    20→\tGetLogs(ctx context.Context, instanceID, containerID string, tail int) (string, error)\n    21→}\n    22→\n    23→type Handlers struct {\n    24→\tstore  store.Store\n    25→\tconfig *config.Config\n    26→\tlogs   LogFetcher\n    27→}\n    28→\n    29→func NewHandlers(s store.Store, cfg *config.Config, logs LogFetcher) *Handlers {\n    30→\treturn &Handlers{store: s, config: cfg, logs: logs}\n    31→}\n    32→\n    33→func (h *Handlers) CreateTask(w http.ResponseWriter, r *http.Request) {\n    34→\tvar req models.CreateTaskRequest\n    35→\tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n    36→\t\twriteError(w, http.StatusBadRequest, \"invalid JSON: \"+err.Error())\n    37→\t\treturn\n    38→\t}\n    39→\tif err := req.Validate(); err != nil {\n    40→\t\twriteError(w, http.StatusBadRequest, err.Error())\n    41→\t\treturn\n    42→\t}\n    43→\n    44→\tnow := time.Now().UTC()\n    45→\ttask := &models.Task{\n    46→\t\tID:            \"bf_\" + ulid.Make().String(),\n    47→\t\tStatus:        models.TaskStatusPending,\n    48→\t\tRepoURL:       req.RepoURL,\n    49→\t\tBranch:        req.Branch,\n    50→\t\tTargetBranch:  req.TargetBranch,\n    51→\t\tPrompt:        req.Prompt,\n    52→\t\tContext:       req.Context,\n    53→\t\tModel:         withDefault(req.Model, h.config.DefaultModel),\n    54→\t\tEffort:        withDefault(req.Effort, h.config.DefaultEffort),\n    55→\t\tMaxBudgetUSD:  withDefaultFloat(req.MaxBudgetUSD, h.config.DefaultMaxBudget),\n    56→\t\tMaxRuntimeMin: withDefaultInt(req.MaxRuntimeMin, int(h.config.DefaultMaxRuntime.Minutes())),\n    57→\t\tMaxTurns:      withDefaultInt(req.MaxTurns, h.config.DefaultMaxTurns),\n    58→\t\tCreatePR:      req.CreatePR,\n    59→\t\tSelfReview:    req.SelfReview,\n    60→\t\tPRTitle:       req.PRTitle,\n    61→\t\tPRBody:        req.PRBody,\n    62→\t\tAllowedTools:  req.AllowedTools,\n    63→\t\tClaudeMD:      req.ClaudeMD,\n    64→\t\tEnvVars:       req.EnvVars,\n    65→\t\tCreatedAt:     now,\n    66→\t\tUpdatedAt:     now,\n    67→\t}\n    68→\n    69→\tif err := h.store.CreateTask(r.Context(), task); err != nil {\n    70→\t\twriteError(w, http.StatusInternalServerError, \"failed to create task\")\n    71→\t\treturn\n    72→\t}\n    73→\n    74→\twriteJSON(w, http.StatusCreated, task)\n    75→}\n    76→\n    77→func (h *Handlers) GetTask(w http.ResponseWriter, r *http.Request) {\n    78→\tid := chi.URLParam(r, \"id\")\n    79→\ttask, err := h.store.GetTask(r.Context(), id)\n    80→\tif err != nil {\n    81→\t\twriteError(w, http.StatusInternalServerError, \"failed to get task\")\n    82→\t\treturn\n    83→\t}\n    84→\tif task == nil {\n    85→\t\twriteError(w, http.StatusNotFound, \"task not found\")\n    86→\t\treturn\n    87→\t}\n    88→\twriteJSON(w, http.StatusOK, task)\n    89→}\n    90→\n    91→func (h *Handlers) ListTasks(w http.ResponseWriter, r *http.Request) {\n    92→\tfilter := store.TaskFilter{\n    93→\t\tLimit:  50,\n    94→\t\tOffset: 0,\n    95→\t}\n    96→\tif s := r.URL.Query().Get(\"status\"); s != \"\" {\n    97→\t\tstatus := models.TaskStatus(s)\n    98→\t\tfilter.Status = &status\n    99→\t}\n   100→\tif l := r.URL.Query().Get(\"limit\"); l != \"\" {\n   101→\t\tif n, err := strconv.Atoi(l); err == nil && n > 0 {\n   102→\t\t\tfilter.Limit = n\n   103→\t\t}\n   104→\t}\n   105→\tif o := r.URL.Query().Get(\"offset\"); o != \"\" {\n   106→\t\tif n, err := strconv.Atoi(o); err == nil && n >= 0 {\n   107→\t\t\tfilter.Offset = n\n   108→\t\t}\n   109→\t}\n   110→\n   111→\ttasks, err := h.store.ListTasks(r.Context(), filter)\n   112→\tif err != nil {\n   113→\t\twriteError(w, http.StatusInternalServerError, \"failed to list tasks\")\n   114→\t\treturn\n   115→\t}\n   116→\tif tasks == nil {\n   117→\t\ttasks = []*models.Task{}\n   118→\t}\n   119→\twriteJSON(w, http.StatusOK, tasks)\n   120→}\n   121→\n   122→func (h *Handlers) DeleteTask(w http.ResponseWriter, r *http.Request) {\n   123→\tid := chi.URLParam(r, \"id\")\n   124→\ttask, err := h.store.GetTask(r.Context(), id)\n   125→\tif err != nil {\n   126→\t\twriteError(w, http.StatusInternalServerError, \"failed to get task\")\n   127→\t\treturn\n   128→\t}\n   129→\tif task == nil {\n   130→\t\twriteError(w, http.StatusNotFound, \"task not found\")\n   131→\t\treturn\n   132→\t}\n   133→\n   134→\t// If running, mark as cancelled (orchestrator will kill the container)\n   135→\tif task.Status == models.TaskStatusRunning || task.Status == models.TaskStatusProvisioning {\n   136→\t\ttask.Status = models.TaskStatusCancelled\n   137→\t\tnow := time.Now().UTC()\n   138→\t\ttask.CompletedAt = &now\n   139→\t\tif err := h.store.UpdateTask(r.Context(), task); err != nil {\n   140→\t\t\twriteError(w, http.StatusInternalServerError, \"failed to cancel task\")\n   141→\t\t\treturn\n   142→\t\t}\n   143→\t} else if !task.Status.IsTerminal() {\n   144→\t\tif err := h.store.DeleteTask(r.Context(), id); err != nil {\n   145→\t\t\twriteError(w, http.StatusInternalServerError, \"failed to delete task\")\n   146→\t\t\treturn\n   147→\t\t}\n   148→\t}\n   149→\n   150→\tw.WriteHeader(http.StatusNoContent)\n   151→}\n   152→\n   153→func (h *Handlers) GetTaskLogs(w http.ResponseWriter, r *http.Request) {\n   154→\tid := chi.URLParam(r, \"id\")\n   155→\ttask, err := h.store.GetTask(r.Context(), id)\n   156→\tif err != nil {\n   157→\t\twriteError(w, http.StatusInternalServerError, \"failed to get task\")\n   158→\t\treturn\n   159→\t}\n   160→\tif task == nil {\n   161→\t\twriteError(w, http.StatusNotFound, \"task not found\")\n   162→\t\treturn\n   163→\t}\n   164→\n   165→\tif task.InstanceID == \"\" || task.ContainerID == \"\" {\n   166→\t\tw.Header().Set(\"Content-Type\", \"text/plain\")\n   167→\t\tw.WriteHeader(http.StatusOK)\n   168→\t\tmsg := \"status: \" + string(task.Status) + \"\\n\"\n   169→\t\tif task.Error != \"\" {\n   170→\t\t\tmsg += \"error: \" + task.Error + \"\\n\"\n   171→\t\t}\n   172→\t\tw.Write([]byte(msg))\n   173→\t\treturn\n   174→\t}\n   175→\n   176→\ttail := 100\n   177→\tif t := r.URL.Query().Get(\"tail\"); t != \"\" {\n   178→\t\tif n, err := strconv.Atoi(t); err == nil && n > 0 {\n   179→\t\t\ttail = n\n   180→\t\t}\n   181→\t}\n   182→\n   183→\tlogs, err := h.logs.GetLogs(r.Context(), task.InstanceID, task.ContainerID, tail)\n   184→\tif err != nil {\n   185→\t\twriteError(w, http.StatusBadGateway, \"failed to fetch logs: \"+err.Error())\n   186→\t\treturn\n   187→\t}\n   188→\n   189→\tw.Header().Set(\"Content-Type\", \"text/plain\")\n   190→\tw.WriteHeader(http.StatusOK)\n   191→\tw.Write([]byte(logs))\n   192→}\n   193→\n   194→func (h *Handlers) HealthCheck(w http.ResponseWriter, r *http.Request) {\n   195→\twriteJSON(w, http.StatusOK, map[string]string{\n   196→\t\t\"status\":    \"ok\",\n   197→\t\t\"auth_mode\": string(h.config.AuthMode),\n   198→\t})\n   199→}\n   200→\n   201→func withDefault(val, fallback string) string {\n   202→\tif val == \"\" {\n   203→\t\treturn fallback\n   204→\t}\n   205→\treturn val\n   206→}\n   207→\n   208→func withDefaultFloat(val, fallback float64) float64 {\n   209→\tif val == 0 {\n   210→\t\treturn fallback\n   211→\t}\n   212→\treturn val\n   213→}\n   214→\n   215→func withDefaultInt(val, fallback int) int {\n   216→\tif val == 0 {\n   217→\t\treturn fallback\n   218→\t}\n   219→\treturn val\n   220→}\n   221→"}]},"parent_tool_use_id":"toolu_01PDcBuJDkTbrVDZqqd8XFxc","session_id":"8cc67d88-77a2-42c6-8a46-47b1ddf8c38f","uuid":"c5946ebb-734f-4d58-90d7-1ef28fc09560"}
