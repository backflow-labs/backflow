{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017fVqoHycUnQaKEApq4rV3W","type":"tool_result","content":"     1→package orchestrator\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"os/exec\"\n     9→\t\"strings\"\n    10→\t\"time\"\n    11→\n    12→\t\"github.com/aws/aws-sdk-go-v2/aws\"\n    13→\tawsconfig \"github.com/aws/aws-sdk-go-v2/config\"\n    14→\t\"github.com/aws/aws-sdk-go-v2/service/ssm\"\n    15→\t\"github.com/rs/zerolog/log\"\n    16→\n    17→\t\"github.com/backflow-labs/backflow/internal/config\"\n    18→\t\"github.com/backflow-labs/backflow/internal/models\"\n    19→)\n    20→\n    21→type ContainerStatus struct {\n    22→\tDone       bool\n    23→\tExitCode   int\n    24→\tNeedsInput bool\n    25→\tQuestion   string\n    26→\tError      string\n    27→\tLogTail    string\n    28→\tPRURL      string\n    29→}\n    30→\n    31→type DockerManager struct {\n    32→\tconfig    *config.Config\n    33→\tssmClient *ssm.Client\n    34→}\n    35→\n    36→func NewDockerManager(cfg *config.Config) *DockerManager {\n    37→\treturn &DockerManager{config: cfg}\n    38→}\n    39→\n    40→func (m *DockerManager) ensureClient(ctx context.Context) error {\n    41→\tif m.ssmClient != nil {\n    42→\t\treturn nil\n    43→\t}\n    44→\tcfg, err := awsconfig.LoadDefaultConfig(ctx, awsconfig.WithRegion(m.config.AWSRegion))\n    45→\tif err != nil {\n    46→\t\treturn fmt.Errorf(\"load AWS config: %w\", err)\n    47→\t}\n    48→\tm.ssmClient = ssm.NewFromConfig(cfg)\n    49→\treturn nil\n    50→}\n    51→\n    52→func (m *DockerManager) RunAgent(ctx context.Context, instance *models.Instance, task *models.Task) (string, error) {\n    53→\n    54→\tenvFlags := []string{\n    55→\t\tfmt.Sprintf(\"-e TASK_ID=%s\", task.ID),\n    56→\t\tfmt.Sprintf(\"-e REPO_URL=%s\", shellEscape(task.RepoURL)),\n    57→\t\tfmt.Sprintf(\"-e BRANCH=%s\", shellEscape(task.Branch)),\n    58→\t\tfmt.Sprintf(\"-e TARGET_BRANCH=%s\", shellEscape(task.TargetBranch)),\n    59→\t\tfmt.Sprintf(\"-e PROMPT=%s\", shellEscape(task.Prompt)),\n    60→\t\tfmt.Sprintf(\"-e MODEL=%s\", shellEscape(task.Model)),\n    61→\t\tfmt.Sprintf(\"-e EFFORT=%s\", shellEscape(task.Effort)),\n    62→\t\tfmt.Sprintf(\"-e MAX_BUDGET_USD=%g\", task.MaxBudgetUSD),\n    63→\t\tfmt.Sprintf(\"-e MAX_TURNS=%d\", task.MaxTurns),\n    64→\t\tfmt.Sprintf(\"-e CREATE_PR=%t\", task.CreatePR),\n    65→\t\tfmt.Sprintf(\"-e SELF_REVIEW=%t\", task.SelfReview),\n    66→\t}\n    67→\n    68→\tif task.PRTitle != \"\" {\n    69→\t\tenvFlags = append(envFlags, fmt.Sprintf(\"-e PR_TITLE=%s\", shellEscape(task.PRTitle)))\n    70→\t}\n    71→\tif task.PRBody != \"\" {\n    72→\t\tenvFlags = append(envFlags, fmt.Sprintf(\"-e PR_BODY=%s\", shellEscape(task.PRBody)))\n    73→\t}\n    74→\tif task.ClaudeMD != \"\" {\n    75→\t\tenvFlags = append(envFlags, fmt.Sprintf(\"-e CLAUDE_MD=%s\", shellEscape(task.ClaudeMD)))\n    76→\t}\n    77→\tif task.Context != \"\" {\n    78→\t\tenvFlags = append(envFlags, fmt.Sprintf(\"-e TASK_CONTEXT=%s\", shellEscape(task.Context)))\n    79→\t}\n    80→\n    81→\t// Auth mode\n    82→\tenvFlags = append(envFlags, fmt.Sprintf(\"-e AUTH_MODE=%s\", string(m.config.AuthMode)))\n    83→\tif m.config.AuthMode == config.AuthModeAPIKey {\n    84→\t\tenvFlags = append(envFlags, fmt.Sprintf(\"-e ANTHROPIC_API_KEY=%s\", m.config.AnthropicAPIKey))\n    85→\t}\n    86→\n    87→\tif m.config.GitHubToken != \"\" {\n    88→\t\tenvFlags = append(envFlags, fmt.Sprintf(\"-e GITHUB_TOKEN=%s\", m.config.GitHubToken))\n    89→\t}\n    90→\n    91→\t// Custom env vars from task\n    92→\tfor k, v := range task.EnvVars {\n    93→\t\tenvFlags = append(envFlags, fmt.Sprintf(\"-e %s=%s\", k, shellEscape(v)))\n    94→\t}\n    95→\n    96→\tvolumeFlags := \"\"\n    97→\tif m.config.AuthMode == config.AuthModeMaxSubscription && m.config.ClaudeCredentialsPath != \"\" {\n    98→\t\tvolumeFlags = fmt.Sprintf(\"-v %s:/home/agent/.claude:ro\", m.config.ClaudeCredentialsPath)\n    99→\t}\n   100→\n   101→\tcmd := fmt.Sprintf(\n   102→\t\t\"docker run -d --cpus=1 --memory=3g %s %s backflow-agent\",\n   103→\t\tvolumeFlags,\n   104→\t\tstrings.Join(envFlags, \" \"),\n   105→\t)\n   106→\n   107→\toutput, err := m.runCommand(ctx, instance.InstanceID, cmd)\n   108→\tif err != nil {\n   109→\t\treturn \"\", fmt.Errorf(\"run container: %w\", err)\n   110→\t}\n   111→\n   112→\tcontainerID := strings.TrimSpace(output)\n   113→\tif containerID == \"\" {\n   114→\t\treturn \"\", fmt.Errorf(\"empty container ID returned\")\n   115→\t}\n   116→\n   117→\t// Docker container IDs are 64-char hex strings; reject anything else\n   118→\t// (e.g. error messages captured via 2>&1)\n   119→\tif !isHexString(containerID) {\n   120→\t\treturn \"\", fmt.Errorf(\"docker run failed: %s\", containerID)\n   121→\t}\n   122→\n   123→\tlog.Debug().Str(\"container\", containerID[:12]).Str(\"instance\", instance.InstanceID).Msg(\"started agent container\")\n   124→\treturn containerID, nil\n   125→}\n   126→\n   127→func (m *DockerManager) InspectContainer(ctx context.Context, instanceID, containerID string) (ContainerStatus, error) {\n   128→\tcmd := fmt.Sprintf(\"docker inspect --format '{{.State.Status}} {{.State.ExitCode}}' %s 2>/dev/null && docker logs --tail 20 %s 2>&1\", containerID, containerID)\n   129→\toutput, err := m.runCommand(ctx, instanceID, cmd)\n   130→\tif err != nil {\n   131→\t\treturn ContainerStatus{}, err\n   132→\t}\n   133→\n   134→\tlines := strings.SplitN(output, \"\\n\", 2)\n   135→\tif len(lines) == 0 {\n   136→\t\treturn ContainerStatus{}, fmt.Errorf(\"empty inspect output\")\n   137→\t}\n   138→\n   139→\tparts := strings.Fields(lines[0])\n   140→\tif len(parts) < 2 {\n   141→\t\treturn ContainerStatus{}, fmt.Errorf(\"unexpected inspect format: %s\", lines[0])\n   142→\t}\n   143→\n   144→\tstatus := ContainerStatus{}\n   145→\tif len(lines) > 1 {\n   146→\t\tstatus.LogTail = lines[1]\n   147→\t}\n   148→\n   149→\tdockerStatus := parts[0]\n   150→\tif dockerStatus == \"exited\" || dockerStatus == \"dead\" {\n   151→\t\tstatus.Done = true\n   152→\t\tfmt.Sscanf(parts[1], \"%d\", &status.ExitCode)\n   153→\n   154→\t\tif status.ExitCode != 0 {\n   155→\t\t\tstatus.Error = fmt.Sprintf(\"container exited with code %d\", status.ExitCode)\n   156→\t\t}\n   157→\n   158→\t\t// Check for status.json written by entrypoint\n   159→\t\tstatusCmd := fmt.Sprintf(\"docker cp %s:/home/agent/workspace/status.json /dev/stdout 2>/dev/null\", containerID)\n   160→\t\tif statusJSON, err := m.runCommand(ctx, instanceID, statusCmd); err == nil {\n   161→\t\t\tvar agentStatus struct {\n   162→\t\t\t\tNeedsInput bool   `json:\"needs_input\"`\n   163→\t\t\t\tQuestion   string `json:\"question\"`\n   164→\t\t\t\tComplete   bool   `json:\"complete\"`\n   165→\t\t\t\tError      string `json:\"error\"`\n   166→\t\t\t\tPRURL      string `json:\"pr_url\"`\n   167→\t\t\t}\n   168→\t\t\tif json.Unmarshal([]byte(statusJSON), &agentStatus) == nil {\n   169→\t\t\t\tstatus.NeedsInput = agentStatus.NeedsInput\n   170→\t\t\t\tstatus.Question = agentStatus.Question\n   171→\t\t\t\tstatus.PRURL = agentStatus.PRURL\n   172→\t\t\t\tif agentStatus.Error != \"\" {\n   173→\t\t\t\t\tstatus.Error = agentStatus.Error\n   174→\t\t\t\t}\n   175→\t\t\t}\n   176→\t\t}\n   177→\t}\n   178→\n   179→\treturn status, nil\n   180→}\n   181→\n   182→func (m *DockerManager) StopContainer(ctx context.Context, instanceID, containerID string) error {\n   183→\tcmd := fmt.Sprintf(\"docker stop -t 30 %s 2>/dev/null; docker rm %s 2>/dev/null\", containerID, containerID)\n   184→\t_, err := m.runCommand(ctx, instanceID, cmd)\n   185→\treturn err\n   186→}\n   187→\n   188→func (m *DockerManager) GetLogs(ctx context.Context, instanceID, containerID string, tail int) (string, error) {\n   189→\tcmd := fmt.Sprintf(\"docker logs --tail %d %s 2>&1\", tail, containerID)\n   190→\treturn m.runCommand(ctx, instanceID, cmd)\n   191→}\n   192→\n   193→func (m *DockerManager) runCommand(ctx context.Context, instanceID, command string) (string, error) {\n   194→\tif m.config.Mode == config.ModeLocal {\n   195→\t\treturn m.runLocalCommand(ctx, command)\n   196→\t}\n   197→\treturn m.runSSMCommand(ctx, instanceID, command)\n   198→}\n   199→\n   200→func (m *DockerManager) runLocalCommand(ctx context.Context, command string) (string, error) {\n   201→\tcmd := exec.CommandContext(ctx, \"bash\", \"-c\", command)\n   202→\tvar stdout, stderr bytes.Buffer\n   203→\tcmd.Stdout = &stdout\n   204→\tcmd.Stderr = &stderr\n   205→\tif err := cmd.Run(); err != nil {\n   206→\t\tdetail := strings.TrimSpace(stderr.String())\n   207→\t\tif detail == \"\" {\n   208→\t\t\tdetail = strings.TrimSpace(stdout.String())\n   209→\t\t}\n   210→\t\tif detail != \"\" {\n   211→\t\t\treturn \"\", fmt.Errorf(\"local command failed: %s\", detail)\n   212→\t\t}\n   213→\t\treturn \"\", fmt.Errorf(\"local command failed: %w\", err)\n   214→\t}\n   215→\treturn stdout.String(), nil\n   216→}\n   217→\n   218→func (m *DockerManager) runSSMCommand(ctx context.Context, instanceID, command string) (string, error) {\n   219→\tif err := m.ensureClient(ctx); err != nil {\n   220→\t\treturn \"\", err\n   221→\t}\n   222→\n   223→\tinput := &ssm.SendCommandInput{\n   224→\t\tInstanceIds:  []string{instanceID},\n   225→\t\tDocumentName: aws.String(\"AWS-RunShellScript\"),\n   226→\t\tParameters: map[string][]string{\n   227→\t\t\t\"commands\": {command},\n   228→\t\t},\n   229→\t}\n   230→\n   231→\tresult, err := m.ssmClient.SendCommand(ctx, input)\n   232→\tif err != nil {\n   233→\t\treturn \"\", fmt.Errorf(\"ssm send command: %w\", err)\n   234→\t}\n   235→\n   236→\tcmdID := aws.ToString(result.Command.CommandId)\n   237→\n   238→\t// Wait for command to complete\n   239→\twaiter := ssm.NewCommandExecutedWaiter(m.ssmClient)\n   240→\tgetOutput := &ssm.GetCommandInvocationInput{\n   241→\t\tCommandId:  aws.String(cmdID),\n   242→\t\tInstanceId: aws.String(instanceID),\n   243→\t}\n   244→\n   245→\tif err := waiter.Wait(ctx, getOutput, 5*time.Minute); err != nil {\n   246→\t\t// Fetch output even on failure to get stderr/diagnostics\n   247→\t\tif out, getErr := m.ssmClient.GetCommandInvocation(ctx, getOutput); getErr == nil {\n   248→\t\t\tstderr := strings.TrimSpace(aws.ToString(out.StandardErrorContent))\n   249→\t\t\tstdout := strings.TrimSpace(aws.ToString(out.StandardOutputContent))\n   250→\t\t\tstatus := string(out.Status)\n   251→\t\t\tdetail := stderr\n   252→\t\t\tif detail == \"\" {\n   253→\t\t\t\tdetail = stdout\n   254→\t\t\t}\n   255→\t\t\tif detail != \"\" {\n   256→\t\t\t\treturn \"\", fmt.Errorf(\"ssm command failed (status=%s): %s\", status, detail)\n   257→\t\t\t}\n   258→\t\t\treturn \"\", fmt.Errorf(\"ssm command failed (status=%s): %w\", status, err)\n   259→\t\t}\n   260→\t\treturn \"\", fmt.Errorf(\"wait for command: %w\", err)\n   261→\t}\n   262→\n   263→\tout, err := m.ssmClient.GetCommandInvocation(ctx, getOutput)\n   264→\tif err != nil {\n   265→\t\treturn \"\", fmt.Errorf(\"get command output: %w\", err)\n   266→\t}\n   267→\n   268→\treturn aws.ToString(out.StandardOutputContent), nil\n   269→}\n   270→\n   271→func isHexString(s string) bool {\n   272→\tif len(s) == 0 {\n   273→\t\treturn false\n   274→\t}\n   275→\tfor _, c := range s {\n   276→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n   277→\t\t\treturn false\n   278→\t\t}\n   279→\t}\n   280→\treturn true\n   281→}\n   282→\n   283→func shellEscape(s string) string {\n   284→\treturn \"'\" + strings.ReplaceAll(s, \"'\", \"'\\\"'\\\"'\") + \"'\"\n   285→}\n   286→"}]},"parent_tool_use_id":"toolu_01PDcBuJDkTbrVDZqqd8XFxc","session_id":"8cc67d88-77a2-42c6-8a46-47b1ddf8c38f","uuid":"0983d3ce-9625-4613-b4d6-81b152bad17b"}
