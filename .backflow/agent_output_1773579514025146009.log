t// Let the launch template provide ImageId, InstanceType, tags, etc.\n    56→\t\tinput.LaunchTemplate = &types.LaunchTemplateSpecification{\n    57→\t\t\tLaunchTemplateId: aws.String(m.config.LaunchTemplateID),\n    58→\t\t\tVersion:          aws.String(\"$Latest\"),\n    59→\t\t}\n    60→\t} else if m.config.AMI != \"\" {\n    61→\t\tinput.ImageId = aws.String(m.config.AMI)\n    62→\t\tinput.InstanceType = types.InstanceType(m.config.InstanceType)\n    63→\t\tinput.TagSpecifications = []types.TagSpecification{\n    64→\t\t\t{\n    65→\t\t\t\tResourceType: types.ResourceTypeInstance,\n    66→\t\t\t\tTags: []types.Tag{\n    67→\t\t\t\t\t{Key: aws.String(\"Name\"), Value: aws.String(\"backflow-agent\")},\n    68→\t\t\t\t\t{Key: aws.String(\"backflow\"), Value: aws.String(\"true\")},\n    69→\t\t\t\t},\n    70→\t\t\t},\n    71→\t\t}\n    72→\t} else {\n    73→\t\treturn \"\", fmt.Errorf(\"either BACKFLOW_AMI or BACKFLOW_LAUNCH_TEMPLATE_ID must be set\")\n    74→\t}\n    75→\n    76→\tresult, err := m.client.RunInstances(ctx, input)\n    77→\tif err != nil {\n    78→\t\treturn \"\", fmt.Errorf(\"run instances: %w\", err)\n    79→\t}\n    80→\n    81→\tif len(result.Instances) == 0 {\n    82→\t\treturn \"\", fmt.Errorf(\"no instances returned\")\n    83→\t}\n    84→\n    85→\tinstanceID := aws.ToString(result.Instances[0].InstanceId)\n    86→\tlog.Info().Str(\"instance_id\", instanceID).Str(\"type\", m.config.InstanceType).Msg(\"launched spot instance\")\n    87→\treturn instanceID, nil\n    88→}\n    89→\n    90→func (m *EC2Manager) TerminateInstance(ctx context.Context, instanceID string) error {\n    91→\tif err := m.ensureClient(ctx); err != nil {\n    92→\t\treturn err\n    93→\t}\n    94→\n    95→\t_, err := m.client.TerminateInstances(ctx, &ec2.TerminateInstancesInput{\n    96→\t\tInstanceIds: []string{instanceID},\n    97→\t})\n    98→\tif err != nil {\n    99→\t\treturn fmt.Errorf(\"terminate instance %s: %w\", instanceID, err)\n   100→\t}\n   101→\n   102→\tlog.Info().Str(\"instance_id\", instanceID).Msg(\"terminated instance\")\n   103→\treturn nil\n   104→}\n   105→\n   106→func (m *EC2Manager) DescribeInstance(ctx context.Context, instanceID string) (*types.Instance, error) {\n   107→\tif err := m.ensureClient(ctx); err != nil {\n   108→\t\treturn nil, err\n   109→\t}\n   110→\n   111→\tresult, err := m.client.DescribeInstances(ctx, &ec2.DescribeInstancesInput{\n   112→\t\tInstanceIds: []string{instanceID},\n   113→\t})\n   114→\tif err != nil {\n   115→\t\treturn nil, fmt.Errorf(\"describe instance %s: %w\", instanceID, err)\n   116→\t}\n   117→\n   118→\tfor _, r := range result.Reservations {\n   119→\t\tfor _, inst := range r.Instances {\n   120→\t\t\treturn &inst, nil\n   121→\t\t}\n   122→\t}\n   123→\n   124→\treturn nil, fmt.Errorf(\"instance %s not found\", instanceID)\n   125→}\n   126→"}]},"parent_tool_use_id":"toolu_01PDcBuJDkTbrVDZqqd8XFxc","session_id":"8cc67d88-77a2-42c6-8a46-47b1ddf8c38f","uuid":"245751c5-5d77-42ab-845b-5654ff64e06d"}
