{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BpP57GKo2LoRMABHDaG8Nm","type":"tool_result","content":"     1→package orchestrator\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"strings\"\n     6→\t\"time\"\n     7→\n     8→\t\"github.com/aws/aws-sdk-go-v2/aws\"\n     9→\tawsconfig \"github.com/aws/aws-sdk-go-v2/config\"\n    10→\t\"github.com/aws/aws-sdk-go-v2/service/ec2/types\"\n    11→\t\"github.com/aws/aws-sdk-go-v2/service/ssm\"\n    12→\tssmtypes \"github.com/aws/aws-sdk-go-v2/service/ssm/types\"\n    13→\t\"github.com/rs/zerolog/log\"\n    14→\n    15→\t\"github.com/backflow-labs/backflow/internal/config\"\n    16→\t\"github.com/backflow-labs/backflow/internal/models\"\n    17→\t\"github.com/backflow-labs/backflow/internal/store\"\n    18→)\n    19→\n    20→type scaler interface {\n    21→\tEvaluate(ctx context.Context)\n    22→\tRequestScaleUp(ctx context.Context)\n    23→}\n    24→\n    25→const idleTimeout = 5 * time.Minute\n    26→\n    27→type Scaler struct {\n    28→\tstore     store.Store\n    29→\tec2       *EC2Manager\n    30→\tdocker    *DockerManager\n    31→\tconfig    *config.Config\n    32→\tssmClient *ssm.Client\n    33→}\n    34→\n    35→func NewScaler(s store.Store, ec2 *EC2Manager, docker *DockerManager, cfg *config.Config) *Scaler {\n    36→\treturn &Scaler{store: s, ec2: ec2, docker: docker, config: cfg}\n    37→}\n    38→\n    39→func (s *Scaler) ensureSSMClient(ctx context.Context) error {\n    40→\tif s.ssmClient != nil {\n    41→\t\treturn nil\n    42→\t}\n    43→\tcfg, err := awsconfig.LoadDefaultConfig(ctx, awsconfig.WithRegion(s.config.AWSRegion))\n    44→\tif err != nil {\n    45→\t\treturn err\n    46→\t}\n    47→\ts.ssmClient = ssm.NewFromConfig(cfg)\n    48→\treturn nil\n    49→}\n    50→\n    51→// isSSMReady checks if the SSM agent on the instance is online and ready.\n    52→func (s *Scaler) isSSMReady(ctx context.Context, instanceID string) bool {\n    53→\tif err := s.ensureSSMClient(ctx); err != nil {\n    54→\t\treturn false\n    55→\t}\n    56→\tout, err := s.ssmClient.DescribeInstanceInformation(ctx, &ssm.DescribeInstanceInformationInput{\n    57→\t\tFilters: []ssmtypes.InstanceInformationStringFilter{\n    58→\t\t\t{Key: aws.String(\"InstanceIds\"), Values: []string{instanceID}},\n    59→\t\t},\n    60→\t})\n    61→\tif err != nil {\n    62→\t\treturn false\n    63→\t}\n    64→\tfor _, info := range out.InstanceInformationList {\n    65→\t\tif info.PingStatus == ssmtypes.PingStatusOnline {\n    66→\t\t\treturn true\n    67→\t\t}\n    68→\t}\n    69→\treturn false\n    70→}\n    71→\n    72→// isDockerReady checks if Docker is running and the agent image is available.\n    73→func (s *Scaler) isDockerReady(ctx context.Context, instanceID string) bool {\n    74→\tout, err := s.docker.runSSMCommand(ctx, instanceID, \"docker image inspect backflow-agent:latest >/dev/null 2>&1 && echo ready\")\n    75→\tif err != nil {\n    76→\t\treturn false\n    77→\t}\n    78→\treturn strings.TrimSpace(out) == \"ready\"\n    79→}\n    80→"}]},"parent_tool_use_id":"toolu_01KnJpccSTYsfRojm9zc6EhF","session_id":"a2b6d02e-3c8e-471d-894d-da47ffea5542","uuid":"ded4ee1e-c837-4eaa-89db-2afece94da3e"}
