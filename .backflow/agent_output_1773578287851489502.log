r.Limit = n\n   103→\t\t}\n   104→\t}\n   105→\tif o := r.URL.Query().Get(\"offset\"); o != \"\" {\n   106→\t\tif n, err := strconv.Atoi(o); err == nil && n >= 0 {\n   107→\t\t\tfilter.Offset = n\n   108→\t\t}\n   109→\t}\n   110→\n   111→\ttasks, err := h.store.ListTasks(r.Context(), filter)\n   112→\tif err != nil {\n   113→\t\twriteError(w, http.StatusInternalServerError, \"failed to list tasks\")\n   114→\t\treturn\n   115→\t}\n   116→\tif tasks == nil {\n   117→\t\ttasks = []*models.Task{}\n   118→\t}\n   119→\twriteJSON(w, http.StatusOK, tasks)\n   120→}\n   121→\n   122→func (h *Handlers) DeleteTask(w http.ResponseWriter, r *http.Request) {\n   123→\tid := chi.URLParam(r, \"id\")\n   124→\ttask, err := h.store.GetTask(r.Context(), id)\n   125→\tif err != nil {\n   126→\t\twriteError(w, http.StatusInternalServerError, \"failed to get task\")\n   127→\t\treturn\n   128→\t}\n   129→\tif task == nil {\n   130→\t\twriteError(w, http.StatusNotFound, \"task not found\")\n   131→\t\treturn\n   132→\t}\n   133→\n   134→\t// If running, mark as cancelled (orchestrator will kill the container)\n   135→\tif task.Status == models.TaskStatusRunning || task.Status == models.TaskStatusProvisioning {\n   136→\t\ttask.Status = models.TaskStatusCancelled\n   137→\t\tnow := time.Now().UTC()\n   138→\t\ttask.CompletedAt = &now\n   139→\t\tif err := h.store.UpdateTask(r.Context(), task); err != nil {\n   140→\t\t\twriteError(w, http.StatusInternalServerError, \"failed to cancel task\")\n   141→\t\t\treturn\n   142→\t\t}\n   143→\t} else if !task.Status.IsTerminal() {\n   144→\t\tif err := h.store.DeleteTask(r.Context(), id); err != nil {\n   145→\t\t\twriteError(w, http.StatusInternalServerError, \"failed to delete task\")\n   146→\t\t\treturn\n   147→\t\t}\n   148→\t}\n   149→\n   150→\tw.WriteHeader(http.StatusNoContent)\n   151→}\n   152→\n   153→func (h *Handlers) GetTaskLogs(w http.ResponseWriter, r *http.Request) {\n   154→\tid := chi.URLParam(r, \"id\")\n   155→\ttask, err := h.store.GetTask(r.Context(), id)\n   156→\tif err != nil {\n   157→\t\twriteError(w, http.StatusInternalServerError, \"failed to get task\")\n   158→\t\treturn\n   159→\t}\n   160→\tif task == nil {\n   161→\t\twriteError(w, http.StatusNotFound, \"task not found\")\n   162→\t\treturn\n   163→\t}\n   164→\n   165→\tif task.InstanceID == \"\" || task.ContainerID == \"\" {\n   166→\t\tw.Header().Set(\"Content-Type\", \"text/plain\")\n   167→\t\tw.WriteHeader(http.StatusOK)\n   168→\t\tmsg := \"status: \" + string(task.Status) + \"\\n\"\n   169→\t\tif task.Error != \"\" {\n   170→\t\t\tmsg += \"error: \" + task.Error + \"\\n\"\n   171→\t\t}\n   172→\t\tw.Write([]byte(msg))\n   173→\t\treturn\n   174→\t}\n   175→\n   176→\ttail := 100\n   177→\tif t := r.URL.Query().Get(\"tail\"); t != \"\" {\n   178→\t\tif n, err := strconv.Atoi(t); err == nil && n > 0 {\n   179→\t\t\ttail = n\n   180→\t\t}\n   181→\t}\n   182→\n   183→\tlogs, err := h.logs.GetLogs(r.Context(), task.InstanceID, task.ContainerID, tail)\n   184→\tif err != nil {\n   185→\t\twriteError(w, http.StatusBadGateway, \"failed to fetch logs: \"+err.Error())\n   186→\t\treturn\n   187→\t}\n   188→\n   189→\tw.Header().Set(\"Content-Type\", \"text/plain\")\n   190→\tw.WriteHeader(http.StatusOK)\n   191→\tw.Write([]byte(logs))\n   192→}\n   193→\n   194→func (h *Handlers) HealthCheck(w http.ResponseWriter, r *http.Request) {\n   195→\twriteJSON(w, http.StatusOK, map[string]string{\n   196→\t\t\"status\":    \"ok\",\n   197→\t\t\"auth_mode\": string(h.config.AuthMode),\n   198→\t})\n   199→}\n   200→\n   201→func withDefault(val, fallback string) string {\n   202→\tif val == \"\" {\n   203→\t\treturn fallback\n   204→\t}\n   205→\treturn val\n   206→}\n   207→\n   208→func withDefaultFloat(val, fallback float64) float64 {\n   209→\tif val == 0 {\n   210→\t\treturn fallback\n   211→\t}\n   212→\treturn val\n   213→}\n   214→\n   215→func withDefaultInt(val, fallback int) int {\n   216→\tif val == 0 {\n   217→\t\tre