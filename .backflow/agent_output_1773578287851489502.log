{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018yuhCyruK3r46FCywwhRfV","type":"tool_result","content":"     1→package orchestrator\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"sync\"\n     7→\t\"time\"\n     8→\n     9→\t\"github.com/rs/zerolog/log\"\n    10→\n    11→\t\"github.com/backflow-labs/backflow/internal/config\"\n    12→\t\"github.com/backflow-labs/backflow/internal/models\"\n    13→\t\"github.com/backflow-labs/backflow/internal/notify\"\n    14→\t\"github.com/backflow-labs/backflow/internal/store\"\n    15→)\n    16→\n    17→type Orchestrator struct {\n    18→\tstore    store.Store\n    19→\tconfig   *config.Config\n    20→\tnotifier notify.Notifier\n    21→\tec2      *EC2Manager\n    22→\tdocker   *DockerManager\n    23→\tscaler   scaler\n    24→\tspot     *SpotHandler\n    25→\n    26→\tmu             sync.Mutex\n    27→\trunning        int\n    28→\tstopCh         chan struct{}\n    29→\tinspectFailures map[string]int // task ID -> consecutive inspect failure count\n    30→}\n    31→\n    32→func New(s store.Store, cfg *config.Config, notifier notify.Notifier) *Orchestrator {\n    33→\tdocker := NewDockerManager(cfg)\n    34→\n    35→\to := &Orchestrator{\n    36→\t\tstore:           s,\n    37→\t\tconfig:          cfg,\n    38→\t\tnotifier:        notifier,\n    39→\t\tdocker:          docker,\n    40→\t\tstopCh:          make(chan struct{}),\n    41→\t\tinspectFailures: make(map[string]int),\n    42→\t}\n    43→\n    44→\tif cfg.Mode == config.ModeLocal {\n    45→\t\to.scaler = localScaler{}\n    46→\t\t// Seed a local instance so findAvailableInstance works without EC2.\n    47→\t\t// If it already exists (server restart), reset it to running state.\n    48→\t\tnow := time.Now().UTC()\n    49→\t\tinst, _ := s.GetInstance(context.Background(), \"local\")\n    50→\t\tif inst != nil {\n    51→\t\t\tinst.Status = models.InstanceStatusRunning\n    52→\t\t\tinst.MaxContainers = cfg.ContainersPerInst\n    53→\t\t\tinst.RunningContainers = 0\n    54→\t\t\tinst.UpdatedAt = now\n    55→\t\t\ts.UpdateInstance(context.Background(), inst)\n    56→\t\t} else {\n    57→\t\t\tinst = &models.Instance{\n    58→\t\t\t\tInstanceID:    \"local\",\n    59→\t\t\t\tInstanceType:  \"local\",\n    60→\t\t\t\tStatus:        models.InstanceStatusRunning,\n    61→\t\t\t\tMaxContainers: cfg.ContainersPerInst,\n    62→\t\t\t\tPrivateIP:     \"127.0.0.1\",\n    63→\t\t\t\tCreatedAt:     now,\n    64→\t\t\t\tUpdatedAt:     now,\n    65→\t\t\t}\n    66→\t\t\ts.CreateInstance(context.Background(), inst)\n    67→\t\t}\n    68→\t} else {\n    69→\t\tec2 := NewEC2Manager(cfg)\n    70→\t\to.ec2 = ec2\n    71→\t\to.scaler = NewScaler(s, ec2, docker, cfg)\n    72→\t\to.spot = NewSpotHandler(s, ec2)\n    73→\n    74→\t\t// Clean up leftover local instance from a previous local-mode run.\n    75→\t\tif inst, _ := s.GetInstance(context.Background(), \"local\"); inst != nil && inst.Status != models.InstanceStatusTerminated {\n    76→\t\t\tinst.Status = models.InstanceStatusTerminated\n    77→\t\t\tinst.RunningContainers = 0\n    78→\t\t\ts.UpdateInstance(context.Background(), inst)\n    79→\t\t}\n    80→\t}"}]},"parent_tool_use_id":"toolu_01KnJpccSTYsfRojm9zc6EhF","session_id":"a2b6d02e-3c8e-471d-894d-da47ffea5542","uuid":"b64a913f-0c2c-41dd-b44b-9d305d8d75df"}
