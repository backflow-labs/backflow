{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Qdw1rVbnNb3P9nVZa4NL68","type":"tool_result","content":"     1→# Backflow server configuration\n     2→\n     3→# Auth mode: \"api_key\" (multi-agent) or \"max_subscription\" (serial, one at a time)\n     4→BACKFLOW_AUTH_MODE=api_key\n     5→\n     6→# Required for api_key mode\n     7→ANTHROPIC_API_KEY=sk-ant-...\n     8→\n     9→# Required for max_subscription mode (path to ~/.claude/ with cached OAuth credentials)\n    10→# CLAUDE_CREDENTIALS_PATH=/home/you/.claude\n    11→\n    12→# GitHub personal access token (for cloning private repos and creating PRs)\n    13→GITHUB_TOKEN=ghp_...\n    14→\n    15→# Server\n    16→BACKFLOW_LISTEN_ADDR=:8080\n    17→BACKFLOW_DB_PATH=backflow.db\n    18→\n    19→# AWS\n    20→AWS_REGION=us-east-1\n    21→BACKFLOW_INSTANCE_TYPE=t4g.medium\n    22→BACKFLOW_LAUNCH_TEMPLATE_ID=lt-...\n    23→BACKFLOW_MAX_INSTANCES=5\n    24→BACKFLOW_CONTAINERS_PER_INSTANCE=4\n    25→\n    26→# Agent defaults\n    27→BACKFLOW_DEFAULT_MODEL=claude-sonnet-4-6\n    28→BACKFLOW_DEFAULT_MAX_BUDGET=10\n    29→BACKFLOW_DEFAULT_MAX_RUNTIME_MIN=30\n    30→BACKFLOW_DEFAULT_MAX_TURNS=200\n    31→\n    32→# Webhooks (optional)\n    33→# BACKFLOW_WEBHOOK_URL=https://hooks.slack.com/services/...\n    34→# BACKFLOW_WEBHOOK_EVENTS=task.needs_input,task.failed,task.completed\n    35→\n    36→# Orchestrator\n    37→BACKFLOW_POLL_INTERVAL_SEC=5\n    38→"}]},"parent_tool_use_id":"toolu_01KnJpccSTYsfRojm9zc6EhF","session_id":"a2b6d02e-3c8e-471d-894d-da47ffea5542","uuid":"9c6d2a33-5872-425c-a136-021bb4fffa0d"}
