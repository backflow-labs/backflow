EXT NOT NULL DEFAULT '',\n    55→\t\tpr_body         TEXT NOT NULL DEFAULT '',\n    56→\t\tpr_url          TEXT NOT NULL DEFAULT '',\n    57→\t\tallowed_tools   TEXT NOT NULL DEFAULT '[]',\n    58→\t\tclaude_md       TEXT NOT NULL DEFAULT '',\n    59→\t\tenv_vars        TEXT NOT NULL DEFAULT '{}',\n    60→\t\tinstance_id     TEXT NOT NULL DEFAULT '',\n    61→\t\tcontainer_id    TEXT NOT NULL DEFAULT '',\n    62→\t\tretry_count     INTEGER NOT NULL DEFAULT 0,\n    63→\t\tcost_usd        REAL NOT NULL DEFAULT 0,\n    64→\t\terror           TEXT NOT NULL DEFAULT '',\n    65→\t\tcreated_at      TEXT NOT NULL,\n    66→\t\tupdated_at      TEXT NOT NULL,\n    67→\t\tstarted_at      TEXT,\n    68→\t\tcompleted_at    TEXT\n    69→\t);\n    70→\n    71→\tCREATE INDEX IF NOT EXISTS idx_tasks_status ON tasks(status);\n    72→\tCREATE INDEX IF NOT EXISTS idx_tasks_created ON tasks(created_at);\n    73→\n    74→\tCREATE TABLE IF NOT EXISTS instances (\n    75→\t\tinstance_id        TEXT PRIMARY KEY,\n    76→\t\tinstance_type      TEXT NOT NULL,\n    77→\t\tavailability_zone  TEXT NOT NULL DEFAULT '',\n    78→\t\tprivate_ip         TEXT NOT NULL DEFAULT '',\n    79→\t\tstatus             TEXT NOT NULL DEFAULT 'pending',\n    80→\t\tmax_containers     INTEGER NOT NULL DEFAULT 4,\n    81→\t\trunning_containers INTEGER NOT NULL DEFAULT 0,\n    82→\t\tcreated_at         TEXT NOT NULL,\n    83→\t\tupdated_at         TEXT NOT NULL\n    84→\t);\n    85→\n    86→\tCREATE INDEX IF NOT EXISTS idx_instances_status ON instances(status);\n    87→\t`\n    88→\t_, err := s.db.Exec(schema)\n    89→\treturn err\n    90→}\n    91→\n    92→// --- Tasks ---\n    93→\n    94→func (s *SQLiteStore) CreateTask(ctx context.Context, task *models.Task) error {\n    95→\t_, err := s.db.ExecContext(ctx, `\n    96→\t\tINSERT INTO tasks (\n    97→\t\t\tid, status, repo_url, branch, target_branch, prompt, context,\n    98→\t\t\tmodel, effort, max_budget_usd, max_runtime_min, max_turns,\n    99→\t\t\tcreate_pr, s