{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JJHERLycwUq6D9wx4aLuiU","type":"tool_result","content":"     1→package models\n     2→\n     3→import (\n     4→\t\"encoding/json\"\n     5→\t\"fmt\"\n     6→\t\"time\"\n     7→)\n     8→\n     9→type TaskStatus string\n    10→\n    11→const (\n    12→\tTaskStatusPending      TaskStatus = \"pending\"\n    13→\tTaskStatusProvisioning TaskStatus = \"provisioning\"\n    14→\tTaskStatusRunning      TaskStatus = \"running\"\n    15→\tTaskStatusCompleted    TaskStatus = \"completed\"\n    16→\tTaskStatusFailed       TaskStatus = \"failed\"\n    17→\tTaskStatusInterrupted  TaskStatus = \"interrupted\"\n    18→\tTaskStatusCancelled    TaskStatus = \"cancelled\"\n    19→)\n    20→\n    21→func (s TaskStatus) IsTerminal() bool {\n    22→\treturn s == TaskStatusCompleted || s == TaskStatusFailed || s == TaskStatusCancelled\n    23→}\n    24→\n    25→type Task struct {\n    26→\tID            string            `json:\"id\"`\n    27→\tStatus        TaskStatus        `json:\"status\"`\n    28→\tRepoURL       string            `json:\"repo_url\"`\n    29→\tBranch        string            `json:\"branch\"`\n    30→\tTargetBranch  string            `json:\"target_branch\"`\n    31→\tPrompt        string            `json:\"prompt\"`\n    32→\tContext       string            `json:\"context,omitempty\"`\n    33→\tModel         string            `json:\"model,omitempty\"`\n    34→\tEffort        string            `json:\"effort,omitempty\"`\n    35→\tMaxBudgetUSD  float64           `json:\"max_budget_usd,omitempty\"`\n    36→\tMaxRuntimeMin int               `json:\"max_runtime_min,omitempty\"`\n    37→\tMaxTurns      int               `json:\"max_turns,omitempty\"`\n    38→\tCreatePR      bool              `json:\"create_pr\"`\n    39→\tSelfReview    bool              `json:\"self_review\"`\n    40→\tPRTitle       string            `json:\"pr_title,omitempty\"`\n    41→\tPRBody        string            `json:\"pr_body,omitempty\"`\n    42→\tPRURL         string            `json:\"pr_url,omitempty\"`\n    43→\tAllowedTools  []string          `json:\"allowed_tools,omitempty\"`\n    44→\tClaudeMD      string            `json:\"claude_md,omitempty\"`\n    45→\tEnvVars       map[string]string `json:\"env_vars,omitempty\"`\n    46→\tInstanceID    string            `json:\"instance_id,omitempty\"`\n    47→\tContainerID   string            `json:\"container_id,omitempty\"`\n    48→\tRetryCount    int               `json:\"retry_count\"`\n    49→\tCostUSD       float64           `json:\"cost_usd,omitempty\"`\n    50→\tError         string            `json:\"error,omitempty\"`\n    51→\tCreatedAt     time.Time         `json:\"created_at\"`\n    52→\tUpdatedAt     time.Time         `json:\"updated_at\"`\n    53→\tStartedAt     *time.Time        `json:\"started_at,omitempty\"`\n    54→\tCompletedAt   *time.Time        `json:\"completed_at,omitempty\"`\n    55→}\n    56→\n    57→// AllowedToolsJSON returns the JSON representation for DB storage.\n    58→func (t *Task) AllowedToolsJSON() string {\n    59→\tif len(t.AllowedTools) == 0 {\n    60→\t\treturn \"[]\"\n    61→\t}\n    62→\tb, _ := json.Marshal(t.AllowedTools)\n    63→\treturn string(b)\n    64→}\n    65→\n    66→// EnvVarsJSON returns the JSON representation for DB storage.\n    67→func (t *Task) EnvVarsJSON() string {\n    68→\tif len(t.EnvVars) == 0 {\n    69→\t\treturn \"{}\"\n    70→\t}\n    71→\tb, _ := json.Marshal(t.EnvVars)\n    72→\treturn string(b)\n    73→}\n    74→\n    75→// CreateTaskRequest is the API input for creating a task.\n    76→type CreateTaskRequest struct {\n    77→\tRepoURL       string            `json:\"repo_url\"`\n    78→\tBranch        string            `json:\"branch,omitempty\"`\n    79→\tTargetBranch  string            `json:\"target_branch,omitempty\"`\n    80→\tPrompt        string            `json:\"prompt\"`\n    81→\tContext       string            `json:\"context,omitempty\"`\n    82→\t